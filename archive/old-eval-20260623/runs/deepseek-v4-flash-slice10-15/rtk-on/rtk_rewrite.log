import re

with open('django/db/models/deletion.py', 'r') as f:
    content = f.read()

# The fast path currently:
old = '''        # Optimize for the case with a single obj and no dependencies
        if len(self.data) == 1 and len(instances) == 1:
            instance = list(instances)[0]
            if self.can_fast_delete(instance):
                with transaction.mark_for_rollback_on_error():
                    count = sql.DeleteQuery(model).delete_batch([instance.pk], self.using)
                return count, {model._meta.label: count}'''

new = '''        # Optimize for the case with a single obj and no dependencies
        if len(self.data) == 1 and len(instances) == 1:
            instance = list(instances)[0]
            if self.can_fast_delete(instance):
                with transaction.mark_for_rollback_on_error():
                    count = sql.DeleteQuery(model).delete_batch([instance.pk], self.using)
                if not model._meta.auto_created:
                    setattr(instance, model._meta.pk.attname, None)
                return count, {model._meta.label: count}'''

content = content.replace(old, new)

with open('django/db/models/deletion.py', 'w') as f:
    f.write(content)

print('File updated successfully')
