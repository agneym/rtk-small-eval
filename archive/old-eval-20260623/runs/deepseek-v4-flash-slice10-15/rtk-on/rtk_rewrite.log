import django
from django.conf import settings
settings.configure(
    DATABASES={
        'default': {
            'ENGINE': 'django.db.backends.sqlite3',
            'NAME': ':memory:',
        }
    },
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
)
django.setup()

from django.db import models, connection
from django.db.models import signals

# Test 1: Model with dependencies (should clear PK via slow path)
class Parent(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'

class Child(models.Model):
    parent = models.ForeignKey(Parent, on_delete=models.CASCADE)
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'

with connection.schema_editor() as schema_editor:
    schema_editor.create_model(Parent)
    schema_editor.create_model(Child)

# Test with dependencies (should go through slow path)
parent = Parent.objects.create(name='parent')
child = Child.objects.create(parent=parent, name='child')
child.delete()
print(f'Child PK after delete (with dependencies): {child.pk}')
assert child.pk is None, f'Expected None, got {child.pk}'

# Test with signal listeners (should go through slow path)
class SignalModel(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'

with connection.schema_editor() as schema_editor:
    schema_editor.create_model(SignalModel)

def handler(**kwargs):
    pass

signals.pre_delete.connect(handler, sender=SignalModel)

obj = SignalModel.objects.create(name='test')
obj.delete()
print(f'SignalModel PK after delete (with signals): {obj.pk}')
assert obj.pk is None, f'Expected None, got {obj.pk}'

# Test: Simple model with no deps (fast path)
class SimpleModel(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'

with connection.schema_editor() as schema_editor:
    schema_editor.create_model(SimpleModel)

obj = SimpleModel.objects.create(name='test')
obj.delete()
print(f'SimpleModel PK after delete (no deps): {obj.pk}')
assert obj.pk is None, f'Expected None, got {obj.pk}'

# Test: Bulk delete via queryset (should not clear PKs on instances)
obj2 = SimpleModel.objects.create(name='test2')
SimpleModel.objects.all().delete()
print(f'Bulk delete: obj2.pk after = {obj2.pk}')
# NOTE: bulk delete via queryset doesn't update instances, that's expected

print('All tests passed!')
""
",
