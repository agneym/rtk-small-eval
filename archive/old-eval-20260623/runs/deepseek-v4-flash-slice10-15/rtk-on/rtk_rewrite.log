import os
os.environ['DJANGO_SETTINGS_MODULE'] = 'tests.test_sqlite'

import django
django.setup()

from django.db.models import DurationField
from django.core.exceptions import ValidationError

# Test 1: Verify the error message format has been corrected
field = DurationField()
try:
    field.to_python('not a duration')
except ValidationError as e:
    msg = str(e)
    print('Test 1: Error message format')
    print(f'  Message: {msg}')
    assert '[DD] [[HH:]MM:]ss[.uuuuuu]' in msg, 'FAIL: New format string not found'
    assert '[DD] [HH:[MM:]]ss[.uuuuuu]' not in msg, 'FAIL: Old format string still present'
    print('  PASS')

# Test 2: Verify valid durations still work
print()
print('Test 2: Valid durations still parse correctly')
from django.utils.dateparse import parse_duration
import datetime

tests = [
    ('14:00', datetime.timedelta(minutes=14)),
    ('1:14:00', datetime.timedelta(hours=1, minutes=14)),
    ('30', datetime.timedelta(seconds=30)),
    ('1 12:00:00', datetime.timedelta(days=1, hours=12)),
]
for input_str, expected in tests:
    result = field.to_python(input_str)
    assert result == expected, f'FAIL: {input_str} -> {result} != {expected}'
    print(f'  {input_str:12s} -> {result}  PASS')

print()
print('All tests passed!')
""
