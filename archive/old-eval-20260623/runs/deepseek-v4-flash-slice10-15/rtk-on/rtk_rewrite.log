import django
from django.conf import settings
settings.configure(DEFAULT_CHARSET='utf-8')
django.setup()

from django.http import HttpResponse, StreamingHttpResponse

# Test 1: HttpResponse.write with memoryview
response = HttpResponse()
response.write(memoryview(b'Written content'))
print('Write memoryview:', repr(response.content))
assert response.content == b'Written content', f'Write memoryview failed: {response.content}'

# Test 2: StreamingHttpResponse with memoryview
response = StreamingHttpResponse([memoryview(b'chunk1'), memoryview(b'chunk2')])
content = response.getvalue()
print('Streaming with memoryview:', repr(content))
assert content == b'chunk1chunk2', f'Streaming memoryview failed: {content}'

# Test 3: Iterables still work
response = HttpResponse([b'chunk1', b'chunk2'])
print('Iterable bytes:', repr(response.content))
assert response.content == b'chunk1chunk2', f'Iterable failed: {response.content}'

# Test 4: Generator still works
def gen():
    yield b'from '
    yield b'generator'

response = HttpResponse(gen())
print('Generator:', repr(response.content))
assert response.content == b'from generator', f'Generator failed: {response.content}'

# Test 5: memoryview with StreamingHttpResponse make_bytes
response = StreamingHttpResponse()
result = list(response.streaming_content)  # empty
# Test that make_bytes works in streaming context
response = StreamingHttpResponse([memoryview(b'test')])
result = b''.join(response.streaming_content)
print('Streaming single memoryview:', repr(result))
assert result == b'test', f'Streaming single memoryview failed: {result}'

# Test 6: HttpResponse with list of memoryviews
response = HttpResponse([memoryview(b'part1 '), memoryview(b'part2')])
print('List of memoryviews:', repr(response.content))
assert response.content == b'part1 part2', f'List of memoryviews failed: {response.content}'

print()
print('All edge case tests passed!')
""",
