    f = models.CharField(max_length=10)
    class Meta: app_label = 'test'
field = Test3._meta.get_field('f')
errors = field.check()
assert len(errors) == 0
print('Test 3: No choices defined - PASSED')

# Test 4: Grouped choices with long value
class Test4(models.Model):
    f = models.CharField(max_length=3, choices=[('G1', [('A', 'Opt A'), ('LONG', 'Long')]), ('G2', [('B', 'Opt B')])])
    class Meta: app_label = 'test'
field = Test4._meta.get_field('f')
errors = field.check()
assert len(errors) == 1 and errors[0].id == 'fields.E122'
print('Test 4: Grouped choices with long value - PASSED')

# Test 5: Integer choices within bounds
class Test5(models.Model):
    f = models.CharField(max_length=3, choices=[(1, 'One'), (999, 'Nine')])
    class Meta: app_label = 'test'
field = Test5._meta.get_field('f')
errors = field.check()
assert len(errors) == 0
print('Test 5: Integer values within max_length - PASSED')

# Test 6: Integer choices too long
class Test6(models.Model):
    f = models.CharField(max_length=2, choices=[(100, 'One Hundred')])
    class Meta: app_label = 'test'
field = Test6._meta.get_field('f')
errors = field.check()
assert len(errors) == 1 and errors[0].id == 'fields.E122'
print('Test 6: Integer values too long - PASSED')

# Test 7: Lazy string choices too long
class Test7(models.Model):
    f = models.CharField(max_length=3, choices=[(_('hello'), 'Hello'), (_('hi'), 'Hi')])
    class Meta: app_label = 'test'
field = Test7._meta.get_field('f')
errors = field.check()
print('Errors:', errors)
assert len(errors) == 1 and errors[0].id == 'fields.E122'
print('Test 7: Lazy string values too long - PASSED')

# Test 8: max_length=None (CharField error)
class Test8(models.Model):
    f = models.CharField(choices=[('A', 'Option A')])
    class Meta: app_label = 'test'
field = Test8._meta.get_field('f')
errors = field.check()
# Should report fields.E120 (max_length not defined) but not crash
assert any(e.id == 'fields.E120' for e in errors)
print('Test 8: max_length=None - PASSED')

# Test 9: Mixed string lengths - one too long
