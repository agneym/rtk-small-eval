# Simulate what process_rhs does
from django.db.models.sql.query import Query
# clone first to avoid modifying the original
rhs = subq_query  # note: in real code, this is already resolved
print('Has limit one:', rhs.has_limit_one())
rhs.clear_select_clause()
print('After clear_select_clause:')
