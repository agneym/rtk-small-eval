import datetime
from django.utils.http import parse_http_date, http_date

# Current behavior test
# RFC850 date with two-digit year '94' -> should be 1994
# According to old logic: 94 >= 70, so 1994
print('Test 1: Sunday, 06-Nov-94 08:49:37 GMT')
parsed = parse_http_date('Sunday, 06-Nov-94 08:49:37 GMT')
print(f'  Parsed: {datetime.datetime.utcfromtimestamp(parsed)}')
print(f'  Expected: 1994-11-06 08:49:37')

# According to RFC 7231, in current year 2024:
# year=74 -> 2000+74=2074, 2074-2024=50 (not > 50), so should be 2074
# year=75 -> 2000+75=2075, 2075-2024=51 (> 50), so should be 1975
# But old logic: 70-99 -> 1900+yy

print()
print('Test 2: Current year is', datetime.datetime.now().year)
current_year = datetime.datetime.now().year
for yy in [0, 30, 50, 69, 70, 74, 75, 80, 94, 99]:
    candidate = 2000 + yy
    if candidate - current_year > 50:
        expected = 1900 + yy
    else:
        expected = 2000 + yy
    parsed = parse_http_date(f'Sunday, 06-Nov-{yy:02d} 08:49:37 GMT')
    parsed_year = datetime.datetime.utcfromtimestamp(parsed).year
    match = '✓' if parsed_year == expected else '✗'
    print(f'  yy={yy:2d} -> old={1900+yy if yy>=70 else 2000+yy} expected={expected} actual={parsed_year} {match}')
""
