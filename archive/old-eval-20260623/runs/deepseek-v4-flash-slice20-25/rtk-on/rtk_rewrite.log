import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')

import django
django.setup()

from enum import Enum
from django.utils.translation import gettext_lazy as _
from django.db.migrations.serializer import serializer_factory

class Status(Enum):
    GOOD = _('Good')  # translatable
    BAD = _('Bad')    # translatable
    
    def __str__(self):
        return self.name

# Test that the serialized form uses the NAME, not the VALUE
string, imports = serializer_factory(Status.GOOD).serialize()
print('Serialized:', string)

# The name should appear in the output, not the value
assert \""Status['GOOD']\"" in string, f'Expected Status[\\\""GOOD\\\""] in {string}'
assert \""'Good'\"" not in string or 'Good' not in string, 'Should not contain the translatable value'

print()
print('SUCCESS: The migration will use Status[\""GOOD\""] instead of Status(\""Good\"")')
print('This means translations can change without breaking old migrations.')
