outer_query = models.User.objects.filter(id=1).query
print('Outer query group_by:', outer_query.group_by)
print()

# Manually resolve the subquery
resolved = subq.query.resolve_expression(outer_query)
print('Resolved subquery:')
print('group_by:', resolved.group_by)
print('subquery:', resolved.subquery)
print('annotations:', resolved.annotations)
print()

# Now let's see what the compiler does
# Let's look at the resolved subquery's select
print('Resolved annotation_select:', resolved.annotation_select)
