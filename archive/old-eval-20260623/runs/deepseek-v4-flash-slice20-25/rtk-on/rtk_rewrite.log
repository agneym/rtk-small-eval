import os
os.environ['DJANGO_SETTINGS_MODULE'] = 'tests.test_sqlite'
import django
from django.conf import settings
settings.INSTALLED_APPS = [
    'django.contrib.contenttypes',
    'django.contrib.auth',
]
django.setup()

from django.contrib.auth import models
from django.db.models import Max
from django.db import connection
from django.db.models.sql import compiler as comp

# Let's trace through the compilation more carefully
a = models.User.objects.filter(email__isnull=True).values('email').annotate(m=Max('id')).values('m')

# Outer query
b = models.User.objects.filter(id=a[:1])

# Get a compiler for the outer query
outer_compiler = b.query.get_compiler(connection=connection)

# Let's look at the where clause to find the subquery
outer_compiler.pre_sql_setup()
print('Outer query where children:')
for child in outer_compiler.where.children:
    if hasattr(child, 'rhs') and hasattr(child.rhs, 'as_sql'):
        # This is the subquery
        print('  Found subquery in where')
        # The subquery will be compiled by calling rhs.as_sql
        # Let's see what happens when we compile it
        sql, params = child.rhs.as_sql(outer_compiler, connection)
        print('  SQL:', sql)
        print('  Params:', params)
""
