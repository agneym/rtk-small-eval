import django
from django.conf import settings
from django.urls import set_script_prefix

settings.configure(
    STATIC_URL='/static/',
    MEDIA_URL='/media/',
    INSTALLED_APPS=[],
    DATABASES={},
)
django.setup()

from django.templatetags.static import static, PrefixNode
from django.core.files.storage import FileSystemStorage

# Test edge case: script prefix without trailing slash
print('Test: script prefix without trailing slash')
set_script_prefix('/myapp')  # Note: set_script_prefix adds trailing slash internally
from django.urls import get_script_prefix
print(f'  get_script_prefix() = \""{get_script_prefix()}\""')
# It should have added trailing slash
assert get_script_prefix() == '/myapp/', 'set_script_prefix should add trailing slash'

# Test FileSystemStorage with a custom base_url
print()
print('Test: FileSystemStorage with custom base_url')
fs = FileSystemStorage()
fs.base_url = '/custom/static/'
set_script_prefix('/')
result = fs.url('img/logo.png')
print(f'  No prefix: {result}')
assert result == '/custom/static/img/logo.png', f'Unexpected: {result}'

set_script_prefix('/sub/')
result = fs.url('img/logo.png')
print(f'  With /sub/: {result}')
assert result == '/sub/custom/static/img/logo.png', f'Unexpected: {result}'

# Test MEDIA_URL with FileSystemStorage
print()
print('Test: MEDIA_URL with FileSystemStorage')
from django.core.files.storage import FileSystemStorage
media_storage = FileSystemStorage()
media_storage.base_url = '/media/'
set_script_prefix('/')
result = media_storage.url('uploads/file.pdf')
print(f'  No prefix: {result}')
assert result == '/media/uploads/file.pdf', f'Unexpected: {result}'

set_script_prefix('/myapp/')
result = media_storage.url('uploads/file.pdf')
print(f'  With /myapp/: {result}')
assert result == '/myapp/media/uploads/file.pdf', f'Unexpected: {result}'

print()
print('All edge case tests passed!')
