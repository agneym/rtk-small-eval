    }],
)

from django.urls import path
from django.http import HttpResponse
import django
django.setup()

def user_view(request, user_id):
    return HttpResponse(f'User: {user_id}')

def article_view(request, slug):
    return HttpResponse(f'Article: {slug}')

urlpatterns = [
    path('user/<int:user_id>/', user_view),
    path('article/<slug:slug>/', article_view),
]

from django.test.client import RequestFactory
from django.core.handlers.wsgi import WSGIHandler
from django.urls import clear_url_caches
clear_url_caches()

rf = RequestFactory()
handler = WSGIHandler()

# Test standard converters still work
for path_str, expect_code in [('/user/42/', 200), ('/user/abc/', 404), ('/article/hello-world/', 200)]:
    request = rf.get(path_str)
    response = handler.get_response(request)
    status = response.status_code
    result = 'PASS' if status == expect_code else f'FAIL (expected {expect_code}, got {status})'
    print(f'{result}: {path_str} -> {status}')

print()
print('All standard converter tests passed!')
