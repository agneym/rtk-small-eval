    'from urllib.parse import urljoin, urlsplit'
)
content = content.replace(
    'from django.conf import settings',
    'from django.conf import settings\nfrom django.urls import get_script_prefix'
)

with open('django/core/files/storage.py', 'w') as f:
    f.write(content)

print('Done')
