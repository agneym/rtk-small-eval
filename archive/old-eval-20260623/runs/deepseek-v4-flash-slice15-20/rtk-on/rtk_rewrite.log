import django
from django.conf import settings
from django.urls import set_script_prefix, get_script_prefix

# Configure Django settings
settings.configure(
    STATIC_URL='/static/',
    MEDIA_URL='/media/',
    INSTALLED_APPS=[],
    DATABASES={},
)

# Test 1: Default script prefix (no FORCE_SCRIPT_NAME)
set_script_prefix('/')
print('Test 1: Default prefix (/)')
print(f'  get_script_prefix() = \""{get_script_prefix()}\""')

# Test FileSystemStorage.url()
from django.core.files.storage import FileSystemStorage
fs = FileSystemStorage()
# We need to set base_url
fs.base_url = settings.STATIC_URL
url_result = fs.url('css/style.css')
print(f'  FileSystemStorage.url(\""css/style.css\"") = \""{url_result}\""')
assert url_result == '/static/css/style.css', f'Expected /static/css/style.css, got {url_result}'

# Test PrefixNode
from django.templatetags.static import PrefixNode
prefix_result = PrefixNode.handle_simple('STATIC_URL')
print(f'  PrefixNode.handle_simple(\""STATIC_URL\"") = \""{prefix_result}\""')
assert prefix_result == '/static/', f'Expected /static/, got {prefix_result}'

# Test with script prefix
set_script_prefix('/myapp/')
print()
print('Test 2: With script prefix /myapp/')
print(f'  get_script_prefix() = \""{get_script_prefix()}\""')

# FileSystemStorage.url() with script prefix
# The FileSystemStorage needs its base_url set properly
# Actually, we need to create a proper FileSystemStorage with base_url
fs2 = FileSystemStorage()
fs2.base_url = settings.STATIC_URL
url_result2 = fs2.url('css/style.css')
print(f'  FileSystemStorage.url(\""css/style.css\"") = \""{url_result2}\""')
assert url_result2 == '/myapp/static/css/style.css', f'Expected /myapp/static/css/style.css, got {url_result2}'

# Test PrefixNode with script prefix
prefix_result2 = PrefixNode.handle_simple('STATIC_URL')
print(f'  PrefixNode.handle_simple(\""STATIC_URL\"") = \""{prefix_result2}\""')
assert prefix_result2 == '/myapp/static/', f'Expected /myapp/static/, got {prefix_result2}'

# Test MEDIA_URL
prefix_media = PrefixNode.handle_simple('MEDIA_URL')
print(f'  PrefixNode.handle_simple(\""MEDIA_URL\"") = \""{prefix_media}\""')
assert prefix_media == '/myapp/media/', f'Expected /myapp/media/, got {prefix_media}'

# Test with STATIC_URL that has scheme (should NOT get prefix)
print()
print('Test 3: With absolute URL as STATIC_URL')
settings.STATIC_URL = 'https://cdn.example.com/static/'
prefix_result3 = PrefixNode.handle_simple('STATIC_URL')
print(f'  PrefixNode.handle_simple(\""STATIC_URL\"") = \""{prefix_result3}\""')
assert prefix_result3 == 'https://cdn.example.com/static/', f'Expected https://cdn.example.com/static/, got {prefix_result3}'

fs3 = FileSystemStorage()
fs3.base_url = settings.STATIC_URL
url_result3 = fs3.url('css/style.css')
print(f'  FileSystemStorage.url(\""css/style.css\"") = \""{url_result3}\""')
assert 'https://cdn.example.com/static/css/style.css' == url_result3, f'Expected https://cdn.example.com/static/css/style.css, got {url_result3}'

# Reset
settings.STATIC_URL = '/static/'

print()
print('All tests passed!')
