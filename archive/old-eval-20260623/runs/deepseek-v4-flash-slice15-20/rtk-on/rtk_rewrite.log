import sys
import os
import types
from pathlib import Path

# Verify the fix works with a proper simulation
# When python manage.py runserver is called, the child process has __main__.__file__ set

# Let's directly test that iter_modules_and_files handles __main__ correctly
from django.utils import autoreload

# Simulate a __main__ module as it would appear when running manage.py
main_module = types.ModuleType('__main__')
main_module.__file__ = '/path/to/manage.py'
# __spec__ is None when running a script
main_module.__spec__ = None

autoreload.iter_modules_and_files.cache_clear()
result = autoreload.iter_modules_and_files((main_module,), frozenset())
print(""Result frozenset:"", result)
assert len(result) == 1, f""Expected 1 file, got {len(result)}""
assert Path('/path/to/manage.py').resolve().absolute() in result
print(""SUCCESS: __main__ module with __file__ is correctly tracked!"")

# Test that a module without __spec__ and without __file__ doesn't cause issues
empty_module = types.ModuleType('test_module')
del empty_module.__spec__
# This module doesn't have __file__ attribute
autoreload.iter_modules_and_files.cache_clear()
result2 = autoreload.iter_modules_and_files((empty_module,), frozenset())
print(""Result2 frozenset:"", result2)
assert len(result2) == 0, f""Expected 0 files, got {len(result2)}""
print(""SUCCESS: module without __spec__ and __file__ is safely skipped!"")

# Test that a module with __spec__ set normally still works
normal_module = types.ModuleType('normal_module')
# Normal modules would have __spec__ set by import machinery
import django
autoreload.iter_modules_and_files.cache_clear()
result3 = autoreload.iter_modules_and_files((django,), frozenset())
print(""Result3 frozenset:"", result3)
assert len(result3) >= 1, f""Expected at least 1 file""
print(""SUCCESS: normal modules with __spec__ are still tracked!"")

print(""\nAll tests passed!"")
