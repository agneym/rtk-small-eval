import numpy as np
from astropy.modeling import models as m
from astropy.modeling.separable import separability_matrix, is_separable, _cstack

# Original test from PR
print(""=== PR Test Cases ==="")
cm = m.Linear1D(10) & m.Linear1D(5)
print(""Test 1 - cm = Linear1D(10) & Linear1D(5):"")
print(separability_matrix(cm))

print(""\nTest 2 - Pix2Sky_TAN & Linear1D(10) & Linear1D(5):"")
print(separability_matrix(m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)))

print(""\nTest 3 - Pix2Sky_TAN & cm (nested):"")
print(separability_matrix(m.Pix2Sky_TAN() & cm))

# More edge cases
print(""\n=== More Edge Cases ==="")
print(""\nTest 4 - (Linear1D(10) & Linear1D(5)) | (Linear1D(7) & Linear1D(8)) (composition of nested):"")
print(separability_matrix((m.Linear1D(10) & m.Linear1D(5)) | (m.Linear1D(7) & m.Linear1D(8))))

print(""\nTest 5 - (Linear1D(10) & Linear1D(5)) + (Linear1D(7) & Linear1D(8)) (arithmetic of nested):"")
print(separability_matrix((m.Linear1D(10) & m.Linear1D(5)) + (m.Linear1D(7) & m.Linear1D(8))))

# Deeply nested
print(""\nTest 6 - deeply nested:"")
nested = m.Pix2Sky_TAN() & (m.Linear1D(1) & m.Linear1D(2) & m.Linear1D(3))
print(separability_matrix(nested))

# Test the _cstack function directly
print(""\n=== Test _cstack directly ==="")
arr = np.array([[1, 0], [0, 1]])
result = _cstack(arr, m.Linear1D(10))
print(""cstack with ndarray left, model right:"")
print(result)

result = _cstack(m.Linear1D(10), arr)
print(""cstack with model left, ndarray right:"")
print(result)
EOF
