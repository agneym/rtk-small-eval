import re

with open('/testbed/astropy/io/fits/fitsrec.py', 'r') as f:
    content = f.read()

# Fix the bug
old = """"""        # Replace exponent separator in floating point numbers
        if 'D' in format:
            output_field.replace(encode_ascii('E'), encode_ascii('D'))""""""

new = """"""        # Replace exponent separator in floating point numbers
        if 'D' in format:
            output_field[:] = output_field.replace(encode_ascii('E'),
                                                    encode_ascii('D'))""""""

content = content.replace(old, new)

with open('/testbed/astropy/io/fits/fitsrec.py', 'w') as f:
    f.write(content)

print(""Done"")
EOF
