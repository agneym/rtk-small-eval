from astropy.io import fits
import numpy as np
import io

# Create a FITS file with a column with D format
# D format is for double-precision floating-point
col = fits.Column(name='DOUBLE', format='D10.5', array=np.array([1.5, 2.5, 3.5]))
table_hdu = fits.TableHDU.from_columns([col])

# Write to a buffer
buf = io.BytesIO()
table_hdu.writeto(buf)
buf.seek(0)

# Read back
hdu = fits.open(buf)[1]
data = hdu.data
print('DOUBLE column data:', data['DOUBLE'])

# Check the raw bytes to see if the D is in there
print()
print('Looking at raw bytes in the table:')
print(repr(hdu._data.tostring()[:100]))
""",
