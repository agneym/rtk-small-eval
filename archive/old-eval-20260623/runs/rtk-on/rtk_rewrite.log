from astropy.io import fits
import numpy as np
import io

# Test all FITS ASCII table number formats: F, E, D
data = {'F': np.array([1.5, 2.5, 3.5]),
        'E': np.array([1.5e10, 2.5e-5, 3.5]),
        'D': np.array([1.5, 2.5e20, 3.5])}

for fmt_code in ['F', 'E', 'D']:
    col = fits.Column(name=fmt_code, format=fmt_code + '14.5', array=data[fmt_code])
    table_hdu = fits.TableHDU.from_columns([col])
    
    buf = io.BytesIO()
    table_hdu.writeto(buf)
    buf.seek(0)
    
    hdu = fits.open(buf)[1]
    print(f'Format {fmt_code}: {repr(hdu.data.tostring()[:100])}')
    hdu.close()
""",
