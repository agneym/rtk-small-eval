import numpy as np
from astropy.nddata import NDDataRef
from astropy.nddata.mixins.ndarithmetic import NDArithmeticMixin

array = np.array([[0, 1, 0], [1, 0, 1], [0, 1, 0]])
mask = np.array([[0, 1, 64], [8, 0, 1], [2, 1, 0]])

nref_nomask = NDDataRef(array)
nref_mask = NDDataRef(array, mask=mask)

# Manually call _arithmetic_mask
self = nref_mask
operand = nref_nomask
print(""self.mask:"", self.mask)
print(""operand.mask:"", operand.mask)

# Add tracing
import functools
original_method = NDArithmeticMixin._arithmetic_mask

def traced_arithmetic_mask(self, operation, operand, handle_mask, axis=None, **kwds):
    print(f""_arithmetic_mask called: self.mask={self.mask}, operand.mask={getattr(operand, 'mask', None)}, handle_mask={handle_mask}"")
    return original_method(self, operation, operand, handle_mask, axis=axis, **kwds)

NDArithmeticMixin._arithmetic_mask = traced_arithmetic_mask

try:
    result = nref_mask.multiply(1., handle_mask=np.bitwise_or)
    print(""result.mask:"", result.mask)
except TypeError as e:
    print(""Error:"", e)
EOF
