from astropy.table import QTable, Table
import astropy.units as u
import sys
import io

# Test 1: Just name
print(""Test 1: header_rows=['name']"")
tbl = QTable({'wave': [350,950]*u.nm, 'response': [0.7, 1.2]*u.count})
buf = io.StringIO()
tbl.write(buf, format=""ascii.rst"", header_rows=[""name""])
print(buf.getvalue())
print()

# Test 2: With unit
print(""Test 2: header_rows=['name', 'unit']"")
buf = io.StringIO()
tbl.write(buf, format=""ascii.rst"", header_rows=[""name"", ""unit""])
print(buf.getvalue())
print()

# Test 3: Default (no header_rows)
print(""Test 3: default (no header_rows)"")
buf = io.StringIO()
tbl.write(buf, format=""ascii.rst"")
print(buf.getvalue())
print()

# Test 4: With Table (no units) and unit header row
print(""Test 4: Table (no units) with header_rows=['name', 'unit']"")
tbl = Table({'wave': [350,950], 'response': [0.7, 1.2]})
buf = io.StringIO()
tbl.write(buf, format=""ascii.rst"", header_rows=[""name"", ""unit""])
print(buf.getvalue())
print()

# Test 5: With Table (no units) and default
print(""Test 5: Table (no units) with default"")
buf = io.StringIO()
tbl.write(buf, format=""ascii.rst"")
print(buf.getvalue())
print()

# Test 6: Reading the output back
print(""Test 6: Reading RST with header_rows"")
out = """"""===== ======== 
 wave response
   nm       ct
===== ========
350.0      0.7
950.0      1.2
===== ========
""""""
print(""Cannot easily test read for now, just verify write works."")
EOF
