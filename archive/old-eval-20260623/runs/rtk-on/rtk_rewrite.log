                        # generate test fixtures
                        fixtures['mask1'] = [True, False, True]
                        fixtures['mask2'] = [True, False, False]
                    func(**fixtures)
                    passed += 1
                except Exception as e:
                    pass
    except Exception as e:
        print(f'{name} failed: {e}')
        traceback.print_exc()
        failed += 1
print(f'Passed: {passed}, Failed: {failed}')
