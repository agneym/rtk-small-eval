import numpy as np
from numpy import chararray

# Create a chararray with 2D shape similar to what the FITS code uses
# Format D is for double, E is for single
# The output_field is a chararray (likely 1D with width itemsize)

# Try with a structured array
arr = np.zeros(3, dtype='S14')
arr[0] = b'   1.50000E+00'
arr[1] = b'   2.50000E+00'
arr[2] = b'   3.50000E+00'
print('Before:')
print(arr)

# Convert to chararray
ca = arr.view(chararray)
print('As chararray:')
print(ca)
print('replace result:')
print(ca.replace(b'E', b'D'))
print('After replace (original):')
print(ca)
""",
