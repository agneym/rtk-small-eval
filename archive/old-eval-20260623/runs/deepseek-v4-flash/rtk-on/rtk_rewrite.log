# Let's verify the topological_sort functions work as expected
import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')
import django
django.setup()

from django.utils.topological_sort import stable_topological_sort, CyclicDependencyError

# Test case from PR description
graph = {}
graph['text-editor.js'] = set()
graph['text-editor-extras.js'] = {'text-editor.js'}
graph['color-picker.js'] = {'text-editor-extras.js'}

result = stable_topological_sort(['color-picker.js', 'text-editor.js', 'text-editor-extras.js'], graph)
print('Result:', result)

# Test with conflict
graph2 = {}
graph2['a'] = {'b'}
graph2['b'] = {'a'}

try:
    result2 = stable_topological_sort(['a', 'b'], graph2)
    print('Result2:', result2)
except CyclicDependencyError as e:
    print('Cycle detected:', e)
