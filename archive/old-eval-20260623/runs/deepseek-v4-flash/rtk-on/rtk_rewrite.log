import numpy as np

# Read the current file
with open('astropy/wcs/wcs.py', 'r') as f:
    content = f.read()

# The fix for _return_list_of_arrays
old_return_list = """"""        def _return_list_of_arrays(axes, origin):
            try:
                axes = np.broadcast_arrays(*axes)
            except ValueError:
                raise ValueError(
                    ""Coordinate arrays are not broadcastable to each other"")

            xy = np.hstack([x.reshape((x.size, 1)) for x in axes])

            if ra_dec_order and sky == 'input':
                xy = self._denormalize_sky(xy)
            output = func(xy, origin)
            if ra_dec_order and sky == 'output':
                output = self._normalize_sky(output)
                return (output[:, 0].reshape(axes[0].shape),
                        output[:, 1].reshape(axes[0].shape))
            return [output[:, i].reshape(axes[0].shape)
                    for i in range(output.shape[1])]""""""

new_return_list = """"""        def _return_list_of_arrays(axes, origin):
            try:
                axes = np.broadcast_arrays(*axes)
            except ValueError:
                raise ValueError(
                    ""Coordinate arrays are not broadcastable to each other"")

            xy = np.hstack([x.reshape((x.size, 1)) for x in axes])

            if xy.size == 0:
                # Return empty arrays matching the input shape
                # Make a dummy call to determine output shape
                dummy_xy = np.zeros((1, xy.shape[1]), dtype=xy.dtype)
                dummy_output = func(dummy_xy, origin)
                if ra_dec_order and sky == 'output':
                    dummy_output = self._normalize_sky(dummy_output)
                    return (np.array([]).reshape(axes[0].shape),
                            np.array([]).reshape(axes[0].shape))
                return [np.array([]).reshape(axes[0].shape)
                        for i in range(dummy_output.shape[1])]

            if ra_dec_order and sky == 'input':
                xy = self._denormalize_sky(xy)
            output = func(xy, origin)
            if ra_dec_order and sky == 'output':
                output = self._normalize_sky(output)
                return (output[:, 0].reshape(axes[0].shape),
                        output[:, 1].reshape(axes[0].shape))
            return [output[:, i].reshape(axes[0].shape)
                    for i in range(output.shape[1])]""""""

assert old_return_list in content, ""Could not find _return_list_of_arrays in wcs.py""

content = content.replace(old_return_list, new_return_list)

# Now fix _return_single_array
old_return_single = """"""        def _return_single_array(xy, origin):
            if xy.shape[-1] != self.naxis:
                raise ValueError(
                    ""When providing two arguments, the array must be ""
                    ""of shape (N, {0})"".format(self.naxis))
            if ra_dec_order and sky == 'input':
                xy = self._denormalize_sky(xy)
            result = func(xy, origin)
            if ra_dec_order and sky == 'output':
                result = self._normalize_sky(result)
            return result""""""

new_return_single = """"""        def _return_single_array(xy, origin):
            if xy.shape[-1] != self.naxis:
                raise ValueError(
                    ""When providing two arguments, the array must be ""
                    ""of shape (N, {0})"".format(self.naxis))
            if xy.shape[0] == 0:
                # Return empty array matching the output shape
                # Make a dummy call to determine output shape
                dummy_xy = np.zeros((1, xy.shape[1]), dtype=xy.dtype)
                dummy_result = func(dummy_xy, origin)
                if ra_dec_order and sky == 'output':
                    dummy_result = self._normalize_sky(dummy_result)
                return dummy_result[:0]
            if ra_dec_order and sky == 'input':
                xy = self._denormalize_sky(xy)
            result = func(xy, origin)
            if ra_dec_order and sky == 'output':
                result = self._normalize_sky(result)
            return result""""""

assert old_return_single in content, ""Could not find _return_single_array in wcs.py""

content = content.replace(old_return_single, new_return_single)

with open('astropy/wcs/wcs.py', 'w') as f:
    f.write(content)

print(""Done fixing"")
EOF
python /tmp/fix.py",
