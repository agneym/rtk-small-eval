import os
import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    LOCAL_FILE_DIR='/tmp/test_files',
    USE_TZ=True,
)
django.setup()

from django.db import models
from django import forms
from django.db.migrations.serializer import serializer_factory

# Edge case 1: Callable that returns different paths based on environment
os.makedirs('/tmp/test_env_a/example_dir', exist_ok=True)
os.makedirs('/tmp/test_env_b/example_dir', exist_ok=True)

_ENV = 'A'
def get_env_path():
    base = '/tmp/test_env_a' if _ENV == 'A' else '/tmp/test_env_b'
    return os.path.join(base, 'example_dir')

field = models.FilePathField(path=get_env_path)
print('Edge case 1: Environment-dependent path')
print('  path stored:', field.path)
form_field = field.formfield()
print('  resolved path:', form_field.path)
print()

# Edge case 2: Serialization round-trip
string, imports = serializer_factory(get_env_path).serialize()
print('Edge case 2: Serialization')
print('  serialized:', string)
print('  imports:', imports)
print()

# Edge case 3: Lambda (should fail to serialize, but work at runtime)
# Note: lambdas can't be serialized by the migration serializer
# but they work at runtime for formfield()
field_lambda = models.FilePathField(path=lambda: '/tmp/test_files/example_dir')
print('Edge case 3: Lambda path')
print('  path:', field_lambda.path)
form_field_lambda = field_lambda.formfield()
print('  resolved path:', form_field_lambda.path)
print()

# Test serialization failure for lambda
try:
    string, imports = serializer_factory(field_lambda.path).serialize()
    print('  lambda serialized:', string)
except ValueError as e:
    print('  lambda serialization error (expected):', e)
print()

# Edge case 4: Empty path '' (should not be in deconstruct kwargs)
field_empty = models.FilePathField()
name, path, args, kwargs = field_empty.deconstruct()
print('Edge case 4: Empty path')
print('  path in kwargs:', 'path' in kwargs)
print()

# Edge case 5: Normal string path
field_str = models.FilePathField(path='/tmp/test_files/example_dir')
name, path, args, kwargs = field_str.deconstruct()
print('Edge case 5: String path')
print('  path in kwargs:', 'path' in kwargs)
print('  kwargs path:', kwargs.get('path'))
""
