            css = {
                medium: self.merge(css.get(medium, []), obj.get(medium, []))
                for medium in css.keys() | obj.keys()
            }
        return css""""""

new_css = """"""    @property
    def _css(self):
        lists = [lst for lst in self._css_lists if lst]
        if not lists:
            return {}
        # Collect all medium -> list_of_file_lists
        medium_dict = {}
        for css_dict in lists:
            for medium, files in css_dict.items():
                if medium not in medium_dict:
                    medium_dict[medium] = []
                medium_dict[medium].append(files)
        # Merge per medium
        result = {}
        for medium, file_lists in medium_dict.items():
            result[medium] = self._merge_lists(file_lists)
        return result""""""

content = content.replace(old_css, new_css)

# Replace the _js property
old_js = """"""    @property
    def _js(self):
        js = self._js_lists[0]
        # filter(None, ...) avoids calling merge() with empty lists.
        for obj in filter(None, self._js_lists[1:]):
            js = self.merge(js, obj)
        return js""""""

new_js = """"""    @property
    def _js(self):
        return self._merge_lists([lst for lst in self._js_lists if lst])""""""

content = content.replace(old_js, new_js)

# Add the _merge_lists static method after the merge method
old_merge_end = """"""        return combined_list

    def __add__""""""

new_merge_end = """"""        return combined_list

    @staticmethod
    def _merge_lists(lists):
        """"""
        Merge multiple lists while trying to keep the relative order of the
        elements. Warn if the lists have the same two elements in a different
        relative order.

        For static assets it can be important to have them included in the DOM
        in a certain order. In JavaScript you may not be able to reference a
        global or in CSS you might want to override a style.
        """"""
        if not lists:
            return []
        # Build a dependency graph from all lists.
        graph = {}
        # Collect all items preserving order of first appearance.
        all_items = []
        for lst in lists:
            for item in lst:
                if item not in graph:
                    graph[item] = set()
                if item not in all_items:
                    all_items.append(item)
            # Add edges for consecutive pairs: if A comes before B in a list,
            # then B depends on A.
            for i in range(len(lst) - 1):
                a, b = lst[i], lst[i + 1]
                graph[b].add(a)
        try:
            return stable_topological_sort(all_items, graph)
        except CyclicDependencyError:
            # Fall back to sequential merge in case of conflicting orders.
            # This will detect and warn about conflicts.
            result = lists[0]
            for lst in lists[1:]:
                result = Media.merge(result, lst)
            return result

    def __add__""""""

content = content.replace(old_merge_end, new_merge_end)

with open('django/forms/widgets.py', 'w') as f:
    f.write(content)

print(""Done!"")
PYEOF
