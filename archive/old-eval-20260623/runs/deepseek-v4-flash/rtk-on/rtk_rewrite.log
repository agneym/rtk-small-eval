2026-06-23T14:41:02+00:00,a684a516743b4c06a73132f460f4265c,1,"cd /testbed && python -c ""
import numpy as np
from astropy.wcs import WCS

print('=' * 60)
print('COMPREHENSIVE TEST: Empty input handling')
print('=' * 60)

# Create a 2D WCS
wcs2d = WCS(naxis=2)
wcs2d.wcs.crpix = [256, 256]
wcs2d.wcs.cdelt = [0.1, 0.1]
wcs2d.wcs.crval = [100.0, 0.0]
wcs2d.wcs.ctype = ['RA---TAN', 'DEC--TAN']

# Create a 3D WCS
wcs3d = WCS(naxis=3)
wcs3d.wcs.crpix = [256, 256, 1]
wcs3d.wcs.cdelt = [0.1, 0.1, 1e-9]
wcs3d.wcs.crval = [100.0, 0.0, 1.420405752e9]
wcs3d.wcs.ctype = ['RA---TAN', 'DEC--TAN', 'FREQ']
wcs3d.wcs.cunit = ['deg', 'deg', 'Hz']

tests = []

# Test 1: 2D list of arrays empty
try:
    r = wcs2d.wcs_pix2world([], [], 0)
    assert isinstance(r, list) and len(r) == 2
    assert r[0].shape == (0,) and r[1].shape == (0,)
    tests.append(('2D wcs_pix2world([], [], 0)', 'PASS'))
except Exception as e:
    tests.append(('2D wcs_pix2world([], [], 0)', f'FAIL: {e}'))

# Test 2: 2D array of arrays empty
try:
    r = wcs2d.wcs_pix2world(np.array([]), np.array([]), 0)
    assert isinstance(r, list) and len(r) == 2
    assert r[0].shape == (0,) and r[1].shape == (0,)
    tests.append(('2D wcs_pix2world(np.array([]), np.array([]), 0)', 'PASS'))
except Exception as e:
    tests.append(('2D wcs_pix2world(np.array([]), np.array([]), 0)', f'FAIL: {e}'))

# Test 3: 2D single Nx2 array empty
try:
    r = wcs2d.wcs_pix2world(np.empty((0, 2)), 0)
    assert isinstance(r, np.ndarray) and r.shape == (0, 2)
    tests.append(('2D wcs_pix2world(np.empty((0,2)), 0)', 'PASS'))
except Exception as e:
    tests.append(('2D wcs_pix2world(np.empty((0,2)), 0)', f'FAIL: {e}'))

# Test 4: 2D all_pix2world empty
try:
    r = wcs2d.all_pix2world(np.empty((0, 2)), 0)
    assert isinstance(r, np.ndarray) and r.shape == (0, 2)
    tests.append(('2D all_pix2world(np.empty((0,2)), 0)', 'PASS'))
except Exception as e:
    tests.append(('2D all_pix2world(np.empty((0,2)), 0)', f'FAIL: {e}'))

# Test 5: 2D all_world2pix empty
try:
    r = wcs2d.all_world2pix(np.empty((0, 2)), 0)
    assert isinstance(r, np.ndarray) and r.shape == (0, 2)
    tests.append(('2D all_world2pix(np.empty((0,2)), 0)', 'PASS'))
except Exception as e:
    tests.append(('2D all_world2pix(np.empty((0,2)), 0)', f'FAIL: {e}'))

# Test 6: 3D list of arrays empty
try:
    r = wcs3d.wcs_pix2world([], [], [], 0)
    assert isinstance(r, list) and len(r) == 3
    assert all(arr.shape == (0,) for arr in r)
    tests.append(('3D wcs_pix2world([], [], [], 0)', 'PASS'))
except Exception as e:
    tests.append(('3D wcs_pix2world([], [], [], 0)', f'FAIL: {e}'))

# Test 7: 3D single Nx3 array empty
try:
    r = wcs3d.all_pix2world(np.empty((0, 3)), 0)
    assert isinstance(r, np.ndarray) and r.shape == (0, 3)
    tests.append(('3D all_pix2world(np.empty((0,3)), 0)', 'PASS'))
except Exception as e:
    tests.append(('3D all_pix2world(np.empty((0,3)), 0)', f'FAIL: {e}'))

# Test 8: 2D wcs_world2pix with empty lists
try:
    r = wcs2d.wcs_world2pix([], [], 0)
    assert isinstance(r, list) and len(r) == 2
    assert r[0].shape == (0,) and r[1].shape == (0,)
    tests.append(('2D wcs_world2pix([], [], 0)', 'PASS'))
except Exception as e:
    tests.append(('2D wcs_world2pix([], [], 0)', f'FAIL: {e}'))

# Test 9: Non-empty still works
try:
    r = wcs2d.wcs_pix2world([1, 2, 3], [4, 5, 6], 0)
    assert isinstance(r, list) and len(r) == 2
    assert r[0].shape == (3,)
    tests.append(('2D wcs_pix2world([1,2,3], [4,5,6], 0) non-empty', 'PASS'))
except Exception as e:
    tests.append(('2D wcs_pix2world([1,2,3], [4,5,6], 0) non-empty', f'FAIL: {e}'))

# Test 10: 2D single Nx2 array non-empty
try:
    r = wcs2d.wcs_pix2world(np.array([[1, 4], [2, 5], [3, 6]]), 0)
    assert isinstance(r, np.ndarray) and r.shape == (3, 2)
    tests.append(('2D wcs_pix2world(Nx2) non-empty', 'PASS'))
except Exception as e:
    tests.append(('2D wcs_pix2world(Nx2) non-empty', f'FAIL: {e}'))

# Print results
print()
for name, result in tests:
    print(f'  {name}: {result}')

print()
print(f'Total: {len(tests)} tests')
print(f'Pass: {sum(1 for _, r in tests if r == \""PASS\"")}')
print(f'Fail: {sum(1 for _, r in tests if r != \""PASS\"")}')
""
",
