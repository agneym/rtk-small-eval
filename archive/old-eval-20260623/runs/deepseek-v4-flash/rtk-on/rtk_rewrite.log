import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')
import django
django.setup()

import warnings

from django.forms.widgets import Media, MediaOrderConflictWarning

# Let's trace each step
widget1 = Media(js=['custom_widget.js'])
widget2 = Media(js=['jquery.js', 'uses_jquery.js'])
form_media = widget1 + widget2
print('form_media._js_lists:', form_media._js_lists)
print('form_media._js:', form_media._js)
print()

inline_media = Media(js=['jquery.js', 'also_jquery.js']) + Media(js=['custom_widget.js'])
print('inline_media._js_lists:', inline_media._js_lists)
print('inline_media._js:', inline_media._js)
print()

merged = form_media + inline_media
print('merged._js_lists:', merged._js_lists)

# Now trace _js manually
with warnings.catch_warnings(record=True) as w:
    warnings.simplefilter('always')
    
    js_lists = merged._js_lists
    print('js_lists:', js_lists)
    
    js = js_lists[0]
    print('Starting with:', js)
    
    for obj in [l for l in js_lists[1:] if l]:
        print(f'Merging {js} with {obj}')
        js = Media.merge(js, obj)
        print(f'Result: {js}')
        for warning in w:
            print(f'Warning caught: {warning.message}')
            w.pop()  # remove it so we don't count it again
    
    print('Final result:', js)
""
