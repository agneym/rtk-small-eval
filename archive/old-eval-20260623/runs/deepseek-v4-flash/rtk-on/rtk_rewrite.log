import os
import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=[
        'django.contrib.contenttypes', 
        'django.contrib.auth',
    ],
    LOCAL_FILE_DIR='/tmp/test_files',
)
django.setup()

from django.db import models
from django.db.migrations.writer import MigrationWriter
from django.db.migrations.serializer import serializer_factory
from django.db.migrations.state import ProjectState

# Simulate what happens in a migration

# 1. Define a function
def get_path():
    return os.path.join(settings.LOCAL_FILE_DIR, 'example_dir')

# 2. Create a field with this function as path
field = models.FilePathField(path=get_path)

# 3. Deconstruct the field  
name, path, args, kwargs = field.deconstruct()
print('Deconstructed field:')
print('  name:', name)
print('  path:', path)
print('  args:', args)
print('  kwargs:', kwargs)

# 4. Serialize the kwargs (like the migration writer does)
for key, value in kwargs.items():
    try:
        string, imports = serializer_factory(value).serialize()
        print(f'  {key}: serialized as: {string!r}, imports: {imports}')
    except Exception as e:
        print(f'  {key}: serialization error: {e}')

# 5. Test that the round-trip works
# Simulate what the migration would produce
# path=get_path where get_path is imported from __main__

# Try to recreate the field using the serialized kwargs
field2 = models.FilePathField(path=get_path)
print()
print('Recreated field:')
print('  path:', field2.path)
print('  path callable:', callable(field2.path))

# Test formfield
form_field = field2.formfield()
print('  formfield path:', form_field.path)
""
