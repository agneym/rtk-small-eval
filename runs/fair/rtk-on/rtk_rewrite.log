import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
)
django.setup()

from django.db import models, connection

class Company(models.Model):
    name = models.CharField(max_length=50)
    trade_number = models.CharField(max_length=50)
    country = models.CharField(max_length=50)
    
    class Meta:
        app_label = 'test'

# Edge case 1: only(), then defer() of a field that wasn't in only()
print('=== Edge case 1: only(name).defer(country) ===')
qs1 = Company.objects.only('name').defer('country')
print(str(qs1.query))

# Edge case 2: defer(), then only()
print('\n=== Edge case 2: defer(name).only(name, country) ===')
qs2 = Company.objects.defer('name').only('name', 'country')
print(str(qs2.query))

# Edge case 3: defer(), then only() with a deferred field removed
print('\n=== Edge case 3: defer(name, country).only(name) ===')
qs3 = Company.objects.defer('name', 'country').only('name')
print(str(qs3.query))

# Edge case 4: only() then defer() of all fields
print('\n=== Edge case 4: only(name, country, trade_number).defer(name, country, trade_number) ===')
qs4 = Company.objects.only('name', 'country', 'trade_number').defer('name', 'country', 'trade_number')
print(str(qs4.query))

# Edge case 5: defer(None) to clear (should still work)
print('\n=== Edge case 5: only(name).defer(None) ===')
qs5 = Company.objects.only('name').defer(None)
print(str(qs5.query))

# Edge case 6: just only()
print('\n=== Edge case 6: only(name) ===')
qs6 = Company.objects.only('name')
print(str(qs6.query))

# Edge case 7: just defer()
print('\n=== Edge case 7: defer(name) ===')
qs7 = Company.objects.defer('name')
print(str(qs7.query))
""
