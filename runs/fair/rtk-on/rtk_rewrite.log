            field for constraint in cls._meta.constraints
            if isinstance(constraint, UniqueConstraint)
            for field in constraint.fields
        ]
        errors.extend(cls._check_local_fields(fields, 'constraints'))
        return errors


############################################
# HELPER FUNCTIONS (CURRIED MODEL METHODS) #
############################################'''

if search in content:
    print('Found the target text')
    new_content = content.replace(search, replace)
    with open('django/db/models/base.py', 'w') as f:
        f.write(new_content)
    print('Successfully modified the file')
else:
    print('Could not find the target text')
    # Debug: show context around 'return errors'
    idx = content.index('return errors')
    print(content[idx-50:idx+200])
