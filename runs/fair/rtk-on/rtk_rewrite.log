from django.db import models, connection

# Create models
class CustomModel(models.Model):
    name = models.CharField(max_length=16)
    class Meta:
        app_label = 'test_app2'

class ProxyCustomModel(CustomModel):
    class Meta:
        proxy = True
        app_label = 'test_app2'

class RegularModel(models.Model):
    title = models.CharField(max_length=16)
    class Meta:
        app_label = 'test_app2'

class AnotherModel(models.Model):
    custom = models.ForeignKey(
        ProxyCustomModel,
        on_delete=models.SET_NULL,
        null=True,
        blank=True,
    )
    regular = models.ForeignKey(
        RegularModel,
        on_delete=models.SET_NULL,
        null=True,
        blank=True,
    )
    class Meta:
        app_label = 'test_app2'

# Create tables
with connection.schema_editor() as schema_editor:
    schema_editor.create_model(CustomModel)
    schema_editor.create_model(RegularModel)
    schema_editor.create_model(AnotherModel)

# Insert test data
c1 = CustomModel.objects.create(name='test1')
r1 = RegularModel.objects.create(title='regular1')
AnotherModel.objects.create(custom=ProxyCustomModel.objects.first(), regular=r1)

# Test 1: Original bug case - proxy model with select_related and only
print('=== Test 1: Proxy model with select_related and only ===')
qs = AnotherModel.objects.select_related('custom').only('custom__name')
print('Query:', qs.query)
try:
    result = list(qs)
    print('Success!')
    for obj in result:
        if obj.custom:
            print(f'  Custom id={obj.custom.id}, name={obj.custom.name}')
except Exception as e:
    import traceback
    traceback.print_exc()
print()

# Test 2: Regular model with select_related and only (should still work)
print('=== Test 2: Regular model with select_related and only ===')
qs = AnotherModel.objects.select_related('regular').only('regular__title')
print('Query:', qs.query)
try:
    result = list(qs)
    print('Success!')
    for obj in result:
        if obj.regular:
            print(f'  Regular id={obj.regular.id}, title={obj.regular.title}')
except Exception as e:
    import traceback
    traceback.print_exc()
print()

# Test 3: Multiple select_related with only
print('=== Test 3: Multiple select_related with only ===')
qs = AnotherModel.objects.select_related('custom', 'regular').only('custom__name', 'regular__title')
print('Query:', qs.query)
try:
    result = list(qs)
    print('Success!')
    for obj in result:
        if obj.custom:
            print(f'  Custom id={obj.custom.id}, name={obj.custom.name}')
        if obj.regular:
            print(f'  Regular id={obj.regular.id}, title={obj.regular.title}')
except Exception as e:
    import traceback
    traceback.print_exc()
print()

# Test 4: Proxy model without only (should still work)
print('=== Test 4: Proxy model select_related without only ===')
qs = AnotherModel.objects.select_related('custom')
print('Query:', qs.query)
try:
    result = list(qs)
    print('Success!')
    for obj in result:
        if obj.custom:
            print(f'  Custom id={obj.custom.id}, name={obj.custom.name}')
except Exception as e:
    import traceback
    traceback.print_exc()
print()

# Test 5: Proxy model with only (no select_related)
print('=== Test 5: Proxy model only (no select_related) ===')
qs = AnotherModel.objects.only('custom')
print('Query:', qs.query)
try:
    result = list(qs)
    print('Success!')
except Exception as e:
    import traceback
    traceback.print_exc()
print()
