from django.db import models
import django
from django.conf import settings
settings.configure(USE_I18N=False)
django.setup()

from django.core import exceptions

f = models.DurationField()
try:
    f.clean('not a datetime', None)
except exceptions.ValidationError as e:
    # Bypass lazy translation
    msg = str(e.message) % e.params
    print('Error message:', msg)
    
    expected_format = '[DD] [[HH:]MM:]ss[.uuuuuu]'
    if expected_format in msg:
        print('SUCCESS: Format string is correct!')
    else:
        print('FAIL: Format string not found!')
        print('Expected:', expected_format)
