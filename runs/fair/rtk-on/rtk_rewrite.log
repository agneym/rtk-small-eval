import django
from django.conf import settings
settings.configure(USE_I18N=True, USE_L10N=True)
django.setup()

from urllib.parse import urlsplit
from django.core.validators import URLValidator
import re

v = URLValidator()

# The ipv6_re in the regex is: \[[0-9a-f:.]+\]
# Let's check if we can pass the regex with something that urlsplit rejects

# Check what urlsplit does with various bracket expressions
bracket_tests = [
    # Basic valid IPv6
    'http://[::1]',
    # Just brackets with invalid IPv6 content
    'http://[g]',  # 'g' is not in 0-9a-f, so won't match
    'http://[a]',  # 'a' is in 0-9a-f
    'http://[ab]',
    'http://[abc]',
]

for url in bracket_tests:
    regex_match = bool(v.regex.search(str(url)))
    try:
        parsed = urlsplit(url)
        url_ok = True
    except ValueError as e:
        url_ok = False
        err = str(e)
    
    try:
        v(url)
        val_ok = True
    except Exception as e:
        val_ok = False
        val_err = f'{type(e).__name__}: {e}'
    
    print(f'URL: {url!r}')
    print(f'  Regex match: {regex_match}, urlsplit OK: {url_ok}, Validator OK: {val_ok}')
    if not url_ok:
        print(f'  urlsplit error: {err}')
    if not val_ok:
        print(f'  Validator error: {val_err}')
    print()
""",
