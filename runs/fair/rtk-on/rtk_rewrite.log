from django.apps.config import AppConfig
# Need to create a proper app config
class TestAppConfig(AppConfig):
    name = 'test'
    label = 'test'
    verbose_name = 'Test'
    path = '/testbed'

# We need to register these with Django's app registry properly
# Let's just use the models directly without app registration
# by creating the tables manually

with connection.schema_editor() as editor:
    editor.create_model(Author)
    editor.create_model(Book)

# Test 2: Author (has reverse FK from Book with CASCADE), empty queryset
print('Test 2: Author (has reverse FK via Book), empty queryset')
result = Author.objects.filter(id__in=[]).delete()
print(f'  Result: {result}')

# Test 3: Book (has forward FK, no reverse FK), empty queryset
print('Test 3: Book (forward FK, no reverse FK), empty queryset')
result = Book.objects.filter(id__in=[]).delete()
print(f'  Result: {result}')
