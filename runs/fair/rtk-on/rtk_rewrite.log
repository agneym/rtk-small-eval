from django.forms.models import ModelChoiceIteratorValue

# Test all the key behaviors
v1 = ModelChoiceIteratorValue(1, 'instance1')
v2 = ModelChoiceIteratorValue(2, 'instance2')
v3 = ModelChoiceIteratorValue(1, 'instance3')  # Same value as v1, different instance

# 1. __str__
assert str(v1) == '1', f'str(v1) = {str(v1)}'

# 2. __eq__ with same type
assert v1 == v3  # Same value
assert v1 != v2  # Different value

# 3. __eq__ with plain value
assert v1 == 1  # Same as underlying value
assert v1 != 2

# 4. __hash__
assert hash(v1) == hash(1), f'hash(v1) = {hash(v1)}, hash(1) = {hash(1)}'
assert hash(v1) == hash(v3), f'Hash should match for equal values'

# 5. Use as dict key (the exact use case from the PR)
show_fields = {1: ['first_name', 'last_name']}
assert v1 in show_fields, 'ModelChoiceIteratorValue should be findable in dict with int keys'
assert show_fields[v1] == ['first_name', 'last_name']

# 6. Use as dict key in a dict keyed by ModelChoiceIteratorValue
d = {v1: 'hello'}
assert d[v3] == 'hello', 'Should be able to look up by equal value'

# 7. Use in set
s = {v1, v2, v3}
assert len(s) == 2, f'Set should have 2 elements (v1 and v3 are equal), got {len(s)}'

print('All tests passed!')
""
