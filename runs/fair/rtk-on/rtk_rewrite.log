print(""Test 2: Non-static path passes through to app"")
print(""="" * 60)

scope2 = {
    'type': 'http',
    'method': 'GET',
    'path': '/some/other/path',
    'headers': [],
    'query_string': b'',
}

app_called = False
async def app2(scope, receive, send):
    global app_called
    app_called = True

handler2 = ASGIStaticFilesHandler(app2)
loop.run_until_complete(handler2(scope2, receive, send))
if app_called:
    print(""PASS: Non-static path correctly passed to wrapped app"")
else:
    print(""FAIL: Non-static path was not passed to wrapped app"")

# Test 3: WSGI handler still works
