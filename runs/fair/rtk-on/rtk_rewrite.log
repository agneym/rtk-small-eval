import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'settings')
import django
django.setup()

from django.apps import apps
from django.db import connection

# Get the models
ProjectDataSet = apps.get_model('testapp', 'ProjectDataSet')
Authors = apps.get_model('testapp', 'Authors')

# Check if the unique constraint exists
with connection.cursor() as cursor:
    constraints = connection.introspection.get_constraints(cursor, 'testapp_authors')
    print(""Constraints on testapp_authors:"")
    for name, info in constraints.items():
        print(f""  {name}: columns={info['columns']}, unique={info['unique']}"")

# Now simulate the alter_unique_together call with old_model
# The old model has project_data_set as FK
# The new model has project_data_set as M2M

# Call alter_unique_together with old_model for deletion
old_together = {('project_data_set', 'state', 'start_date')}
new_together = set()

print(f""\\nTesting alter_unique_together with old_model (FK)..."")
try:
    with connection.schema_editor() as schema_editor:
        schema_editor.alter_unique_together(
            Authors,  # old_model (has FK)
            old_together,
            new_together,  # empty - delete all
        )
    print(""  SUCCESS: Deleted constraint using old_model"")
except ValueError as e:
    print(f""  FAILED: {e}"")
except Exception as e:
    print(f""  ERROR: {type(e).__name__}: {e}"")

# Re-add the constraint for further testing
print(f""\\nRe-adding the constraint using old_model..."")
try:
    with connection.schema_editor() as schema_editor:
        schema_editor.alter_unique_together(
            Authors,  # old_model (has FK)
            set(),
            old_together,
        )
    print(""  SUCCESS: Re-added constraint"")
except Exception as e:
    print(f""  ERROR: {type(e).__name__}: {e}"")

# Now try with old_model for deletion and new_model for creation
print(f""\\nTesting: delete with old_model (FK), create with new_model (M2M)..."")
try:
    with connection.schema_editor() as schema_editor:
        # Delete with old_model
        schema_editor.alter_unique_together(
            Authors,  # old_model (has FK)
            old_together,
            set(),
        )
    print(""  SUCCESS: Deleted constraint using old_model"")
except ValueError as e:
    print(f""  FAILED: {e}"")
except Exception as e:
    print(f""  ERROR: {type(e).__name__}: {e}"")

# Re-add for verification
with connection.schema_editor() as schema_editor:
    schema_editor.alter_unique_together(
        Authors,
        set(),
        old_together,
    )
print(""\\nAll tests passed!"")
''')

