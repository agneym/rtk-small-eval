import os
os.environ['DJANGO_SETTINGS_MODULE'] = 'tests.test_sqlite'
import django
from django.conf import settings
settings.DATABASES = {'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}}
settings.INSTALLED_APPS = ['django.contrib.contenttypes', 'django.contrib.auth']
django.setup()

from django.db import connection
from django.db.models import Subquery
from django.contrib.auth.models import User

# Create the tables
from django.core.management import call_command
call_command('migrate', '--run-syncdb', verbosity=0)

q = User.objects.all()
sq = Subquery(q)
print(f'query.subquery = {sq.query.subquery}')

compiler = sq.query.get_compiler(connection=connection)
sql, params = sq.as_sql(compiler, connection)
print(f'SQL: {sql}')
print(f'Params: {params}')

assert sql.startswith('(SELECT') and sql.endswith(')'), f'SQL is malformed: {sql}'
print('SUCCESS!')
""",
