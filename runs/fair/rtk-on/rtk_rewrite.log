import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')
import django
django.setup()

from django.db import connection
from django.db.models import IntegerField, Value
from django.db.models.sql import Query as SqlQuery

# Test: check that calling distinct on a combined query doesn't raise an error
# but also doesn't work (silently fails)

# Let's verify the current behavior
q = SqlQuery('test_number')
q.combinator = 'union'
print('Has combinator:', q.combinator)
print('Distinct fields before:', q.distinct_fields)
q.add_distinct_fields('name')
