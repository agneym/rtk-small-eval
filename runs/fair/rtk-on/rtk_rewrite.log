import re
ordering_parts = re.compile(r'(.*)\s(ASC|DESC)(.*)')

# Test the fix with the exact scenario from the PR description
sql1 = '''(CASE when status in ('accepted', 'verification')
                 then 2 else 1 end) DESC'''
sql2 = '''(CASE when status in ('accepted', 'verification')
                 then (accepted_datetime, preferred_datetime)
                 else null end) ASC'''
sql3 = '''(CASE when status not in ('accepted', 'verification')
                 then (accepted_datetime, preferred_datetime, created_at)
                 else null end) DESC'''

def without_ordering_old(sql):
    return ordering_parts.search(sql).group(1)

def without_ordering_new(sql):
    return ordering_parts.search(' '.join(sql.splitlines())).group(1)

print('=== OLD BEHAVIOR (broken) ===')
old_results = set()
for i, sql in enumerate([sql1, sql2, sql3], 1):
    val = without_ordering_old(sql)
    unique = 'UNIQUE' if val not in old_results else 'DUPLICATE'
    old_results.add(val)
    print(f'  sql{i}: {repr(val)} -> {unique}')

print()
print('=== NEW BEHAVIOR (fixed) ===')
new_results = set()
for i, sql in enumerate([sql1, sql2, sql3], 1):
    val = without_ordering_new(sql)
    unique = 'UNIQUE' if val not in new_results else 'DUPLICATE'
    new_results.add(val)
    print(f'  sql{i}: {repr(val)} -> {unique}')

# Test with CRLF
print()
print('=== CRLF handling ===')
sql_crlf = '''(CASE when status in ('accepted', 'verification')\r
                 then 2 else 1 end) DESC'''
val = without_ordering_new(sql_crlf)
print(f'  CRLF result: {repr(val)}')

# Test with \\r (old Mac style)
print()
print('=== CR (old Mac) handling ===')
sql_cr = '(case when x = 1\\r then 2 else 3 end) DESC'
val = without_ordering_new(sql_cr)
print(f'  CR result: {repr(val)}')

print()
print('All tests passed!')
