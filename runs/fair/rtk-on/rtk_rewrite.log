import re

# Read the forms/fields.py file
with open('django/forms/fields.py', 'r') as f:
    content = f.read()

# Find the FilePathField.__init__ method and add callable handling
old = """"""class FilePathField(ChoiceField):
    def __init__(self, path, *, match=None, recursive=False, allow_files=True,
                 allow_folders=False, **kwargs):
        self.path, self.match, self.recursive = path, match, recursive
        self.allow_files, self.allow_folders = allow_files, allow_folders""""""

new = """"""class FilePathField(ChoiceField):
    def __init__(self, path, *, match=None, recursive=False, allow_files=True,
                 allow_folders=False, **kwargs):
        if callable(path):
            path = path()
        self.path, self.match, self.recursive = path, match, recursive
        self.allow_files, self.allow_folders = allow_files, allow_folders""""""

if old in content:
    content = content.replace(old, new, 1)
    with open('django/forms/fields.py', 'w') as f:
        f.write(content)
    print(""SUCCESS: Updated django/forms/fields.py"")
else:
    print(""FAILED: Could not find the target text in django/forms/fields.py"")
EOF
