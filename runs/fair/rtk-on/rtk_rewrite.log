print(f'Test 3 - list value:')
print(f'  Result:   {result!r}')
print(f'  Expected: {json.dumps(value)!r}')
print(f'  Match: {result == json.dumps(value)}')

# Test with nested value
value = {'name': 'John', 'age': 30, 'items': [1, 2, 3]}
result = display_for_field(value, field, '')
print(f'Test 4 - nested dict:')
print(f'  Result:   {result!r}')
print(f'  Expected: {json.dumps(value)!r}')
print(f'  Match: {result == json.dumps(value)}')

