    for migration in migrations_list:
        print(f'Migration for {app_label}:')
        for op in migration.operations:
            print(f'  {op.__class__.__name__}: {op.describe()}')
            if hasattr(op, 'field') and op.field:
                f = op.field
                if hasattr(f, 'remote_field') and f.remote_field:
                    to_field = getattr(f.remote_field, 'field_name', None)
                    print(f'    to_field: {to_field}')
                # Also show deconstruct for ForeignKey fields
                if isinstance(f, models.ForeignKey):
                    decon = f.deconstruct()
                    print(f'    deconstruct kwargs keys: {list(decon[3].keys())}')
                    if 'to_field' in decon[3]:
                        print(f'    deconstruct to_field: {decon[3][\""to_field\""]}')
