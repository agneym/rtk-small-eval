import os
import sys
sys.path.insert(0, 'tests')

os.environ['DJANGO_SETTINGS_MODULE'] = 'test_sqlite'

import django
from django.conf import settings
settings.DATABASES['default']['NAME'] = ':memory:'

django.setup()

from django.db import connection
from django.db.migrations.state import ProjectState
from django.db.migrations import operations
import django.db.models as models
from django.db.migrations.state import ModelState

# Create project state with index_together
project_state = ProjectState()
app_label = 'test_rninui'

model_state = ModelState(
    app_label,
    'Pony',
    [
        ('id', models.AutoField(primary_key=True)),
        ('pink', models.IntegerField(default=3)),
        ('weight', models.FloatField()),
    ],
    options={
        'index_together': {('weight', 'pink')},
    },
)
project_state.add_model(model_state)

# Before creating table, check state model's indexes
print(""Before DB creation:"")
model = project_state.apps.get_model(app_label, 'Pony')
print(""  _meta.indexes:"", model._meta.indexes)
print(""  _meta.index_together:"", model._meta.index_together)

# Create the table
with connection.schema_editor() as editor:
    for model in project_state.apps.get_models():
        editor.create_model(model)

# Check the model after DB creation
print(""\nAfter DB creation:"")
# The model from state's apps might not have been reloaded
# Let's check the database
with connection.cursor() as cursor:
    cursor.execute(f""SELECT name FROM sqlite_master WHERE type='index' AND tbl_name='{app_label}_pony'"")
    indexes = [r[0] for r in cursor.fetchall()]
    print(""  DB indexes:"", indexes)

# Now check if there's a method to find the auto-generated name
# _create_index_name on the schema editor
from django.db.backends.base.schema import BaseDatabaseSchemaEditor
print(f""\ncan_rename_index: {connection.features.can_rename_index}"")

# Let's look at how the index name is computed
schema_editor = connection.schema_editor()
# The _create_index_name method
table_name = f""{app_label}_pony""
columns = ['weight', 'pink']
# Get the column names from fields
from_model = project_state.apps.get_model(app_label, 'Pony')
cols = [from_model._meta.get_field(f).column for f in ('weight', 'pink')]
print(f""\nColumns: {cols}"")

# Use _constraint_names to find the index
with connection.schema_editor() as editor:
    matching = editor._constraint_names(from_model, column_names=cols, index=True)
    print(f""Matching indexes: {matching}"")

# Let me also check what rename_index does on SQLite vs PostgreSQL
print(f""\nSQLite features.can_rename_index: {connection.features.can_rename_index}"")

# Clean up
with connection.schema_editor() as editor:
    editor.delete_model(model_state.apps.get_model(app_label, 'Pony'))
