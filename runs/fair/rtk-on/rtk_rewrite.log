import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
)
django.setup()

from django.db import models, connection
from django.db.models import Q, ExpressionWrapper, BooleanField, Value, F

class TestModel(models.Model):
    name = models.CharField(max_length=100)
    age = models.IntegerField(default=0)
    class Meta:
        app_label = 'test'

qs = TestModel.objects.all()

# Original issue cases
print('=== Original issue cases ===')

# 1. Q(pk__in=[]) 
sql1 = qs.annotate(foo=ExpressionWrapper(Q(pk__in=[]), output_field=BooleanField())).values('foo').query
assert 'SELECT' in str(sql1) and 'AS' in str(sql1), f'Invalid SQL: {sql1}'
print(f'Q(pk__in=[]): {sql1}')

# 2. ~Q(pk__in=[])
sql2 = qs.annotate(foo=ExpressionWrapper(~Q(pk__in=[]), output_field=BooleanField())).values('foo').query
assert 'SELECT' in str(sql2) and 'AS' in str(sql2), f'Invalid SQL: {sql2}'
print(f'~Q(pk__in=[]): {sql2}')

# Additional edge cases
print()
print('=== Additional edge cases ===')

# 3. Normal ExpressionWrapper with F()
sql3 = qs.annotate(foo=ExpressionWrapper(F('age'), output_field=BooleanField())).values('foo').query
print(f'F(\""age\""): {sql3}')

# 4. Normal Q
sql4 = qs.annotate(foo=ExpressionWrapper(Q(age__gt=5), output_field=BooleanField())).values('foo').query
print(f'Q(age__gt=5): {sql4}')

# 5. Negated Q
sql5 = qs.annotate(foo=ExpressionWrapper(~Q(age__gt=5), output_field=BooleanField())).values('foo').query
print(f'~Q(age__gt=5): {sql5}')

# 6. Combined Q (OR)
sql6 = qs.annotate(foo=ExpressionWrapper(Q(age__gt=5) | Q(age__lt=3), output_field=BooleanField())).values('foo').query
print(f'Q(age__gt=5) | Q(age__lt=3): {sql6}')

# 7. Combined Q (AND)
sql7 = qs.annotate(foo=ExpressionWrapper(Q(age__gt=5) & Q(age__lt=10), output_field=BooleanField())).values('foo').query
print(f'Q(age__gt=5) & Q(age__lt=10): {sql7}')

# 8. Negated combined Q
sql8 = qs.annotate(foo=ExpressionWrapper(~(Q(age__gt=5) & Q(age__lt=10)), output_field=BooleanField())).values('foo').query
print(f'~(Q(age__gt=5) & Q(age__lt=10)): {sql8}')

# 9. Double negation
sql9 = qs.annotate(foo=ExpressionWrapper(~(~Q(age__gt=5)), output_field=BooleanField())).values('foo').query
print(f'~(~Q(age__gt=5)): {sql9}')

# 10. Value(True) and Value(False)
sql10 = qs.annotate(foo=ExpressionWrapper(Value(True), output_field=BooleanField())).values('foo').query
print(f'Value(True): {sql10}')

sql11 = qs.annotate(foo=ExpressionWrapper(Value(False), output_field=BooleanField())).values('foo').query
print(f'Value(False): {sql11}')

# Run actual queries
print()
print('=== Query executions ===')
from django.db import connection as db_connection
with db_connection.schema_editor() as schema_editor:
    schema_editor.create_model(TestModel)

TestModel.objects.create(name='test', age=10)

# Test actual values
result1 = TestModel.objects.annotate(
    foo=ExpressionWrapper(Q(pk__in=[]), output_field=BooleanField())
).values('foo').first()
print(f'Q(pk__in=[]) result: {result1}')

result2 = TestModel.objects.annotate(
    foo=ExpressionWrapper(~Q(pk__in=[]), output_field=BooleanField())
).values('foo').first()
print(f'~Q(pk__in=[]) result: {result2}')

result3 = TestModel.objects.annotate(
    foo=ExpressionWrapper(Q(age__gt=5), output_field=BooleanField())
).values('foo').first()
print(f'Q(age__gt=5) result: {result3}')

result4 = TestModel.objects.annotate(
    foo=ExpressionWrapper(~Q(age__gt=5), output_field=BooleanField())
).values('foo').first()
print(f'~Q(age__gt=5) result: {result4}')

print()
print('All tests passed!')
