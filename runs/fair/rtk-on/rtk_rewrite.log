import django
django.setup()

from django.db import connection
from django.db.models import Subquery, OuterRef
from django.db.models.expressions import Subquery as SubqueryExpr

# Create a basic query to use as subquery
from django.contrib.auth.models import User
q = User.objects.all()
sq = Subquery(q)
print(f""query.subquery = {sq.query.subquery}"")

# Test as_sql
compiler = sq.query.get_compiler(connection=connection)
sql, params = sq.as_sql(compiler, connection)
print(f""SQL: {sql}"")
print(f""Params: {params}"")

# Verify SQL is wrapped in parentheses and starts with (SELECT
assert sql.startswith('(SELECT'), f""SQL should start with '(SELECT', got: {sql[:50]}...""
assert sql.endswith(')'), f""SQL should end with ')', got: {sql[-50:]}...""
print(""\nSUCCESS: Fix works correctly!"")
PYEOF
