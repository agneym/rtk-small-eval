import re
path = 'django/db/models/fields/__init__.py'
with open(path, 'r') as f:
    content = f.read()

# Fix __subclasscheck__ to use issubclass instead of 'in'
old = '        return subclass in self._subclasses or super().__subclasscheck__(subclass)'
new = '        return issubclass(subclass, self._subclasses) or super().__subclasscheck__(subclass)'
content = content.replace(old, new)

with open(path, 'w') as f:
    f.write(content)

print('Fixed!')

# Verify
with open(path, 'r') as f:
    content = f.read()
    if 'issubclass(subclass, self._subclasses)' in content:
        print('Verification passed')
    else:
        print('Verification FAILED')
