# Let me verify my understanding of the topological sort approach with the test cases
# from the existing test_merge function

from collections import defaultdict, deque

def merge_all(lists):
    '''Multi-way merge using topological sort'''
    # Collect all unique elements in order of first appearance
    all_elements = []
    for lst in lists:
        for item in lst:
            if item not in all_elements:
                all_elements.append(item)
    
    if not all_elements:
        return []
    
    # Build directed graph from adjacent pairs in each list
    graph = {item: set() for item in all_elements}
    in_degree = {item: 0 for item in all_elements}
    
    for lst in lists:
        for i in range(len(lst) - 1):
            a, b = lst[i], lst[i+1]
            if b not in graph.get(a, set()):
                if a not in graph:
                    graph[a] = set()
                if b not in graph:
                    graph[b] = set()
                graph[a].add(b)
