import django
import os
import sys
os.environ['DJANGO_ALLOW_ASYNC_UNSAFE'] = 'true'
sys.path.insert(0, '/testbed')

import django.conf
django.conf.settings.configure(
    DATABASES={
        'default': {
            'ENGINE': 'django.db.backends.sqlite3',
            'NAME': ':memory:',
        },
    },
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.AutoField',
)
django.setup()

from django.db import models, connection, transaction
from django.db.models import ForeignKey, CASCADE, CharField
from django.core.exceptions import ValidationError

# ========== Test models ==========
class Product(models.Model):
    sku = models.CharField(primary_key=True, max_length=50)
    class Meta:
        app_label = 'test_app'

class AutoProduct(models.Model):
    name = models.CharField(max_length=50)
    class Meta:
        app_label = 'test_app'

class Order(models.Model):
    product = ForeignKey(Product, on_delete=CASCADE)
    class Meta:
        app_label = 'test_app'

class AutoOrder(models.Model):
    product = ForeignKey(AutoProduct, on_delete=CASCADE)
    class Meta:
        app_label = 'test_app'

class NullableOrder(models.Model):
    product = ForeignKey(Product, on_delete=CASCADE, null=True, blank=True)
    class Meta:
        app_label = 'test_app'

# Create tables
with connection.schema_editor() as schema_editor:
    schema_editor.create_model(Product)
    schema_editor.create_model(AutoProduct)
    schema_editor.create_model(Order)
    schema_editor.create_model(AutoOrder)
    schema_editor.create_model(NullableOrder)

passed = 0
failed = 0

def test(description, func):
    global passed, failed
    try:
        func()
        passed += 1
        print(f""  PASS: {description}"")
    except Exception as e:
        failed += 1
        print(f""  FAIL: {description}: {type(e).__name__}: {e}"")

# ========== Test 1: Original issue - CharField PK, set PK after assignment ==========
print(""\n--- Test 1: CharField PK, set PK after assignment ---"")
def t1():
    with transaction.atomic():
        order = Order()
        order.product = Product()
        order.product.sku = ""foo""
        order.product.save()
        order.save()
        assert order.product_id == ""foo"", f""Expected 'foo', got '{order.product_id}'""
        assert not Order.objects.filter(product_id="""").exists()
        assert Order.objects.filter(product=order.product).exists()
    # Clean up
    Order.objects.all().delete()
    Product.objects.all().delete()
test(""CharField PK set after assignment saves correctly"", t1)

# ========== Test 2: CharField PK, set PK before assignment ==========
print(""\n--- Test 2: CharField PK, set PK before assignment ---"")
def t2():
    with transaction.atomic():
        order = Order()
        order.product = Product(sku=""bar"")
        order.product.save()
        order.save()
        assert order.product_id == ""bar""
        assert Order.objects.filter(product=order.product).exists()
