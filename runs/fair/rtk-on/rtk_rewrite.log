import numpy as np
from astropy.nddata import NDDataRef

array = np.array([[0, 1, 0], [1, 0, 1], [0, 1, 0]])
mask = np.array([[0, 1, 64], [8, 0, 1], [2, 1, 0]])

nref_nomask = NDDataRef(array)
nref_mask = NDDataRef(array, mask=mask)

# subtraction
print('Test subtract: mask * no mask')
result = nref_mask.subtract(nref_nomask, handle_mask=np.bitwise_or).mask
print('Result:', result)

# addition
print()
print('Test add: mask * no mask')
result = nref_mask.add(nref_nomask, handle_mask=np.bitwise_or).mask
print('Result:', result)

# divide
print()
print('Test divide: mask * no mask')
result = nref_mask.divide(nref_nomask, handle_mask=np.bitwise_or).mask
print('Result:', result)

# handle_mask='first_found'
print()
print('Test: mask * no mask with first_found')
result = nref_mask.multiply(nref_nomask, handle_mask='first_found').mask
print('Result:', result)

# handle_mask=None
print()
print('Test: mask * no mask with handle_mask=None')
result = nref_mask.multiply(nref_nomask, handle_mask=None).mask
print('Result:', result)

# no mask * mask
print()
print('Test: no mask * mask')
result = nref_nomask.multiply(nref_mask, handle_mask=np.bitwise_or).mask
print('Result:', result)

# both no mask with first_found
print()
print('Test: no mask * no mask with first_found')
result = nref_nomask.multiply(nref_nomask, handle_mask='first_found').mask
print('Result:', result)

# Collapse operations
print('Test sum with mask:')
result = nref_mask.sum(handle_mask=np.bitwise_or).mask
print('Result:', result)

print('Test mean with mask:')
result = nref_mask.mean(handle_mask=np.bitwise_or).mask
print('Result:', result)
