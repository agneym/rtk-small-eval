from django.contrib.auth import models
from django.db.models import Max

a = models.User.objects.filter(email__isnull=True).values('email').annotate(m=Max('id')).values('m')[:1]
b = models.User.objects.filter(id=a[:1])

# Get the inner query after it's been resolved in the outer query
child = b.query.where.children[0]
rhs = child.rhs
print('RHS type:', type(rhs))
print('RHS.group_by before compile:', rhs.group_by)
print()

# Now compile and trace
from django.db import connection
compiler = b.query.get_compiler(connection=connection)

# Let's trace the subquery compilation
# The Exact lookup's as_sql will call compiler.compile(rhs)
# which will call rhs.as_sql(compiler, connection)
# which calls self.get_compiler(connection=connection).as_sql()
# So a NEW compiler is created for the inner query

# Let's manually compile the inner query
inner_compiler = rhs.get_compiler(connection=connection)
print('Inner compiler\'s query.group_by:', inner_compiler.query.group_by)
sql, params = inner_compiler.as_sql()
print('Inner SQL:', sql)
print('Inner compiler\'s query.group_by after as_sql:', inner_compiler.query.group_by)
print('Original rhs.group_by after as_sql:', rhs.group_by)
