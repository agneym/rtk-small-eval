from enum import Enum, IntEnum
from django.db.migrations.serializer import serializer_factory

# Test 1: Regular Enum with string value (the PR's use case)
class Status(Enum):
    GOOD = 'Good'
    BAD = 'Bad'

result, imports = serializer_factory(Status.GOOD).serialize()
print('Test 1 - Regular Enum:')
print(f'  Result: {result!r}')
print(f'  Imports: {imports}')
assert result == \""__main__.Status['GOOD']\"", f'Expected __main__.Status[\\'GOOD\\'], got {result}'
print('  PASS')

# Test 2: IntEnum
class MyIntEnum(IntEnum):
    A = 1
    B = 2

result, imports = serializer_factory(MyIntEnum.B).serialize()
print('Test 2 - IntEnum:')
print(f'  Result: {result!r}')
assert result == \""__main__.MyIntEnum['B']\"", f'Expected __main__.MyIntEnum[\\'B\\'], got {result}'
print('  PASS')

# Test 3: Combined Flag (should fall back to value-based access)
import re
flag = re.RegexFlag(16 | 8)  # DOTALL | MULTILINE
result, imports = serializer_factory(flag).serialize()
print('Test 3 - Combined RegexFlag:')
print(f'  Result: {result!r}')
print(f'  Imports: {imports}')
# Should use value-based access since name is None
assert result == 're.RegexFlag(24)', f'Expected re.RegexFlag(24), got {result}'
print('  PASS')

# Test 4: Single RegexFlag (should use name-based access)
flag = re.RegexFlag(16)  # DOTALL
result, imports = serializer_factory(flag).serialize()
print('Test 4 - Single RegexFlag:')
print(f'  Result: {result!r}')
assert result == \""re.RegexFlag['DOTALL']\"", f'Expected re.RegexFlag[\\'DOTALL\\'], got {result}'
print('  PASS')

# Test 5: Binary Enum
class BinaryEnum(Enum):
    A = b'a-value'

result, imports = serializer_factory(BinaryEnum.A).serialize()
print('Test 5 - Binary Enum:')
print(f'  Result: {result!r}')
# For binary values, name-based access still works since it uses the name
assert result == \""__main__.BinaryEnum['A']\"", f'Expected __main__.BinaryEnum[\\'A\\'], got {result}'
print('  PASS')

print()
print('All tests passed!')
