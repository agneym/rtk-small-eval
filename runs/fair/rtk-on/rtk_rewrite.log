import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')
import django
django.setup()

from django.db import models, connection
from django.db.migrations.state import ProjectState, ModelState
from django.db.migrations.operations.models import RenameModel

# Create a model with explicit db_table
model_state = ModelState('test_app', 'MyModel', [
    ('id', models.AutoField(primary_key=True)),
], {'db_table': 'my_custom_table'})

project_state = ProjectState()
project_state.models['test_app', 'mymodel'] = model_state

# Also create a related model with FK to MyModel
related_state = ModelState('test_app', 'RelatedModel', [
    ('id', models.AutoField(primary_key=True)),
    ('my_model', models.ForeignKey('test_app.MyModel', models.CASCADE)),
], {})
project_state.models['test_app', 'relatedmodel'] = related_state

# Apply RenameModel state operation
operation = RenameModel('MyModel', 'NewModelName')
new_state = project_state.clone()
operation.state_forwards('test_app', new_state)

# Verify state changes
assert ('test_app', 'mymodel') not in new_state.models, ""Old model still in state""
assert ('test_app', 'newmodelname') in new_state.models, ""New model not in state""

# Check db_tables
old_model = project_state.apps.get_model('test_app', 'MyModel')
new_model = new_state.apps.get_model('test_app', 'NewModelName')
print(f""Old db_table: {old_model._meta.db_table!r}"")
print(f""New db_table: {new_model._meta.db_table!r}"")
print(f""db_table unchanged (explicitly set): {old_model._meta.db_table == new_model._meta.db_table}"")

# Verify that alter_db_table would NOT be called (old == new)
assert old_model._meta.db_table == new_model._meta.db_table, ""db_table should be the same""
print(""\n✓ If old and new db_tables are the same, alter_db_table is skipped."")
print(""✓ This prevents unnecessary FK constraint drops in Postgres"")
print(""✓ This prevents unnecessary table recreations in SQLite"")

# Now test with auto-generated db_table (no explicit db_table)
model_state2 = ModelState('test_app', 'MyModel2', [
    ('id', models.AutoField(primary_key=True)),
], {})
project_state2 = ProjectState()
project_state2.models['test_app', 'mymodel2'] = model_state2

operation2 = RenameModel('MyModel2', 'NewModelName2')
new_state2 = project_state2.clone()
operation2.state_forwards('test_app', new_state2)

old_model2 = project_state2.apps.get_model('test_app', 'MyModel2')
new_model2 = new_state2.apps.get_model('test_app', 'NewModelName2')
print(f""\nOld db_table (auto): {old_model2._meta.db_table!r}"")
print(f""New db_table (auto): {new_model2._meta.db_table!r}"")
print(f""db_table changed (auto-generated): {old_model2._meta.db_table != new_model2._meta.db_table}"")

# Verify that alter_db_table WOULD be called (old != new)
assert old_model2._meta.db_table != new_model2._meta.db_table, ""db_table should be different""
print(""\n✓ If old and new db_tables differ, alter_db_table is still called as expected."")
print(""✓ RenameModel without explicit db_table still works correctly."")

print(""\nAll checks passed!"")
PYEOF
