from django.core.validators import URLValidator
import re

v = URLValidator()

# Let's find a URL that passes the regex but fails urlsplit
# The ipv6_re is: \[[0-9a-f:.]+\]
# What if we have a very long or weird IPv6-like pattern?

test_urls = [
    # These have valid scheme and might match ipv6_re
    'http://[',
    'http://[]',
    'http://[::',
    'http://[::]',
    'http://[1234:5678]',
    'http://[1234:5678:',
    'http://[a:b:c:d:e:f:g:h]',
    'http://[a:b:c:d:e:f:g:h:',
    'http://[a:b:c:d:e:f:g:h]:8080',
]

for url in test_urls:
    # Check if regex matches
    regex_match = bool(v.regex.search(str(url)))
    
    # Check urlsplit
    try:
        parsed = urlsplit(url)
        urlsplit_ok = True
    except ValueError as e:
        urlsplit_ok = False
        urlsplit_err = str(e)
    
    # Check validator
    try:
        v(url)
        val_ok = True
    except Exception as e:
        val_ok = False
        val_err = f'{type(e).__name__}: {e}'
    
    print(f'URL: {url!r}')
    print(f'  Regex match: {regex_match}, urlsplit OK: {urlsplit_ok}, Validator OK: {val_ok}')
    if not urlsplit_ok:
        print(f'  urlsplit error: {urlsplit_err}')
    if not val_ok:
        print(f'  Validator error: {val_err}')
    print()
