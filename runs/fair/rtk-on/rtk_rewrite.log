import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
)
django.setup()

from django.db import models
from django.db.migrations.state import ModelState, ProjectState
from django.db.migrations.autodetector import MigrationAutodetector
from django.db.migrations.questioner import MigrationQuestioner

# Match the PR description exactly: PK renamed, FK with to_field
print('=== PR Scenario: PK renamed, FK with to_field ===')
before = [
    ModelState('app', 'ModelA', [
        # No separate id field - field_wrong IS the pk
        ('field_wrong', models.CharField('field1', max_length=50, primary_key=True)),
    ]),
    ModelState('app', 'ModelB', [
        ('id', models.AutoField(primary_key=True)),
        ('field_fk', models.ForeignKey('app.ModelA', models.CASCADE, blank=True, null=True, to_field='field_wrong')),
    ]),
]

after = [
    ModelState('app', 'ModelA', [
        ('field_fixed', models.CharField('field1', max_length=50, primary_key=True)),
    ]),
    ModelState('app', 'ModelB', [
        ('id', models.AutoField(primary_key=True)),
        # User didn't change the FK - it still references ModelA without explicit to_field
        ('field_fk', models.ForeignKey('app.ModelA', models.CASCADE, blank=True, null=True)),
    ]),
]

before_state = ProjectState()
for ms in before:
    before_state.add_model(ms.clone())

after_state = ProjectState()
for ms in after:
    after_state.add_model(ms.clone())

autodetector = MigrationAutodetector(before_state, after_state, MigrationQuestioner({'ask_rename': True}))
changes = autodetector._detect_changes()

for app_label, migrations_list in sorted(changes.items()):
    for migration in migrations_list:
        print(f'Migration for {app_label}:')
        for op in migration.operations:
            print(f'  {op.__class__.__name__}: {op.describe()}')
            if hasattr(op, 'field') and op.field:
                f = op.field
                decon = f.deconstruct()
                print(f'    deconstruct: {decon}')
                if hasattr(f, 'remote_field') and f.remote_field:
                    print(f'    to_field: {getattr(f.remote_field, \""field_name\"", None)}')
