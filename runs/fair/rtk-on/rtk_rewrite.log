from django.db import models
from django.core import checks

# Test 1: Model inheriting from concrete parent (the original issue)
class ParentModel(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'

class ChildModel(ParentModel):
    age = models.IntegerField()
    class Meta:
        app_label = 'test'

errors = ChildModel.check()
w042_errors = [e for e in errors if e.id == 'models.W042']
print('Test 1 - ChildModel with concrete parent:')
print(f'  W042 errors: {len(w042_errors)}')
assert len(w042_errors) == 0, f'Expected 0 W042 errors, got {len(w042_errors)}'
print('  PASS')

# Test 2: Model without parents (standard model, should still warn)
class StandaloneModel(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'

errors = StandaloneModel.check()
w042_errors = [e for e in errors if e.id == 'models.W042']
print('Test 2 - StandaloneModel (no parent):')
print(f'  W042 errors: {len(w042_errors)}')
assert len(w042_errors) == 1, f'Expected 1 W042 error, got {len(w042_errors)}'
print('  PASS')

# Test 3: Model inheriting from abstract parent (should still warn)
class AbstractModel(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'
        abstract = True

class ConcreteFromAbstract(AbstractModel):
    age = models.IntegerField()
    class Meta:
        app_label = 'test'

errors = ConcreteFromAbstract.check()
w042_errors = [e for e in errors if e.id == 'models.W042']
print('Test 3 - ConcreteFromAbstract (abstract parent):')
print(f'  W042 errors: {len(w042_errors)}')
assert len(w042_errors) == 1, f'Expected 1 W042 error, got {len(w042_errors)}'
print('  PASS')

# Test 4: Proxy model (should not warn)
class ProxyChild(ParentModel):
    class Meta:
        app_label = 'test'
        proxy = True

errors = ProxyChild.check()
w042_errors = [e for e in errors if e.id == 'models.W042']
print('Test 4 - ProxyChild (proxy model):')
print(f'  W042 errors: {len(w042_errors)}')
assert len(w042_errors) == 0, f'Expected 0 W042 errors, got {len(w042_errors)}'
print('  PASS')

# Test 5: Model with explicit pk (should not warn)
class ExplicitPKModel(models.Model):
    id = models.BigAutoField(primary_key=True)
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'

errors = ExplicitPKModel.check()
w042_errors = [e for e in errors if e.id == 'models.W042']
print('Test 5 - ExplicitPKModel (explicit pk):')
print(f'  W042 errors: {len(w042_errors)}')
assert len(w042_errors) == 0, f'Expected 0 W042 errors, got {len(w042_errors)}'
print('  PASS')

print()
print('All tests passed!')
