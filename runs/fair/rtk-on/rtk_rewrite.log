Book.objects.create(publisher=p1, pages=600)
Book.objects.create(publisher=p1, pages=300)
Book.objects.create(publisher=p2, pages=500)
Book.objects.create(publisher=p3, pages=500)
Book.objects.create(publisher=p4, pages=500)
Book.objects.create(publisher=p5, pages=100)

# This is the test query
long_books_count_qs = Book.objects.filter(
    publisher=OuterRef('pk'),
    pages__gt=400,
).values('publisher').annotate(count=Count('pk')).values('count')
long_books_count_breakdown = Publisher.objects.values_list(
    Subquery(long_books_count_qs, IntegerField()),
).annotate(total=Count('*'))
print('Query:', long_books_count_breakdown.query)
print()
print('Result:', dict(long_books_count_breakdown))
