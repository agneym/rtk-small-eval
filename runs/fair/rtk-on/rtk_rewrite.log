import django
from django.db import models
from django.conf import settings
if not settings.configured:
    settings.configure(
        DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
        INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
        DEFAULT_AUTO_FIELD='django.db.models.AutoField',
    )
    django.setup()

from django.db.models import F, Window, Count
from django.db.models.functions import RowNumber

class TestModel(m.Model):
    name = models.CharField(max_length=255)
    value = models.IntegerField(default=0)
    
    class Meta:
        app_label = 'test'

# Test that Window expression still raises NotSupportedError in filter
try:
    qs = TestModel.objects.filter(name=F('value'))
    print('F expression works in filter - OK')
except Exception as e:
    print(f'F expression failed: {e}')

try:
    qs = TestModel.objects.annotate(
        row_num=Window(expression=RowNumber())
    ).filter(row_num=1)
    print('Window in filter did NOT raise an error - BAD')
except django.db.utils.NotSupportedError as e:
    print(f'Window expression correctly rejected: {e}')
except Exception as e:
    print(f'Other error: {e}')
