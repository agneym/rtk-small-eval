import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')

import django
django.setup()

from django.db import models

# Test 1: Non-self-referencing FK should still work
class OtherModel(models.Model):
    class Meta:
        ordering = (""-id"",)
        app_label = 'test_edge'
    id = models.BigAutoField(primary_key=True)
    name = models.CharField(max_length=100)

class RefModel(models.Model):
    class Meta:
        ordering = (""-id"",)
        app_label = 'test_edge'
    id = models.BigAutoField(primary_key=True)
    ref = models.ForeignKey(OtherModel, on_delete=models.CASCADE, null=True)

# Test
qs = RefModel.objects.all()
print(""=== Non-self-referencing FK ==="")
print(""order_by('ref_id'):"", qs.order_by(""ref_id"").query)
print(""order_by('ref'):"", qs.order_by(""ref"").query)

# Test 2: Ordering by pk
class SimpleModel(models.Model):
    class Meta:
