""""""
Final verification of the fix for:
Saving parent object after setting on child leads to data loss for 
parents with non-numeric primary key.
""""""
import django
import os
import sys
os.environ['DJANGO_ALLOW_ASYNC_UNSAFE'] = 'true'
sys.path.insert(0, '/testbed')

import django.conf
django.conf.settings.configure(
    DATABASES={
        'default': {
            'ENGINE': 'django.db.backends.sqlite3',
            'NAME': ':memory:',
        },
    },
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.AutoField',
)
django.setup()

from django.db import models, connection, transaction

# ===== Models =====
class Product(models.Model):
    sku = models.CharField(primary_key=True, max_length=50)
    class Meta:
        app_label = 'test_app'

class Order(models.Model):
    product = models.ForeignKey(Product, on_delete=models.CASCADE)
    class Meta:
        app_label = 'test_app'

# ===== Setup =====
with connection.schema_editor() as schema_editor:
    schema_editor.create_model(Product)
    schema_editor.create_model(Order)

errors = []

def assert_eq(actual, expected, msg):
    if actual != expected:
        errors.append(f""{msg}: expected {expected!r}, got {actual!r}"")

def assert_true(value, msg):
    if not value:
        errors.append(f""{msg}: expected True, got False"")

def assert_false(value, msg):
    if value:
        errors.append(f""{msg}: expected False, got True"")

# ===== Test the exact scenario from the PR description =====
print(""=== PR Scenario: Set PK after assignment ==="")
try:
    with transaction.atomic():
        order = Order()
        order.product = Product()
        order.product.sku = ""foo""
        order.product.save()
        order.save()
        
        assert_eq(order.product_id, ""foo"", ""product_id should be 'foo'"")
        assert_false(
            Order.objects.filter(product_id="""").exists(),
            ""Should not find order with empty product_id""
        )
        assert_true(
            Order.objects.filter(product=order.product).exists(),
            ""Should find order by product""
        )
        
        if not errors:
            print(""  PASS: All assertions passed!"")
        else:
            for e in errors:
                print(f""  FAIL: {e}"")
except Exception as e:
    print(f""  ERROR: {type(e).__name__}: {e}"")

# Clean up
Order.objects.all().delete()
Product.objects.all().delete()

# ===== Test with explicit PK at creation =====
print(""\n=== Test: Set PK at creation (should still work) ==="")
try:
    with transaction.atomic():
        order = Order()
        order.product = Product(sku=""bar"")
        order.product.save()
        order.save()
        
        assert_eq(order.product_id, ""bar"", ""product_id should be 'bar'"")
        assert_true(
            Order.objects.filter(product=order.product).exists(),
            ""Should find order by product""
        )
        
        if not errors:
            print(""  PASS: All assertions passed!"")
        else:
            for e in errors:
                print(f""  FAIL: {e}"")
except Exception as e:
    print(f""  ERROR: {type(e).__name__}: {e}"")

# Clean up
Order.objects.all().delete()
Product.objects.all().delete()

# ===== Test with existing product =====
print(""\n=== Test: Assign existing product ==="")
try:
    with transaction.atomic():
        product = Product(sku=""existing"")
        product.save()
        order = Order()
        order.product = product
        order.save()
        
        assert_eq(order.product_id, ""existing"", ""product_id should be 'existing'"")
        assert_true(
            Order.objects.filter(product=product).exists(),
            ""Should find order by product""
        )
        
        if not errors:
            print(""  PASS: All assertions passed!"")
        else:
            for e in errors:
                print(f""  FAIL: {e}"")
except Exception as e:
    print(f""  ERROR: {type(e).__name__}: {e}"")

# Clean up
Order.objects.all().delete()
Product.objects.all().delete()

# ===== Test that manually changed FK is preserved =====
print(""\n=== Test: Manual FK change preserved ==="")
try:
    with transaction.atomic():
        Product.objects.create(sku=""a"")
        Product.objects.create(sku=""b"")
        order = Order()
        order.product = Product.objects.get(sku=""a"")
        order.save()
        # Manually change FK to point to different product
        order.product_id = ""b""
        order.save()
        
        assert_eq(order.product_id, ""b"", ""product_id should be 'b' after manual change"")
        assert_true(
            Order.objects.filter(product_id=""b"").exists(),
            ""Should find order with product_id='b'""
        )
        
        if not errors:
            print(""  PASS: All assertions passed!"")
        else:
            for e in errors:
                print(f""  FAIL: {e}"")
except Exception as e:
    print(f""  ERROR: {type(e).__name__}: {e}"")

# Clean up
Order.objects.all().delete()
Product.objects.all().delete()

# ===== Summary =====
print(f""\n{'='*40}"")
if errors:
    print(f""FAILED: {len(errors)} error(s)"")
    for e in errors:
        print(f""  - {e}"")
else:
    print(""ALL TESTS PASSED!"")
print(f""{'='*40}"")

# Clean up tables
with connection.schema_editor() as schema_editor:
    schema_editor.delete_model(Order)
    schema_editor.delete_model(Product)

sys.exit(1 if errors else 0)
