import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')

import django
django.setup()

from django.db import models
from django.test.utils import isolate_apps
from django.core import checks

# Test 1: Missing field in UniqueConstraint should raise E012
@isolate_apps('test_constraints')
def test_missing_field():
    class Model(models.Model):
        name = models.CharField(max_length=100)
        
        class Meta:
            app_label = 'test_constraints'
            constraints = [
                models.UniqueConstraint(fields=['missing_field'], name='unique_name'),
            ]
    
    errors = Model.check(databases=['default'])
    e012_errors = [e for e in errors if e.id == 'models.E012']
    print(f'Test 1 - Missing field: {len(e012_errors)} E012 errors')
    for e in e012_errors:
        print(f'  {e.msg}')
    return len(e012_errors) > 0

# Test 2: Valid field in UniqueConstraint should not raise E012
@isolate_apps('test_constraints')
def test_valid_field():
    class Model(models.Model):
        name = models.CharField(max_length=100)
        
        class Meta:
            app_label = 'test_constraints'
            constraints = [
                models.UniqueConstraint(fields=['name'], name='unique_name'),
            ]
    
    errors = Model.check(databases=['default'])
    e012_errors = [e for e in errors if e.id == 'models.E012']
    print(f'Test 2 - Valid field: {len(e012_errors)} E012 errors')
    return len(e012_errors) == 0

# Test 3: Multiple fields, one missing
@isolate_apps('test_constraints')
def test_mixed_fields():
    class Model(models.Model):
        name = models.CharField(max_length=100)
        
        class Meta:
            app_label = 'test_constraints'
            constraints = [
                models.UniqueConstraint(fields=['name', 'missing_field'], name='unique_name'),
            ]
    
    errors = Model.check(databases=['default'])
    e012_errors = [e for e in errors if e.id == 'models.E012']
    print(f'Test 3 - Mixed fields: {len(e012_errors)} E012 errors')
    for e in e012_errors:
        print(f'  {e.msg}')
    return len(e012_errors) == 1

# Test 4: CheckConstraint should not trigger this check
@isolate_apps('test_constraints')
def test_check_constraint_no_error():
    class Model(models.Model):
        age = models.IntegerField()
        
        class Meta:
            app_label = 'test_constraints'
            constraints = [
                models.CheckConstraint(check=models.Q(age__gte=18), name='is_adult'),
            ]
    
    errors = Model.check(databases=['default'])
    e012_errors = [e for e in errors if e.id == 'models.E012']
    print(f'Test 4 - CheckConstraint (no UniqueConstraint fields check): {len(e012_errors)} E012 errors')
    return len(e012_errors) == 0

print('Running tests...')
print()
r1 = test_missing_field()
print()
r2 = test_valid_field()
print()
r3 = test_mixed_fields()
print()
r4 = test_check_constraint_no_error()
print()
print('All tests passed:', all([r1, r2, r3, r4]))
""
