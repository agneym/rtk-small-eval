import sys
sys.path.insert(0, '.')
import django
from django.conf import settings
settings.configure(DEBUG=True, 
    # Edge case 1: Tuple
    TUPLE_SETTING=(
        {'secret': 'value', 'foo': 'bar'},
        {'token': 'value', 'bar': 'baz'},
    ),
    # Edge case 2: Set
    # Sets can't contain dicts (unhashable), so just strings
    # Edge case 3: Nested mixed types
    NESTED_SETTING=[
        {'secret': 'value'},
        ['foo', {'token': 'value'}],
        ({'password': 'value'},),
    ],
    # Edge case 4: Plain list
    PLAIN_LIST=['safe_value', 'another_safe'],
)
django.setup()
from django.views.debug import SafeExceptionReporterFilter
import pprint

filter = SafeExceptionReporterFilter()
result = filter.get_safe_settings()

print('=== TUPLE_SETTING ===')
pprint.pprint(result['TUPLE_SETTING'])

print()
print('=== NESTED_SETTING ===')
pprint.pprint(result['NESTED_SETTING'])

print()
print('=== PLAIN_LIST ===')
pprint.pprint(result['PLAIN_LIST'])

# Verify tuple preservation
assert isinstance(result['TUPLE_SETTING'], tuple), 'Tuple type not preserved'
assert result['TUPLE_SETTING'][0]['secret'] == '********************', 'secret not cleansed in tuple'
assert result['TUPLE_SETTING'][1]['token'] == '********************', 'token not cleansed in tuple'

# Verify nested
assert result['NESTED_SETTING'][0]['secret'] == '********************', 'secret not cleansed in nested list'
assert result['NESTED_SETTING'][1][1]['token'] == '********************', 'token not cleansed in nested list/list'
assert result['NESTED_SETTING'][2][0]['password'] == '********************', 'password not cleansed in nested list/tuple'

print('All edge case assertions passed!')
""",
