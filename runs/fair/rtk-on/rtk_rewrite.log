import json
from django.utils.html import json_script
from django.core.serializers.json import DjangoJSONEncoder

class CustomEncoder(json.JSONEncoder):
    def default(self, o):
        if isinstance(o, set):
            return sorted(o)
        return super().default(o)

# Test 1: default encoder (DjangoJSONEncoder) still works
result = json_script({'key': 'value'})
print('Test 1 (default encoder):', result)

# Test 2: element_id still works with default encoder
result = json_script({'key': 'value'}, 'my-id')
print('Test 2 (with element_id):', result)

# Test 3: custom encoder
result = json_script({1, 2, 3}, encoder=CustomEncoder)
print('Test 3 (custom encoder):', result)

# Test 4: custom encoder with element_id
result = json_script({1, 2, 3}, 'my-id', CustomEncoder)
print('Test 4 (custom encoder + element_id):', result)

# Test 5: None encoder uses DjangoJSONEncoder
result = json_script({'key': 'value'}, encoder=None)
print('Test 5 (None encoder):', result)

print()
print('All tests passed!')
""
