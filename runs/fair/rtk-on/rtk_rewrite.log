print(f'ValidationError(\""error1\"") == ValidationError(\""error2\""): {e1 == e3}')  # Should be False

print()
print('=== Simple Form with code and params ===')
e1 = ValidationError('error', code='required', params={'value': 42})
e2 = ValidationError('error', code='required', params={'value': 42})
e3 = ValidationError('error', code='required', params={'value': 43})
