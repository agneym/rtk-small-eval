import django
from django.conf import settings
settings.configure(
    DEBUG=True,
    LANGUAGE_CODE='de-at',
    LANGUAGES=[('de', 'German'), ('en', 'English')],
    LANGUAGES_BIDI=[],
    INSTALLED_APPS=['django.contrib.contenttypes'],
)
django.setup()

from django.core.checks import Error
from django.core.checks.translation import check_language_settings_consistent

result = check_language_settings_consistent(None)
print('Result with de-at (base de available):', result)
assert result == [], f'Expected no errors, got {result}'
print('PASS: de-at falls back to de')

# Test that fr-ca raises error when only en is available
settings.LANGUAGE_CODE = 'fr-ca'
settings.LANGUAGES = [('en', 'English')]
result = check_language_settings_consistent(None)
print('Result with fr-ca (no fr available):', result)
assert len(result) == 1, f'Expected 1 error, got {result}'
assert result[0].id == 'translation.E004', f'Expected E004, got {result[0].id}'
print('PASS: fr-ca with no fr base raises error')

# Test that exact match still works
settings.LANGUAGE_CODE = 'de'
settings.LANGUAGES = [('de', 'German'), ('en', 'English')]
result = check_language_settings_consistent(None)
print('Result with de (exact match):', result)
assert result == [], f'Expected no errors, got {result}'
print('PASS: de exact match works')

# Test that en-us always works (added by default)
settings.LANGUAGE_CODE = 'en-us'
settings.LANGUAGES = [('de', 'German')]
result = check_language_settings_consistent(None)
print('Result with en-us (always available):', result)
assert result == [], f'Expected no errors, got {result}'
print('PASS: en-us always works')

# Test that zh-hans (which has no 'zh' base) works since it's directly available
settings.LANGUAGE_CODE = 'zh-hans'
settings.LANGUAGES = [('zh-hans', 'Chinese'), ('en', 'English')]
result = check_language_settings_consistent(None)
print('Result with zh-hans (direct match):', result)
assert result == [], f'Expected no errors, got {result}'
print('PASS: zh-hans direct match works')

print()
print('All tests passed!')
""",
