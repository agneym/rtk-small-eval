import re

with open('django/utils/functional.py', 'r') as f:
    content = f.read()

# Find the LazyObject class and add __radd__ after __contains__
# The pattern is: __contains__ = new_method_proxy(operator.contains)
# followed by a blank line and then def unpickle_lazyobject

old = '''    __contains__ = new_method_proxy(operator.contains)


def unpickle_lazyobject(wrapped):'''

new = '''    __contains__ = new_method_proxy(operator.contains)

    def __radd__(self, other):
        if self._wrapped is empty:
            self._setup()
        return other + self._wrapped


def unpickle_lazyobject(wrapped):'''

if old in content:
    content = content.replace(old, new, 1)
    with open('django/utils/functional.py', 'w') as f:
        f.write(content)
    print('Successfully added __radd__')
else:
    print('Could not find the target location')
    # Find what's around line 374-377
    for i, line in enumerate(content.split('\\n')[370:380], start=371):
        print(f'{i}: {line}')
