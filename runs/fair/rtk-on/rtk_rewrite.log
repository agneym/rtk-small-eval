import django
import os
os.environ['DJANGO_SETTINGS_MODULE'] = 'tests.test_sqlite'

import sys
sys.path.insert(0, '/testbed/tests')

from django.conf import settings
settings.INSTALLED_APPS = [
    'django.contrib.contenttypes',
    'django.contrib.auth',
]

# Need to configure the database properly
settings.DATABASES['default']['NAME'] = ':memory:'

django.setup()

from django.db import models, connection
from django.db.models import Q

# Create schema
with connection.schema_editor() as schema_editor:
    class Category(models.Model):
        name = models.CharField(max_length=100)
        class Meta:
            app_label = 'test'
    
    class Book(models.Model):
        categories = models.ManyToManyField(Category, related_name='books')
        title = models.CharField(max_length=100)
        class Meta:
            app_label = 'test'
    
    class Page(models.Model):
        book = models.ForeignKey(Book, models.CASCADE, related_name='pages')
        content = models.TextField()
        class Meta:
            app_label = 'test'
    
    # Publisher has limit_choices_to that involves a join through book -> categories
    # This is the key: when you have a FK with limit_choices_to using Q that joins,
    # you can get duplicates
    class Publisher(models.Model):
        book = models.ForeignKey(Book, models.CASCADE, related_name='publishers',
                                  limit_choices_to=Q(categories__name='Fiction'))
        name = models.CharField(max_length=100)
        class Meta:
            app_label = 'test'
    
    schema_editor.create_model(Category)
    schema_editor.create_model(Book)
    schema_editor.create_model(Page)
    schema_editor.create_model(Publisher)

# Insert some data
cat1 = Category.objects.create(name='Fiction')
cat2 = Category.objects.create(name='Non-Fiction')

book1 = Book.objects.create(title='Book 1')
book1.categories.add(cat1)
book1.categories.add(cat2)  # Book 1 is in both categories

book2 = Book.objects.create(title='Book 2')
book2.categories.add(cat1)

book3 = Book.objects.create(title='Book 3')
book3.categories.add(cat2)

# Now test get_choices on Publisher.book
field = Publisher._meta.get_field('book')
print(""Testing get_choices..."")
choices = field.get_choices(include_blank=False)
print(f""Number of choices: {len(choices)}"")
for choice in choices:
    print(f""  {choice}"")

# Book 1 matches because it has a 'Fiction' category, but it also has 'Non-Fiction'
# so if the query joins with categories, book1 will appear twice (once per category)
# Without distinct(), we'll see duplicates
ids = [c[0] for c in choices]
if len(ids) != len(set(ids)):
    print(""BUG: DUPLICATE OPTIONS DETECTED!"")
else:
    print(""OK: No duplicates"")

# Clean up
connection.schema_editor().delete_model(Publisher)
connection.schema_editor().delete_model(Page)
connection.schema_editor().delete_model(Book)
connection.schema_editor().delete_model(Category)
