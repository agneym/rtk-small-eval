# Fix the check_filterable method
# The issue: getattr(expression, 'filterable', True) on a model instance 
# with a field named 'filterable' returns the field value, causing NotSupportedError.
# Fix: Only check 'filterable' for BaseExpression instances.

import re

with open('/testbed/django/db/models/sql/query.py', 'r') as f:
    content = f.read()

# Replace the check_filterable method
old_method = """"""    def check_filterable(self, expression):
        \""\""\""Raise an error if expression cannot be used in a WHERE clause.\""\""\""
        if not getattr(expression, 'filterable', True):
            raise NotSupportedError(
                expression.__class__.__name__ + ' is disallowed in the filter '
                'clause.'
            )
        if hasattr(expression, 'get_source_expressions'):
            for expr in expression.get_source_expressions():
                self.check_filterable(expr)""""""

new_method = """"""    def check_filterable(self, expression):
        \""\""\""Raise an error if expression cannot be used in a WHERE clause.\""\""\""
        if isinstance(expression, BaseExpression):
            if not expression.filterable:
                raise NotSupportedError(
                    expression.__class__.__name__ + ' is disallowed in the filter '
                    'clause.'
                )
        if hasattr(expression, 'get_source_expressions'):
            for expr in expression.get_source_expressions():
                self.check_filterable(expr)""""""

if old_method in content:
    content = content.replace(old_method, new_method)
    with open('/testbed/django/db/models/sql/query.py', 'w') as f:
        f.write(content)
    print(""Fix applied successfully!"")
else:
    print(""Could not find the method to replace. Checking content..."")
    # Let's see what's there
    import sys
    print(repr(content[content.find('def check_filterable'):content.find('def check_filterable')+200]))
EOF
