result = obj.get_foo_bar_display()
print(f""Test 1 - Simple override: {result}"")
assert result == ""something"", f""Expected 'something', got '{result}'""

# Test 2: No override (should work as before)
class BarFoo(models.Model):
    bar_foo = models.CharField(""bar"", max_length=10, choices=[(1, 'foo'), (2, 'bar')])
    
    class Meta:
        app_label = 'test'

obj2 = BarFoo(bar_foo=1)
result2 = obj2.get_bar_foo_display()
print(f""Test 2 - No override: {result2}"")
assert result2 == ""foo"", f""Expected 'foo', got '{result2}'""

print(""All tests passed!"")
