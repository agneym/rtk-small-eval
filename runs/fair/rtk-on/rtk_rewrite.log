from django.conf import settings
settings.configure()
from django.contrib.messages.storage.base import Message
from django.contrib.messages.storage.cookie import MessageEncoder, MessageDecoder

# Test 1: empty string extra_tags
original_message = Message(10, 'Here is a message', extra_tags='')
encoded_message = MessageEncoder().encode(original_message)
decoded_message = MessageDecoder().decode(encoded_message)

print('=== Test 1: extra_tags=\""\"" ===')
print(f'original extra_tags == \""\"": {original_message.extra_tags == \""\""}')
print(f'decoded extra_tags == \""\"": {decoded_message.extra_tags == \""\""}')
print(f'decoded extra_tags is None: {decoded_message.extra_tags is None}')
print(f'Match: {original_message.extra_tags == decoded_message.extra_tags}')

# Test 2: None extra_tags
original_message2 = Message(10, 'Here is a message', extra_tags=None)
encoded_message2 = MessageEncoder().encode(original_message2)
decoded_message2 = MessageDecoder().decode(encoded_message2)

print()
print('=== Test 2: extra_tags=None ===')
print(f'original extra_tags is None: {original_message2.extra_tags is None}')
print(f'decoded extra_tags is None: {decoded_message2.extra_tags is None}')
print(f'Match: {original_message2.extra_tags == decoded_message2.extra_tags}')

# Test 3: non-empty extra_tags
original_message3 = Message(10, 'Here is a message', extra_tags='foo')
encoded_message3 = MessageEncoder().encode(original_message3)
decoded_message3 = MessageDecoder().decode(encoded_message3)

print()
print('=== Test 3: extra_tags=\""foo\"" ===')
print(f'original extra_tags == \""foo\"": {original_message3.extra_tags == \""foo\""}')
print(f'decoded extra_tags == \""foo\"": {decoded_message3.extra_tags == \""foo\""}')
print(f'Match: {original_message3.extra_tags == decoded_message3.extra_tags}')

# Test 4: using messages API default
from django.contrib.messages.storage.base import BaseStorage
print()
print('=== Test 4: BaseStorage.add default extra_tags=\""\"" ===')
msg = Message(20, 'test msg', extra_tags='')
print(f'extra_tags == \""\"": {msg.extra_tags == \""\""}')
""",
