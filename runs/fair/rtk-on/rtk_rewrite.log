import warnings
from collections import defaultdict, deque
import heapq

def merge_all(lists):
    '''Multi-way merge using topological sort'''
    all_elements = []
    first_appearance = {}
    for lst in lists:
        for item in lst:
            if item not in first_appearance:
                first_appearance[item] = len(all_elements)
                all_elements.append(item)
    
    if not all_elements:
        return []
    
    graph = {item: set() for item in all_elements}
    in_degree = {item: 0 for item in all_elements}
    
    for lst in lists:
        for i in range(len(lst) - 1):
            a, b = lst[i], lst[i+1]
            if b not in graph[a]:
                graph[a].add(b)
                in_degree[b] += 1
    
    heap = [first_appearance[item] for item in all_elements if in_degree[item] == 0]
    heapq.heapify(heap)
    index_to_item = {first_appearance[item]: item for item in all_elements if in_degree[item] == 0}
    
    sorted_items = []
    
    while heap:
        idx = heapq.heappop(heap)
        item = index_to_item[idx]
        sorted_items.append(item)
        for neighbor in graph[item]:
            in_degree[neighbor] -= 1
            if in_degree[neighbor] == 0:
                ni = first_appearance[neighbor]
                index_to_item[ni] = neighbor
                heapq.heappush(heap, ni)
    
    if len(sorted_items) < len(all_elements):
        remaining = set(all_elements) - set(sorted_items)
        # Find the first conflicting pair to report
        for item in sorted(all_elements, key=lambda x: first_appearance.get(x, 0)):
            if item in remaining:
                for neighbor in graph.get(item, set()):
                    if neighbor in remaining:
                        warnings.warn(
