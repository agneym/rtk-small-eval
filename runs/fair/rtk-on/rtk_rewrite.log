import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
)
django.setup()

from django.db import models, connection

class Author(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'

class Book(models.Model):
    title = models.CharField(max_length=100)
    author = models.ForeignKey(Author, models.CASCADE)
    class Meta:
        app_label = 'test'

with connection.schema_editor() as editor:
    editor.create_model(Author)
    editor.create_model(Book)

from django.db.models.deletion import Collector, get_candidate_relations_to_delete

# Check Author's candidate relations
opts = Author._meta
print('Author fields:')
for f in opts.get_fields(include_hidden=True):
    print(f'  {f.name}: auto_created={f.auto_created}, concrete={f.concrete}, one_to_one={f.one_to_one}, one_to_many={f.one_to_many}')

print()
print('Candidate relations for Author:')
for rel in get_candidate_relations_to_delete(opts):
    print(f'  {rel.name}: field={rel.field}, on_delete={rel.field.remote_field.on_delete}')

print()
collector = Collector(using='default')
qs = Author.objects.filter(name__in=[])
print(f'can_fast_delete: {collector.can_fast_delete(qs)}')
