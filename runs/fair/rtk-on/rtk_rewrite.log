    editor.create_model(Referrer)

from django.db.models.deletion import Collector, get_candidate_relations_to_delete

print('Origin fields:')
for f in Origin._meta.get_fields(include_hidden=True):
    print(f'  {f.name}: auto_created={f.auto_created}, concrete={f.concrete}')

print()
print('Referrer fields:')
for f in Referrer._meta.get_fields(include_hidden=True):
    print(f'  {f.name}: auto_created={f.auto_created}, concrete={f.concrete}')

