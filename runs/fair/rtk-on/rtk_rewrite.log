# Read the file
with open('django/db/models/fields/related.py', 'r') as f:
    lines = f.readlines()

# Find the check method and add the new check
for i, line in enumerate(lines):
    if '*self._check_table_uniqueness(**kwargs),' in line:
        print(f'Line {i+1}: {line.rstrip()}')
        # Add the new check before this line
        lines.insert(i, '            *self._check_symmetrical_related_name(**kwargs),\n')
        break

# Now find where to add the _check_symmetrical_related_name method
# It should be added after _check_ignored_options and before _check_table_uniqueness
for i, line in enumerate(lines):
    if 'def _check_table_uniqueness' in line:
        print(f'Line {i+1}: {line.rstrip()}')
        # We'll add our method before this one
        break

with open('django/db/models/fields/related.py', 'w') as f:
    f.writelines(lines)
print('Done')
""
