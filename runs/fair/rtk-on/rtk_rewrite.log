import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
)
django.setup()

from django.db import models
from django.db.migrations.state import ModelState, ProjectState
from django.db.migrations.operations.fields import RenameField

# Verify that RenameField.state_forwards updates FK to_field properly
print('=== Verify RenameField handles FK to_field ===')

before_state = ProjectState()
before_state.add_model(ModelState('app', 'ModelA', [
    ('field_wrong', models.CharField('field1', max_length=50, primary_key=True)),
]))
before_state.add_model(ModelState('app', 'ModelB', [
    ('id', models.AutoField(primary_key=True)),
    ('modela', models.ForeignKey('app.ModelA', models.CASCADE, blank=True, null=True, to_field='field_wrong')),
]))

# Check FK field_name before rename
old_model_b = before_state.apps.get_model('app', 'ModelB')
old_fk = old_model_b._meta.get_field('modela')
print(f'Before RenameField - FK field_name: {old_fk.remote_field.field_name}')

# Apply RenameField
op = RenameField('ModelA', 'field_wrong', 'field_fixed')
new_state = before_state.clone()
op.state_forwards('app', new_state)

# Check FK field_name after rename
new_model_b = new_state.apps.get_model('app', 'ModelB')
new_fk = new_model_b._meta.get_field('modela')
print(f'After RenameField - FK field_name: {new_fk.remote_field.field_name}')
print(f'RenameField correctly updates FK to_field: {new_fk.remote_field.field_name == \""field_fixed\""}')
