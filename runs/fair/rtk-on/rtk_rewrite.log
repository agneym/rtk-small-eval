    content = f.read()

# Add the new method before _check_table_uniqueness
new_method = '''
    def _check_symmetrical_related_name(self, **kwargs):
        if self.remote_field.symmetrical and (
            self.remote_field.model == RECURSIVE_RELATIONSHIP_CONSTANT or
            self.remote_field.model == self.model
        ) and self._related_name is not None:
            return [
                checks.Error(
                    'related_name cannot be specified for ManyToManyField '
                    'with symmetrical=True on a self-referential field.',
                    obj=self,
                    id='fields.E341',
                )
            ]
        return []

'''

# Find where to insert
insert_pos = content.find('    def _check_table_uniqueness')
content = content[:insert_pos] + new_method + content[insert_pos:]

with open('django/db/models/fields/related.py', 'w') as f:
    f.write(content)

print('Done')
