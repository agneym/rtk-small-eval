import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
)
django.setup()

from django.contrib.auth.models import User, Group
from django.db import models, connection

with connection.schema_editor() as editor:
    editor.create_model(User)
    editor.create_model(Group)

# Test with auth.User (has reverse FK from User_groups, User_permissions)
print('=== Test 1: Model with reverse FK relations ===')
print('User (has reverse FK from Group memberships):')
result = User.objects.filter(id__in=[]).delete()
print(f'  Result: {result}')
assert result == (0, {'auth.User': 0}), f'Expected (0, {{\""auth.User\"": 0}}), got {result}'
print('  PASS')

print()
print('=== Test 2: Verify normal deletion still works ===')
u = User.objects.create(username='testuser')
result = User.objects.filter(id=u.id).delete()
print(f'  Result: {result}')
assert result[0] == 1, f'Expected 1 deleted, got {result}'
assert 'auth.User' in result[1], f'Expected auth.User in result, got {result}'
print('  PASS')

print()
print('=== Test 3: Cascade deletion with related objects ===')
# Create models with FK relationships
class Author(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'
        db_table = 'test_author_fix'

class Book(models.Model):
    title = models.CharField(max_length=100)
    author = models.ForeignKey(Author, models.CASCADE)
    class Meta:
        app_label = 'test'
        db_table = 'test_book_fix'

with connection.schema_editor() as editor:
    editor.create_model(Author)
    editor.create_model(Book)

# Create an author with a book
a = Author.objects.create(name='Author')
b = Book.objects.create(title='Book', author=a)

# Delete the author (should cascade to book)
result = Author.objects.filter(id=a.id).delete()
print(f'  Delete Author with Book: {result}')
assert result[0] == 2, f'Expected 2 total deleted, got {result}'
assert 'test.Author' in result[1], f'Expected test.Author in result'
assert 'test.Book' in result[1], f'Expected test.Book in result'
print('  PASS')

print()
print('=== All tests passed! ===')
