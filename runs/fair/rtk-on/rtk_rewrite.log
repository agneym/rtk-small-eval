with open('django/templatetags/static.py', 'r') as f:
    content = f.read()

# Modify PrefixNode.handle_simple() to include script prefix
old_method = '''    @classmethod
    def handle_simple(cls, name):
        try:
            from django.conf import settings
        except ImportError:
            prefix = ''
        else:
            prefix = iri_to_uri(getattr(settings, name, ''))
        return prefix'''

new_method = '''    @classmethod
    def handle_simple(cls, name):
        try:
            from django.conf import settings
        except ImportError:
            prefix = ''
        else:
            prefix = iri_to_uri(getattr(settings, name, ''))
        return cls.handle_script_prefix(prefix)

    @classmethod
    def handle_script_prefix(cls, prefix):
        from django.urls import get_script_prefix
        script_prefix = get_script_prefix()
        if script_prefix != '/' and prefix:
            prefix = script_prefix.rstrip('/') + prefix
        return prefix'''

assert old_method in content, ""Could not find old method""
content = content.replace(old_method, new_method)

with open('django/templatetags/static.py', 'w') as f:
    f.write(content)

print(""Updated django/templatetags/static.py"")
PYEOF
