import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')

import django
django.setup()

from django.db import models

class OneModel(models.Model):
    class Meta:
        ordering = (""-id"",)
        app_label = 'test_ordering'
    id = models.BigAutoField(primary_key=True)
    root = models.ForeignKey(""self"", on_delete=models.CASCADE, null=True)
    oneval = models.BigIntegerField(null=True)

class TwoModel(models.Model):
    class Meta:
        app_label = 'test_ordering'
    id = models.BigAutoField(primary_key=True)
    record = models.ForeignKey(OneModel, on_delete=models.CASCADE)
    twoval = models.BigIntegerField(null=True)

# Test all the cases from the PR

qs = TwoModel.objects.filter(record__oneval__in=[1,2,3])

print(""1. order_by('record__root_id')"")
qs1 = qs.order_by(""record__root_id"")
print(qs1.query)
print()

print(""2. order_by('record__root')"")
qs2 = qs.order_by(""record__root"")
print(qs2.query)
print()

print(""3. order_by('record__root__id')"")
qs3 = qs.order_by(""record__root__id"")
print(qs3.query)
print()

print(""4. order_by('-record__root_id')"")
qs4 = qs.order_by(""-record__root_id"")
print(qs4.query)
print()

print(""5. order_by('-record__root')"")
qs5 = qs.order_by(""-record__root"")
print(qs5.query)
print()

print(""6. order_by('-record__root__id')"")
qs6 = qs.order_by(""-record__root__id"")
print(qs6.query)
print()

# Check each case
for name, qs_obj in [(""record__root_id"", qs1), (""record__root"", qs2), 
                      (""record__root__id"", qs3), (""-record__root_id"", qs4),
                      (""-record__root"", qs5), (""-record__root__id"", qs6)]:
    sql = str(qs_obj.query)
    joins_count = sql.count(""JOIN"")
    is_desc = ""DESC"" in sql.upper().split(""ORDER BY"")[1] if ""ORDER BY"" in sql else False
    print(f""{name}: {joins_count} JOIN(s), {'DESC' if is_desc else 'ASC'} - {sql.split('ORDER BY')[1].strip() if 'ORDER BY' in sql else 'N/A'}"")
