import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    ROOT_URLCONF='tests.urlpatterns_reverse.urls',
    TEMPLATES=[{'BACKEND': 'django.template.backends.django.DjangoTemplates', 'DIRS': [], 'APP_DIRS': True}],
)
django.setup()

from django.urls import resolvers
import functools

def empty_view(request, *args, **kwargs):
    pass

# Test 1: Basic function
match = resolvers.ResolverMatch(empty_view, ('arg1',), {'key1': 'val1'}, url_name='test')
assert match.func is empty_view
assert match.args == ('arg1',)
assert match.kwargs == {'key1': 'val1'}
assert match._func_path == '__main__.empty_view'
print('Test 1 passed: Basic function')

# Test 2: Partial function
partial_view = functools.partial(empty_view, template_name='test.html')
match = resolvers.ResolverMatch(partial_view, (), {'extra': 'val'}, url_name='partial-test')
assert match.func is empty_view
assert match.args == ()
assert match.kwargs == {'template_name': 'test.html', 'extra': 'val'}
assert match._func_path == '__main__.empty_view'
print('Test 2 passed: Partial function')

# Test 3: Partial with positional args
partial_view2 = functools.partial(empty_view, 'pos_arg')
match = resolvers.ResolverMatch(partial_view2, ('url_arg',), {}, url_name='partial-pos')
assert match.func is empty_view
assert match.args == ('pos_arg', 'url_arg')
assert match._func_path == '__main__.empty_view'
print('Test 3 passed: Partial with positional args')

# Test 4: Nested partial (should be flattened by functools)
partial_nested = functools.partial(partial_view, extra2='val2')
match = resolvers.ResolverMatch(partial_nested, (), {}, url_name='nested')
assert match.func is empty_view
assert match.kwargs == {'template_name': 'test.html', 'extra2': 'val2'}
assert match._func_path == '__main__.empty_view'
print('Test 4 passed: Nested partial')

# Test 5: __getitem__ should work with combined values
match = resolvers.ResolverMatch(partial_view, ('url_arg',), {'extra': 'val'}, url_name='getitem')
func, args, kwargs = match[0], match[1], match[2]
assert func is empty_view
assert args == ('url_arg',)
assert kwargs == {'template_name': 'test.html', 'extra': 'val'}
print('Test 5 passed: __getitem__')

print()
print('All tests passed!')
