# Reset Django
import django
from django.conf import settings
django.setup()

from django.db.migrations.state import ProjectState
from django.db.migrations.autodetector import MigrationAutodetector

# Build old state
old_state = ProjectState.from_apps(django.apps.apps)

# Now load the new models
if 'testapp.models' in sys.modules:
    del sys.modules['testapp.models']
if 'testapp' in sys.modules:
    del sys.modules['testapp']

with open(os.path.join(tmpdir, 'testapp', 'models.py'), 'w') as f:
    f.write('''
from django.db import models

class ProjectDataSet(models.Model):
    name = models.TextField(max_length=50)

class Authors(models.Model):
    project_data_set = models.ManyToManyField(
        ProjectDataSet,
    )
    state = models.IntegerField()
    start_date = models.DateField()
''')

from django.apps import apps
apps.clear_cache()

import importlib
import testapp.models
django.setup()

new_state = ProjectState.from_apps(django.apps.apps)

# Compare old and new
old_model = old_state.models['testapp', 'authors']
new_model = new_state.models['testapp', 'authors']

print(""\nOld fields:"")
for name, field in old_model.fields.items():
    print(f""  {name}: {type(field).__name__}, many_to_many={field.many_to_many}"")

print(""\nNew fields:"")
for name, field in new_model.fields.items():
    print(f""  {name}: {type(field).__name__}, many_to_many={field.many_to_many}"")

print(f""\nOld unique_together: {old_model.options.get('unique_together')}"")
print(f""New unique_together: {new_model.options.get('unique_together')}"")

# Now generate the autodetector
from django.db.migrations.questioner import MigrationQuestioner
autodetector = MigrationAutodetector(old_state, new_state, MigrationQuestioner())
changes = autodetector.changes(graph=None)

print(f""\nNumber of migrations generated: {len(changes.get('testapp', []))}"")
for migration in changes.get('testapp', []):
    print(f""  Migration name: {migration.name}"")
    print(f""  Operations:"")
    for op in migration.operations:
        print(f""    - {op.__class__.__name__}: {op.describe()}"")
