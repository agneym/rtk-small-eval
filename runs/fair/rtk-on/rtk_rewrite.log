import os
os.environ['DJANGO_SETTINGS_MODULE'] = 'tests.test_sqlite'

import django
from django.conf import settings

# Configure settings properly
settings.DATABASES = {
    'default': {
        'ENGINE': 'django.db.backends.sqlite3',
        'NAME': ':memory:',
    },
}
settings.SECRET_KEY = 'test-secret-key'
settings.INSTALLED_APPS = [
    'django.contrib.contenttypes',
    'django.contrib.auth',
]
settings.PASSWORD_RESET_TIMEOUT = 86400
django.setup()

# Create tables
from django.core.management import call_command
call_command('migrate', '--run-syncdb', verbosity=0)

from django.contrib.auth.models import User
from django.contrib.auth.tokens import PasswordResetTokenGenerator

# Test 1: Token remains valid if email hasn't changed
print(""Test 1: Token valid without email change"")
user = User.objects.create_user('testuser1', 'test1@example.com', 'testpass123')
p0 = PasswordResetTokenGenerator()
token = p0.make_token(user)
assert p0.check_token(user, token) == True, ""Token should be valid""
print(""  PASS"")

# Test 2: Token becomes invalid when email changes
print(""Test 2: Token invalid after email change"")
user.email = 'changed@example.com'
user.save()
assert p0.check_token(user, token) == False, ""Token should be invalid""
print(""  PASS"")

# Test 3: Email set to empty string should invalidate token
print(""Test 3: Token invalid when email set to empty"")
user2 = User.objects.create_user('testuser2', 'test2@example.com', 'testpass456')
token2 = p0.make_token(user2)
user2.email = ''
user2.save()
assert p0.check_token(user2, token2) == False, ""Token should be invalid after email emptied""
print(""  PASS"")

# Test 4: Token still valid for user with email=None initially
print(""Test 4: Token works with empty email"")
# Create a user with no email
user3 = User.objects.create_user('testuser3', '', 'testpass789')
token3 = p0.make_token(user3)
assert p0.check_token(user3, token3) == True, ""Token should be valid with empty email""
print(""  PASS"")

# Test 5: Token becomes invalid when email changes from empty to something
print(""Test 5: Token invalid when email changes from empty to something"")
user3.email = 'newemail@example.com'
user3.save()
assert p0.check_token(user3, token3) == False, ""Token should be invalid after email change from empty""
print(""  PASS"")

# Test 6: Different users have different tokens (even with same email)
print(""Test 6: Different users get different tokens"")
user4 = User.objects.create_user('testuser4', 'same@example.com', 'pass1')
user5 = User.objects.create_user('testuser5', 'same@example.com', 'pass2')
# Use mocked time to compare tokens at same timestamp
from django.contrib.auth.tokens import PasswordResetTokenGenerator as PRTG
token4 = p0.make_token(user4)
token5 = p0.make_token(user5)
assert token4 != token5, ""Different users should have different tokens""
print(""  PASS"")

print(""\nAll edge case tests passed!"")
EOF
