import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
)
django.setup()

from django.db import models, connection
from django.db.models import F, Q
from django.db.models.constraints import UniqueConstraint

# Create the schema editor
with connection.schema_editor() as schema_editor:
    
    # Define a model with various constraints
    class Tag(models.Model):
        name = models.SlugField(help_text='The tag key.')
        value = models.CharField(max_length=150, help_text='The tag value.')
        category = models.CharField(max_length=50, default='general')
        class Meta:
            app_label = 'myapp'
            db_table = 'test_tag2'
            constraints = [
                UniqueConstraint(
                    F('name'),
                    F('value'),
                    name='unique_name_value',
                ),
                UniqueConstraint(
                    fields=['name'],
                    name='unique_name',
                ),
                UniqueConstraint(
                    fields=['value'],
                    condition=Q(category='special'),
                    name='unique_value_conditional',
                ),
            ]
    
    # Create the table
    schema_editor.create_model(Tag)
    print('Created table successfully')
    
    # Test altering a field with constraints
    old_field = Tag._meta.get_field('value')
    new_field = models.CharField(max_length=200, help_text='The tag value (updated).')
    new_field.set_attributes_from_name('value')
    new_field.model = Tag
    
    schema_editor.alter_field(Tag, old_field, new_field)
    print('Altered field successfully')
    
    # Test another alter
    old_field2 = Tag._meta.get_field('name')
    new_field2 = models.SlugField(max_length=100, help_text='The tag key (updated).')
    new_field2.set_attributes_from_name('name')
    new_field2.model = Tag
    
    schema_editor.alter_field(Tag, old_field2, new_field2)
    print('Altered name field successfully')
    
    # Test add/remove constraints
    schema_editor.add_constraint(Tag, UniqueConstraint(
        fields=['category'],
        name='unique_category',
    ))
    print('Added constraint successfully')
    
    schema_editor.remove_constraint(Tag, UniqueConstraint(
        fields=['category'],
        name='unique_category',
    ))
    print('Removed constraint successfully')

print('All tests passed!')
