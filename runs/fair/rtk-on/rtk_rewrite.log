# Read the file
with open('django/core/checks/translation.py', 'r') as f:
    content = f.read()

# Replace the check_language_settings_consistent function
old = """"""@register(Tags.translation)
def check_language_settings_consistent(app_configs, **kwargs):
    \""\""\""Error if language settings are not consistent with each other.\""\""\""
    available_tags = {i for i, _ in settings.LANGUAGES} | {'en-us'}
    if settings.LANGUAGE_CODE not in available_tags:
        return [E004]
    return []""""""

new = """"""@register(Tags.translation)
def check_language_settings_consistent(app_configs, **kwargs):
    \""\""\""Error if language settings are not consistent with each other.\""\""\""
    available_tags = {i for i, _ in settings.LANGUAGES} | {'en-us'}
    if settings.LANGUAGE_CODE not in available_tags:
        # The LANGUAGE_CODE setting may be a sublanguage (e.g., de-at) where
        # the base language (e.g., de) is available, which is allowed.
        generic_lang_code = settings.LANGUAGE_CODE.split('-')[0]
        if generic_lang_code not in available_tags:
            return [E004]
    return []""""""

assert old in content, ""Could not find the function to replace""
content = content.replace(old, new)

with open('django/core/checks/translation.py', 'w') as f:
    f.write(content)

print(""Done"")
EOF
python /tmp/fix.py",
