# Fix line 748: cur_model = source.related_model -> cur_model = source.related_model._meta.concrete_model
# Fix line 751: cur_model = source.remote_field.model -> cur_model = source.remote_field.model._meta.concrete_model
old = '''                if is_reverse_o2o(source):
                    cur_model = source.related_model
                else:
                    cur_model = source.remote_field.model
                opts = cur_model._meta'''

new = '''                if is_reverse_o2o(source):
                    cur_model = source.related_model._meta.concrete_model
                else:
                    cur_model = source.remote_field.model._meta.concrete_model
                opts = cur_model._meta'''

if old in content:
    content = content.replace(old, new, 1)
    with open('django/db/models/sql/query.py', 'w') as f:
        f.write(content)
    print('Fix applied successfully')
else:
    print('Could not find the code to replace')
    # Show what's around that area
    import sys
    sys.exit(1)
