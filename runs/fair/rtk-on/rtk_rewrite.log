from django.db import models, connection
from django.db.models import Count, Subquery, OuterRef, Value, IntegerField

class Publisher(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'

class Book(models.Model):
    publisher = models.ForeignKey(Publisher, on_delete=models.CASCADE, related_name='books')
    pages = models.IntegerField(default=0)
    class Meta:
        app_label = 'test'

with connection.schema_editor() as schema_editor:
    schema_editor.create_model(Publisher)
    schema_editor.create_model(Book)

# Add some data
p1 = Publisher.objects.create(name='P1')
p2 = Publisher.objects.create(name='P2')
p3 = Publisher.objects.create(name='P3')
p4 = Publisher.objects.create(name='P4')
p5 = Publisher.objects.create(name='P5')

