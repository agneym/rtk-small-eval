import django
import os
os.environ['DJANGO_SETTINGS_MODULE'] = 'tests.test_sqlite'

import sys
sys.path.insert(0, '/testbed/tests')

from django.conf import settings
settings.INSTALLED_APPS = [
    'django.contrib.contenttypes',
    'django.contrib.auth',
]

# Need to configure the database properly
settings.DATABASES['default']['NAME'] = ':memory:'

django.setup()

from django.db import models, connection
from django.db.models import Q

# Create schema
with connection.schema_editor() as schema_editor:
    class Category(models.Model):
        name = models.CharField(max_length=100)
        class Meta:
            app_label = 'test'
    
    class Book(models.Model):
        title = models.CharField(max_length=100)
        class Meta:
            app_label = 'test'
    
    class Page(models.Model):
        book = models.ForeignKey(Book, models.CASCADE, related_name='pages')
        content = models.TextField()
        class Meta:
            app_label = 'test'
    
    # This is the model with limit_choices_to that involves a join
    # from Book -> Page (one-to-many)
    class EditorialReview(models.Model):
        book = models.ForeignKey(Book, models.CASCADE, related_name='reviews',
                                  limit_choices_to=Q(pages__content__startswith='A'))
        rating = models.IntegerField()
        class Meta:
            app_label = 'test'
    
    schema_editor.create_model(Category)
    schema_editor.create_model(Book)
    schema_editor.create_model(Page)
    schema_editor.create_model(EditorialReview)

# Insert some data
book1 = Book.objects.create(title='Book 1')
Page.objects.create(book=book1, content='A page')
Page.objects.create(book=book1, content='Another page')
Page.objects.create(book=book1, content='B page')

book2 = Book.objects.create(title='Book 2')
Page.objects.create(book=book2, content='A page')

book3 = Book.objects.create(title='Book 3')
Page.objects.create(book=book3, content='C page')

# Now test get_choices on EditorialReview.book
field = EditorialReview._meta.get_field('book')
print(""Testing get_choices..."")
choices = field.get_choices(include_blank=False)
print(f""Number of choices: {len(choices)}"")
for choice in choices:
    print(f""  {choice}"")

# Book 1 has 2 pages starting with 'A', so without distinct(), it will appear twice!
ids = [c[0] for c in choices]
if len(ids) != len(set(ids)):
    print(""BUG: DUPLICATE OPTIONS DETECTED!"")
else:
    print(""OK: No duplicates"")

# Clean up
with connection.schema_editor() as se:
    se.delete_model(EditorialReview)
    se.delete_model(Page)
    se.delete_model(Book)
    se.delete_model(Category)
