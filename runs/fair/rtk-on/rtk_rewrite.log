import django
from django.conf import settings
settings.configure(USE_I18N=True, USE_L10N=True)
django.setup()

from django.forms import URLField
from django.core.exceptions import ValidationError

f = URLField()

# Test cases from the PR/fix
test_cases = [
    # Original PR case - should not raise ValueError
    ('////]@N.AN', ValidationError),
    # Empty hostname case
    ('#@A.bO', ValidationError),
    # Valid URLs
    ('http://example.com', None),
    ('http://[::1]', None),
    ('https://google.com', None),
    ('ftp://example.com', None),
    # Invalid URLs
    ('http://[invalid', ValidationError),
    ('http://[', ValidationError),
    ('http://]', ValidationError),
    ('not-a-url', ValidationError),
]

all_pass = True
for url, expected_error in test_cases:
    try:
        result = f.clean(url)
        if expected_error is None:
            print(f'PASS: {url!r} -> {result!r}')
        else:
            print(f'FAIL: {url!r} -> expected {expected_error.__name__}, got no error (result={result!r})')
            all_pass = False
    except ValidationError as e:
        if expected_error == ValidationError:
            print(f'PASS: {url!r} -> ValidationError (expected)')
        else:
            print(f'FAIL: {url!r} -> unexpected ValidationError: {e}')
            all_pass = False
    except ValueError as e:
        print(f'FAIL: {url!r} -> ValueError (should have been ValidationError): {e}')
        all_pass = False
    except Exception as e:
        print(f'FAIL: {url!r} -> unexpected {type(e).__name__}: {e}')
        all_pass = False

if all_pass:
    print('\nAll tests PASSED!')
else:
    print('\nSome tests FAILED!')
""",
