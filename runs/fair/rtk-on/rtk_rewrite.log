import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
)
django.setup()

from django.contrib.auth.models import User
from django.db import models, connection

# Test with auth.User (has reverse FK from User_groups, User_permissions)
# But we need to create the auth tables first
from django.core.management import call_command
call_command('migrate', '--run-syncdb', verbosity=0)

print('=== Test 1: Model with reverse FK relations (User via auth) ===')
result = User.objects.filter(id__in=[]).delete()
print(f'  Result: {result}')
assert result == (0, {'auth.User': 0}), f'Expected (0, {{\""auth.User\"": 0}}), got {result}'
print('  PASS')

print()
print('=== Test 2: Normal deletion with objects ===')
u = User.objects.create(username='testuser')
result = User.objects.filter(id=u.id).delete()
print(f'  Result: {result}')
assert result[0] == 1, f'Expected 1 deleted, got {result}'
assert 'auth.User' in result[1], f'Expected auth.User in result'
print('  PASS')

print()
print('=== Test 3: Custom model without reverse FK ===')
class Simple(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'simple'
        db_table = 'simple_model'

with connection.schema_editor() as editor:
    editor.create_model(Simple)

print('  Simple model (no reverse FK), empty queryset:')
result = Simple.objects.filter(id__in=[]).delete()
print(f'    Result: {result}')
assert result == (0, {'simple.Simple': 0}), f'Expected (0, {{\""simple.Simple\"": 0}}), got {result}'
print('  PASS')

print()
print('=== Test 4: Custom model with forward FK (no reverse) ===')
class Child(models.Model):
    parent = models.ForeignKey(Simple, models.CASCADE)
    class Meta:
        app_label = 'simple'
        db_table = 'child_model'

with connection.schema_editor() as editor:
    editor.create_model(Child)

print('  Child model (forward FK only), empty queryset:')
result = Child.objects.filter(id__in=[]).delete()
print(f'    Result: {result}')
# Child has no reverse FK, so can_fast_delete is True, model should be in result
assert result == (0, {'simple.Child': 0}), f'Expected (0, {{\""simple.Child\"": 0}}), got {result}'
print('  PASS')

print()
print('=== Test 5: Model with reverse FK (via Child), empty queryset ===')
print('  Simple model (has reverse FK from Child), empty queryset:')
result = Simple.objects.filter(id__in=[]).delete()
print(f'    Result: {result}')
assert result == (0, {'simple.Simple': 0}), f'Expected (0, {{\""simple.Simple\"": 0}}), got {result}'
print('  PASS')

print()
print('=== All tests passed! ===')
