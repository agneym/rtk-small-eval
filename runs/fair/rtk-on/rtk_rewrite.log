import numpy as np
from astropy.io import fits
import tempfile
import os

# Test: Write an ASCII table with 'D' format and verify D exponents are written
data = np.array([1.23456e10, 2.34567e20, 3.45678e-30], dtype=np.float64)

col1 = fits.Column(name='a', format='D20.10', array=data)
cols = fits.ColDefs([col1])

# Create an ASCII table HDU
hdu = fits.HDUList([fits.PrimaryHDU(), fits.BinTableHDU.from_columns(cols)])

# Actually, for ASCII tables we need to use a different approach
# Let me look at how ASCII tables work...

# Try creating a simple ASCII table
tmpfile = tempfile.mktemp('.fits')
try:
    tbhdu = fits.BinTableHDU.from_columns(cols)
    # Write to FITS file
    hdu = fits.HDUList([fits.PrimaryHDU(), tbhdu])
    hdu.writeto(tmpfile, overwrite=True)
    print('Wrote file successfully')
    
    # Read back
    with fits.open(tmpfile) as hdul:
        print('Read back successfully')
        print(hdul[1].data)
finally:
    if os.path.exists(tmpfile):
        os.unlink(tmpfile)
