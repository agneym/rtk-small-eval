import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
)
django.setup()

from django.db import models, connection
from django.db.models import Q, Count, Subquery, OuterRef, Value, Exists, IntegerField

# Test with the original bug report pattern
class A(models.Model):
    class Meta:
        app_label = 'test3'

class B(models.Model):
    class Meta:
        app_label = 'test3'

class AB(models.Model):
    a = models.ForeignKey(A, on_delete=models.CASCADE, related_name='ab_a')
    b = models.ForeignKey(B, on_delete=models.CASCADE, related_name='ab_b')
    status = models.IntegerField()
    class Meta:
        app_label = 'test3'

class C(models.Model):
    a = models.ForeignKey(A, null=True, blank=True, on_delete=models.SET_NULL, related_name='c')
    status = models.IntegerField()
    class Meta:
        app_label = 'test3'

# Use proper model setup
# Create a temporary model for testing joins

# Test various scenarios
class Author(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test3'

class Book(models.Model):
    author = models.ForeignKey(Author, on_delete=models.CASCADE)
    title = models.CharField(max_length=100)
    class Meta:
        app_label = 'test3'

with connection.schema_editor() as schema_editor:
    for model in [A, B, AB, C, Author, Book]:
        try:
            schema_editor.create_model(model)
        except:
            pass

# Test 1: Simple subquery annotation with .values().annotate()
subq = Book.objects.filter(author=OuterRef('pk')).values('title')[:1]
query = Author.objects.annotate(
    my_title=Subquery(subq),
    total=Count('id'),
)
answer = query.values('my_title').annotate(total_count=Count('my_title'))
print('Test 1 - Simple subquery annotation:')
print('Query:', answer.query)
print()

# Test 2: Exists annotation with values/annotate
query2 = Author.objects.annotate(
    has_books=Exists(Book.objects.filter(author=OuterRef('pk'))),
    total=Count('id'),
)
answer2 = query2.values('has_books').annotate(total_count=Count('*'))
print('Test 2 - Exists annotation:')
print('Query:', answer2.query)
print()

# Test 3: Multiple annotations
query3 = Author.objects.annotate(
    my_title=Subquery(subq),
    book_count=Count('book'),
)
answer3 = query3.values('my_title').annotate(
    total_count=Count('my_title'),
    total_books=Count('book'),
)
print('Test 3 - Multiple annotations:')
print('Query:', answer3.query)
print()

# Test 4: Check that GROUP BY still works with regular column refs
authors = Author.objects.values('name').annotate(total=Count('id'))
print('Test 4 - Regular column GROUP BY:')
print('Query:', authors.query)
print()

# Test 5: Check annotation referencing another annotation doesn't break
query5 = Author.objects.annotate(
    total=Count('id') * 2,
).values('total').annotate(count=Count('*'))
print('Test 5 - Annotation on annotation:')
print('Query:', query5.query)
print()
