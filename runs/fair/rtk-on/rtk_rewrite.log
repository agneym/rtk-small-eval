import django
from django.conf import settings
if not settings.configured:
    settings.configure(
        DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
        INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
        DEFAULT_AUTO_FIELD='django.db.models.AutoField',
    )
    django.setup()

from django.db import models

# Edge case 1: model with filterable=True field
class ModelWithFilterableTrue(models.Model):
    label = models.CharField(max_length=255)
    filterable = models.BooleanField(default=True)
    
    class Meta:
        app_label = 'test'

class RelatedModel(models.Model):
    name = models.CharField(max_length=255)
    fk = models.ForeignKey(ModelWithFilterableTrue, on_delete=models.CASCADE)
    
    class Meta:
        app_label = 'test'

# Test with filterable=True
obj = ModelWithFilterableTrue(label='test', filterable=True)
try:
    qs = RelatedModel.objects.filter(name='test', fk=obj)
    print('Edge case 1 PASS: filterable=True field value works')
except Exception as e:
    print(f'Edge case 1 FAIL: {e}')

# Edge case 2: model with no filterable field
class ModelNoFilterable(models.Model):
    label = models.CharField(max_length=255)
    
    class Meta:
        app_label = 'test'

class RelatedModel2(models.Model):
    name = models.CharField(max_length=255)
    fk = models.ForeignKey(ModelNoFilterable, on_delete=models.CASCADE)
    
    class Meta:
        app_label = 'test'

obj2 = ModelNoFilterable(label='test')
try:
    qs = RelatedModel2.objects.filter(name='test', fk=obj2)
    print('Edge case 2 PASS: model without filterable field works')
except Exception as e:
    print(f'Edge case 2 FAIL: {e}')

# Edge case 3: multiple filter kwargs
obj3 = ModelWithFilterableTrue(label='test2', filterable=True)
try:
    qs = RelatedModel.objects.filter(name='test', fk=obj).filter(fk=obj3)
    print('Edge case 3 PASS: chained filters work')
except Exception as e:
    print(f'Edge case 3 FAIL: {e}')

# Edge case 4: exclude
try:
    qs = RelatedModel.objects.exclude(name='test', fk=obj)
    print('Edge case 4 PASS: exclude works')
except Exception as e:
    print(f'Edge case 4 FAIL: {e}')
