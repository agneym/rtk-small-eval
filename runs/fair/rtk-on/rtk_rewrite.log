import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
)
django.setup()

from django.db import models
from django.core import checks

# Test 1: Self-referential M2M with related_name and symmetrical=True (explicit)
class TestModel1(models.Model):
    m2m = models.ManyToManyField('self', symmetrical=True, related_name='friends')
    class Meta:
        app_label = 'test'

errors = TestModel1.check()
print('Test 1 - Self-referential M2M with symmetrical=True, related_name:')
for e in errors:
    print(f'  {e.id}: {e.msg}')
print(f'  Total errors: {len(errors)}')
print()

# Test 2: Self-referential M2M with related_name (default symmetrical=True)
class TestModel2(models.Model):
    m2m = models.ManyToManyField('self', related_name='friends')
    class Meta:
        app_label = 'test'

errors = TestModel2.check()
print('Test 2 - Self-referential M2M (default symmetrical) with related_name:')
for e in errors:
    print(f'  {e.id}: {e.msg}')
print(f'  Total errors: {len(errors)}')
print()

# Test 3: Self-referential M2M with symmetrical=False and related_name (should be fine)
class TestModel3(models.Model):
    m2m = models.ManyToManyField('self', symmetrical=False, related_name='friends')
    class Meta:
        app_label = 'test'

errors = TestModel3.check()
print('Test 3 - Self-referential M2M with symmetrical=False, related_name:')
for e in errors:
    print(f'  {e.id}: {e.msg}')
print(f'  Total errors: {len(errors)}')
print()

# Test 4: Self-referential M2M without related_name (should be fine)
class TestModel4(models.Model):
    m2m = models.ManyToManyField('self', symmetrical=True)
    class Meta:
        app_label = 'test'

errors = TestModel4.check()
print('Test 4 - Self-referential M2M with symmetrical=True, no related_name:')
for e in errors:
    print(f'  {e.id}: {e.msg}')
print(f'  Total errors: {len(errors)}')
print()

# Test 5: Non-self-referential M2M with symmetrical=True and related_name (edge case)
class OtherModel(models.Model):
    name = models.CharField(max_length=10)
    class Meta:
        app_label = 'test'

class TestModel5(models.Model):
    m2m = models.ManyToManyField(OtherModel, symmetrical=True, related_name='test_items')
    class Meta:
        app_label = 'test'

errors = TestModel5.check()
print('Test 5 - Non-self-referential M2M with symmetrical=True, related_name:')
for e in errors:
    print(f'  {e.id}: {e.msg}')
print(f'  Total errors: {len(errors)}')
