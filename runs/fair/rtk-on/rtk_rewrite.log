import numpy as np
from astropy.io import fits
from astropy.io.fits.column import Column, ColDefs
import tempfile
import os

# Test ASCII table with D format (with the fix already applied)
data = np.array([1.23456e10, 2.34567e20, 3.45678e-30], dtype=np.float64)

col1 = fits.Column(name='a', format='D20.10', array=data)
cols = fits.ColDefs([col1])
tbhdu = fits.TableHDU.from_columns(cols)

tmpfile = tempfile.mktemp('.fits')
try:
    hdu = fits.HDUList([fits.PrimaryHDU(), tbhdu])
    hdu.writeto(tmpfile, overwrite=True)
    
    with open(tmpfile, 'rb') as f:
        content = f.read()
    
    raw = content.decode('ascii', errors='replace')
    
    # Find the data segment more precisely
    # Look for the HD (header-data unit) separation
    # The ASCII table data starts after the END card
    
    import re
    # Find all numbers with exponents
    numbers = re.findall(r'\d+\.\d+[DE][+-]\d+', raw)
    print('Numbers found:', numbers)
    
    # Check for 'E' exponents that should have been 'D'
    e_exponents = re.findall(r'[E][+-]\d+', raw)
    d_exponents = re.findall(r'[D][+-]\d+', raw)
    print('E exponents:', e_exponents)
    print('D exponents:', d_exponents)
    
    if d_exponents and not e_exponents:
        print('SUCCESS: All exponents are D format (correct for D column)')
    elif e_exponents:
        print('BUG: Some exponents are still E format (should be D)')
    else:
        print('No exponents found')
finally:
    if os.path.exists(tmpfile):
        os.unlink(tmpfile)
