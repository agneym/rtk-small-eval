                    # Set serialize=False for primary key fields to match
                    # what Options.setup_pk() does during model rendering
                    # (otherwise the deconstruction comparison fails).
                    if old_field.primary_key:
                        old_field.serialize = False
                    old_field_dec = self.deep_deconstruct(old_field)
                    if field.remote_field and field.remote_field.model and 'to' in old_field_dec[2]:'''
