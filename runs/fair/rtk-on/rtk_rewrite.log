    @wraps(func)
    def inner(*args, **kwargs):
        print(f'{func.__name__} called')
        return func(*args, **kwargs)
    return inner

class Test3:
    def hello(self):
        return 'hello'

Test3 = method_decorator(logger, name='hello')(Test3)
