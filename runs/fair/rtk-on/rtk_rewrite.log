from django.utils.http import parse_http_date
from datetime import datetime
import calendar

# Test the current behavior with a two-digit year
# In 2026, year '70' should be interpreted according to RFC 7231:
# 2070 is 44 years in the future (not more than 50), so it should be 2070, not 1970

try:
    # RFC850 format with two-digit year
    result = parse_http_date('Sunday, 06-Nov-70 08:49:37 GMT')
    dt = datetime.utcfromtimestamp(result)
    print(f'Year 70 -> {dt.year} (expected: 2070 based on RFC 7231)')
except Exception as e:
    print(f'Error: {e}')

# Year 99: 2099 is 73 years in the future (more than 50), so should be 1999
try:
    result = parse_http_date('Sunday, 06-Nov-99 08:49:37 GMT')
    dt = datetime.utcfromtimestamp(result)
    print(f'Year 99 -> {dt.year} (expected: 1999 based on RFC 7231)')
except Exception as e:
    print(f'Error: {e}')
