2026-06-24T09:32:47+00:00,f473ef7b50424a10b5a3cabe2a7bfff4,1,"cd /testbed && cat > /tmp/fix_rst.py << 'EOF'
import sys
sys.path.insert(0, '/testbed')

# Read the current file
with open('astropy/io/ascii/rst.py', 'r') as f:
    content = f.read()

# Replace __init__
old_init = """"""    def __init__(self):
        super().__init__(delimiter_pad=None, bookend=False)""""""

new_init = """"""    def __init__(self, header_rows=None):
        super().__init__(delimiter_pad=None, bookend=False, header_rows=header_rows)""""""

content = content.replace(old_init, new_init)

# Replace write
old_write = """"""    def write(self, lines):
        lines = super().write(lines)
        lines = [lines[1]] + lines + [lines[1]]
        return lines""""""

new_write = """"""    def write(self, lines):
        lines = super().write(lines)
        header_rows = self.data.header_rows
        idx = len(header_rows)
        lines = [lines[idx]] + lines + [lines[idx]]
        return lines""""""

content = content.replace(old_write, new_write)

with open('astropy/io/ascii/rst.py', 'w') as f:
    f.write(content)

print(""File updated successfully"")
EOF
python /tmp/fix_rst.py",
