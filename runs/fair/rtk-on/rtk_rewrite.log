import os, sys
os.environ['DJANGO_SETTINGS_MODULE'] = 'test_settings'

import django
from django.conf import settings
settings.INSTALLED_APPS = [
    'django.contrib.contenttypes',
    'django.contrib.auth',
]
settings.DATABASES = {
    'default': {
        'ENGINE': 'django.db.backends.sqlite3',
        'NAME': ':memory:',
    },
}

sys.path.insert(0, 'tests')
django.setup()

from django.core.management import call_command
from django.apps import apps
from django.contrib.auth.models import Permission
from django.contrib.contenttypes.models import ContentType
from django.db import models

# Create the tables
call_command('migrate', 'auth', '0010', verbosity=0)
call_command('migrate', 'contenttypes', '0002', verbosity=0)

# Create a concrete model class dynamically
class ConcreteModel(models.Model):
    class Meta:
        app_label = 'auth'
        managed = False

class ProxyModel(ConcreteModel):
    class Meta:
        proxy = True
        app_label = 'auth'
        managed = False
        default_permissions = ('add', 'change', 'delete', 'view')

# Register models with the app registry
from django.apps.registry import Apps
test_apps = Apps(['django.contrib.contenttypes', 'django.contrib.auth'])

# Force create content types
ct_concrete = ContentType.objects.get_or_create(
    app_label='auth',
    model='concretemodel',
    defaults={'name': 'Concrete Model'},
)[0]

ct_proxy = ContentType.objects.get_or_create(
    app_label='auth',
    model='proxymodel',
    defaults={'name': 'Proxy Model'},
)[0]

print(f'Concrete CT: {ct_concrete} (id={ct_concrete.id})')
print(f'Proxy CT: {ct_proxy} (id={ct_proxy.id})')

# Create permission with concrete content_type (simulating pre-migration state)
perm1 = Permission.objects.create(
    content_type=ct_concrete,
    codename='add_proxymodel',
    name='Can add proxymodel',
)

# Also create the same permission with proxy content_type (simulating conflict)
perm2 = Permission.objects.create(
    content_type=ct_proxy,
    codename='add_proxymodel',
    name='Can add proxymodel',
)

print(f'Created {Permission.objects.count()} permissions')
print('Permissions before migration:')
for p in Permission.objects.all():
    print(f'  id={p.id}, codename={p.codename}, content_type_id={p.content_type_id}')

# Now run the migration function directly
from importlib import import_module
update_proxy_permissions = import_module('django.contrib.auth.migrations.0011_update_proxy_permissions')

# We need a mock schema_editor
class MockSchemaEditor:
    class Connection:
        alias = 'default'
    connection = Connection()

print('Running migration...')
update_proxy_permissions.update_proxy_model_permissions(apps, MockSchemaEditor())
print('Migration completed successfully (no crash)')

print('Permissions after migration:')
for p in Permission.objects.all():
    print(f'  id={p.id}, codename={p.codename}, content_type_id={p.content_type_id}')
