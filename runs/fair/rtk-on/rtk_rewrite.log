print()

# Test 4: Decorator that sets an attribute
def attr_setter(func):
    @wraps(func)
    def inner(*args, **kwargs):
        return func(*args, **kwargs)
    inner.custom_attr = 'test_value'
    return inner

class Test4:
    @method_decorator(attr_setter)
    def hello(self):
        return 'hello'

t4 = Test4()
print('Test 4 - Custom attribute:', t4.hello())
print('Has custom_attr on wrapper:', hasattr(Test4.hello, 'custom_attr'))
print()

