# Read the resolvers.py file and modify the match method
import re

with open('django/urls/resolvers.py', 'r') as f:
    content = f.read()

# Find the RoutePattern.match method and modify it
old = '''    def match(self, path):
        match = self.regex.search(path)
        if match:
            # RoutePattern doesn't allow non-named groups so args are ignored.
            kwargs = match.groupdict()
            for key, value in kwargs.items():
                converter = self.converters[key]
                try:
                    kwargs[key] = converter.to_python(value)
                except ValueError:
                    return None
            return path[match.end():], (), kwargs
        return None'''

new = '''    def match(self, path):
        match = self.regex.search(path)
        if match:
            # RoutePattern doesn't allow non-named groups so args are ignored.
            kwargs = match.groupdict()
            for key, value in kwargs.items():
                converter = self.converters[key]
                try:
                    kwargs[key] = converter.to_python(value)
                except ValueError:
                    return None
                except Http404:
                    raise Resolver404({'tried': [], 'path': path})
            return path[match.end():], (), kwargs
        return None'''

content = content.replace(old, new)

with open('django/urls/resolvers.py', 'w') as f:
    f.write(content)

print('Done')
