                if remote_field_name:
                    to_field_rename_key = rename_key + (remote_field_name,)
                    if to_field_rename_key in self.renamed_fields:
                        # If the old field_name was the primary key, it was
                        # renamed as well - the RenameField operation will
                        # handle updating the FK's to_field. Don't revert
