    label = m.CharField(max_length=255)
    filterable = m.BooleanField(default=False)
    
    class Meta:
        app_label = 'test'

class TestModelB(m.Model):
    name = m.CharField(max_length=255)
    a = m.ForeignKey(TestModelA, on_delete=m.CASCADE)
    
    class Meta:
        app_label = 'test'

# Test the filter
