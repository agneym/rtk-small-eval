# Read the original file
with open('django/contrib/auth/forms.py', 'r') as f:
    content = f.read()

# Find the class ReadOnlyPasswordHashWidget and add id_for_label method
old = '''class ReadOnlyPasswordHashWidget(forms.Widget):
    template_name = 'auth/widgets/read_only_password_hash.html'
    read_only = True

    def get_context(self, name, value, attrs):'''

new = '''class ReadOnlyPasswordHashWidget(forms.Widget):
    template_name = 'auth/widgets/read_only_password_hash.html'
    read_only = True

    def id_for_label(self, id_):
        return None

    def get_context(self, name, value, attrs):'''

content = content.replace(old, new)

with open('django/contrib/auth/forms.py', 'w') as f:
    f.write(content)

print('Done')
""
