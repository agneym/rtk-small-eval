import os
os.environ['DJANGO_SETTINGS_MODULE'] = 'tests.test_sqlite'

import django
from django.conf import settings
settings.INSTALLED_APPS.append('tests.test_sqlite')
django.setup()

from django.db import models

# Test 1: Fields without a model (before contribute_to_class)
f1 = models.IntegerField()
f2 = models.IntegerField()
print(""Test 1: Fields without a model"")
print(f""  f1 == f2: {f1 == f2}"")  # Should be False (different creation_counter)
print(f""  hash(f1): {hash(f1)}"")
print(f""  hash(f2): {hash(f2)}"")
print(f""  f1 < f2: {f1 < f2}"")  # Should be True or False based on creation_counter
print()

# Test 2: Same field instance
print(""Test 2: Same field instance"")
print(f""  f1 == f1: {f1 == f1}"")  # Should be True
print()

# Test 3: Abstract model fields
class A(models.Model):
    class Meta:
        abstract = True
        app_label = 'test'
    myfield = models.IntegerField()
    otherfield = models.CharField(max_length=10)

class B(A):
    class Meta:
        app_label = 'test'

class C(A):
    class Meta:
        app_label = 'test'

b_myfield = B._meta.get_field('myfield')
c_myfield = C._meta.get_field('myfield')
b_otherfield = B._meta.get_field('otherfield')
c_otherfield = C._meta.get_field('otherfield')

print(""Test 3: Fields from different subclasses of abstract model"")
print(f""  B.myfield == C.myfield: {b_myfield == c_myfield}"")  # Should be False
print(f""  B.myfield == B.myfield: {b_myfield == b_myfield}"")  # Should be True
print(f""  B.myfield == B.otherfield: {b_myfield == b_otherfield}"")  # Should be False
print(f""  len({{b_myfield, c_myfield}}): {len({b_myfield, c_myfield})}"")  # Should be 2
print(f""  len({{b_myfield, b_otherfield}}): {len({b_myfield, b_otherfield})}"")  # Should be 2
print()

# Test 4: Sorting fields
fields = [c_myfield, b_myfield, b_otherfield, c_otherfield]
sorted_fields = sorted(fields)
print(""Test 4: Sorting works"")
print(f""  Original order: {[f.name for f in fields]}"")
print(f""  Sorted order: {[f.name for f in sorted_fields]}"")
print()

# Test 5: Field from same model but different creation counters
f3 = models.IntegerField()
f4 = models.IntegerField()
print(""Test 5: Different fields, no model"")
print(f""  f3 == f4: {f3 == f4}"")  # Should be False
print(f""  f3 < f4: {f3 < f4}"")  # Should be True
print()

# Test 6: Same field compared with non-field
print(""Test 6: Field compared with non-field"")
print(f""  f1 == 'hello': {f1 == 'hello'}"")  # Should be False
print(f""  f1 != 'hello': {f1 != 'hello'}"")  # Should be True
print()

