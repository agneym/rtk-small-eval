import io
from unittest.mock import patch
from django.core.management import call_command
from django.db import connection

# Test 1: Non-atomic migration should NOT have transaction wrappers
# (regardless of can_rollback_ddl)
print('=== Test 1: Non-atomic migration ===')
with patch.object(connection.features, 'can_rollback_ddl', False):
    out = io.StringIO()
    call_command('sqlmigrate', 'migrations', '0001', stdout=out, 
                 MIGRATION_MODULES={'migrations': 'migrations.test_migrations_non_atomic'})
    output = out.getvalue().lower()
    tx_start = connection.ops.start_transaction_sql().lower()
    tx_end = connection.ops.end_transaction_sql().lower()
    has_tx_start = tx_start in output if tx_start else False
    has_tx_end = tx_end in output if tx_end else False
    print(f'  Transaction start found: {has_tx_start}')
    print(f'  Transaction end found: {has_tx_end}')
    # Both should be absent for non-atomic migration
    assert not has_tx_start, 'Should NOT have transaction start for non-atomic migration'
    assert not has_tx_end, 'Should NOT have transaction end for non-atomic migration'
    print('  PASS')

# Test 2: Atomic migration with can_rollback_ddl=True should have wrappers
print()
print('=== Test 2: Atomic migration, can_rollback_ddl=True ===')
with patch.object(connection.features, 'can_rollback_ddl', True):
    out = io.StringIO()
    call_command('sqlmigrate', 'migrations', '0001', stdout=out)
    output = out.getvalue().lower()
    tx_start = connection.ops.start_transaction_sql().lower()
    tx_end = connection.ops.end_transaction_sql().lower()
    has_tx_start = tx_start in output if tx_start else False
    has_tx_end = tx_end in output if tx_end else False
    print(f'  Transaction start found: {has_tx_start}')
    print(f'  Transaction end found: {has_tx_end}')
    # Both should be present for atomic migration with rollback DDL support
    if tx_start:
        assert has_tx_start, 'Should have transaction start for atomic migration with rollback DDL'
    if tx_end:
        assert has_tx_end, 'Should have transaction end for atomic migration with rollback DDL'
    print('  PASS')

# Test 3: Atomic migration with can_rollback_ddl=False should NOT have wrappers
print()
print('=== Test 3: Atomic migration, can_rollback_ddl=False ===')
with patch.object(connection.features, 'can_rollback_ddl', False):
    out = io.StringIO()
    call_command('sqlmigrate', 'migrations', '0001', stdout=out)
    output = out.getvalue().lower()
    tx_start = connection.ops.start_transaction_sql().lower()
    tx_end = connection.ops.end_transaction_sql().lower()
    has_tx_start = tx_start in output if tx_start else False
    has_tx_end = tx_end in output if tx_end else False
    print(f'  Transaction start found: {has_tx_start}')
    print(f'  Transaction end found: {has_tx_end}')
    # Both should be absent for atomic migration without rollback DDL support
    assert not has_tx_start, 'Should NOT have transaction start for atomic migration without rollback DDL'
    assert not has_tx_end, 'Should NOT have transaction end for atomic migration without rollback DDL'
    print('  PASS')

print()
print('All tests passed!')
