2026-06-24T18:47:14+00:00,68e357d786cc4e14afc86d97141ef4e8,1,"cd /testbed && python << 'PYEOF'
import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')
import django
django.setup()

from django.db import models, connection
from django.db.migrations.state import ProjectState, ModelState
from django.db.migrations.operations.models import RenameModel, AddField

# Create a model with explicit db_table and an M2M field
model_state = ModelState('test_app', 'MyModel', [
    ('id', models.AutoField(primary_key=True)),
], {'db_table': 'my_custom_table'})

project_state = ProjectState()
project_state.models['test_app', 'mymodel'] = model_state

# Add a related model for M2M
related_state = ModelState('test_app', 'Tag', [
    ('id', models.AutoField(primary_key=True)),
], {})
project_state.models['test_app', 'tag'] = related_state

# Add M2M field
add_m2m = AddField('MyModel', 'tags', models.ManyToManyField('test_app.Tag'))
new_state = project_state.clone()
add_m2m.state_forwards('test_app', new_state)

# Now apply RenameModel
operation = RenameModel('MyModel', 'NewModelName')
final_state = new_state.clone()
operation.state_forwards('test_app', final_state)

# Verify
old_model = new_state.apps.get_model('test_app', 'MyModel')
new_model = final_state.apps.get_model('test_app', 'NewModelName')

print(f""Old db_table: {old_model._meta.db_table!r}"")
print(f""New db_table: {new_model._meta.db_table!r}"")
print(f""db_table unchanged: {old_model._meta.db_table == new_model._meta.db_table}"")

# Check M2M through tables
old_m2m_fields = old_model._meta.local_many_to_many
new_m2m_fields = new_model._meta.local_many_to_many

for old_f, new_f in zip(old_m2m_fields, new_m2m_fields):
    if new_f.model == new_f.related_model or not new_f.remote_field.through._meta.auto_created:
        print(""Skipping self-referential or non-auto-created M2M"")
        continue
    old_through = old_f.remote_field.through
    new_through = new_f.remote_field.through
    print(f""\nOld through table: {old_through._meta.db_table!r}"")
    print(f""New through table: {new_through._meta.db_table!r}"")
    print(f""Through table unchanged: {old_through._meta.db_table == new_through._meta.db_table}"")
    
    # Since db_table is explicitly set and doesn't change, through table
    # is based on db_table ('my_custom_table_tags'), which also doesn't change
    assert old_through._meta.db_table == new_through._meta.db_table
    print(""✓ alter_db_table for through table is skipped (noop)"")

    # Check M2M column names
    old_col = old_through._meta.get_field(old_model._meta.model_name)
    new_col = new_through._meta.get_field(new_model._meta.model_name)
    print(f""\nOld column name: {old_col.column!r}"")
    print(f""New column name: {new_col.column!r}"")
    print(f""Column name changed: {old_col.column != new_col.column}"")
    # Column names are based on model name, so they DO change
    assert old_col.column != new_col.column
    print(""✓ alter_field for M2M column still happens (column name based on model name)"")

print(""\nAll M2M checks passed!"")
PYEOF
