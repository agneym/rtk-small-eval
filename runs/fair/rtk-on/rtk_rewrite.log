new_method = '''    def database_forwards(self, app_label, schema_editor, from_state, to_state):
        new_model = to_state.apps.get_model(app_label, self.name)
        if self.allow_migrate_model(schema_editor.connection.alias, new_model):
            old_model = from_state.apps.get_model(app_label, self.name)
            # Delete old constraints using old_model to get the correct
            # column names when fields have changed (e.g. ForeignKey to
            # ManyToManyField).
            old_unique_together = getattr(old_model._meta, self.option_name, set())
            new_unique_together = getattr(new_model._meta, self.option_name, set())
            olds = {tuple(fields) for fields in old_unique_together}
            news = {tuple(fields) for fields in new_unique_together}
            # Delete old constraints (use old_model for column names)
            for fields in olds.difference(news):
                schema_editor._delete_composed_index(
                    old_model,
                    fields,
                    {""unique"": True, ""primary_key"": False}
                    if self.option_name == ""unique_together""
                    else {""index"": True, ""unique"": False},
                    schema_editor.sql_delete_unique
                    if self.option_name == ""unique_together""
                    else schema_editor.sql_delete_index,
                )
            # Create new constraints (use new_model for column names)
            for field_names in news.difference(olds):
                fields = [new_model._meta.get_field(field) for field in field_names]
                if self.option_name == ""unique_together"":
                    schema_editor.execute(
                        schema_editor._create_unique_sql(new_model, fields)
                    )
                else:
                    schema_editor.execute(
                        schema_editor._create_index_sql(
                            new_model, fields=fields, suffix=""_idx""
                        )
                    )'''

assert old_method in content, ""Could not find the old method""
