import os, sys
os.environ['DJANGO_SETTINGS_MODULE'] = 'test_settings'

import django
from django.conf import settings

if not settings.configured:
    settings.configure(
        DATABASES={
            'default': {
                'ENGINE': 'django.db.backends.sqlite3',
                'NAME': ':memory:',
            },
            'other': {
                'ENGINE': 'django.db.backends.sqlite3',
                'NAME': ':memory:',
            }
        },
        DATABASE_ROUTERS=[],
        INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
        DEFAULT_AUTO_FIELD='django.db.models.AutoField',
        SECRET_KEY='test-secret-key',
    )

django.setup()

from django.db import connections, router
from django.db.migrations.recorder import MigrationRecorder

print('=' * 60)
print('FIX VERIFICATION - User scenario from PR description')
print('=' * 60)
print()
print('User\'s router:')
print('  class Router(object):')
print('      def allow_migrate(self, db, model):')
print('          if db == \""default\"":')
print('              return True')
print('          return False')
print()

class UserRouter:
    def allow_migrate(self, db, app_label, model_name=None, **hints):
        if db == 'default':
            return True
        return False

router.routers = [UserRouter()]

# Test 1: ensure_schema on default (should work)
print('Test 1: ensure_schema on default database')
r_default = MigrationRecorder(connections['default'])
r_default.ensure_schema()
assert r_default.has_table(), 'Table should exist on default'
print('  ✓ django_migrations table created on default')
print()

# Test 2: ensure_schema on other (should NOT create table)
print('Test 2: ensure_schema on other database')
r_other = MigrationRecorder(connections['other'])
r_other.ensure_schema()
assert not r_other.has_table(), 'Table should NOT exist on other'
print('  ✓ django_migrations table NOT created on other')
print()

# Test 3: record_applied on default (should work)
print('Test 3: record_applied on default')
r_default.record_applied('myapp', '0001_initial')
migrations = r_default.applied_migrations()
assert ('myapp', '0001_initial') in migrations, 'Migration should be recorded on default'
print('  ✓ Migration recorded on default')
print()

# Test 4: record_applied on other (should NOT record)
print('Test 4: record_applied on other')
r_other.record_applied('myapp', '0001_initial')
migrations = r_other.applied_migrations()
assert ('myapp', '0001_initial') not in migrations, 'Migration should NOT be recorded on other'
print('  ✓ Migration NOT recorded on other')
print()

# Test 5: record_unapplied on default (should work)
print('Test 5: record_unapplied on default')
r_default.record_unapplied('myapp', '0001_initial')
migrations = r_default.applied_migrations()
assert ('myapp', '0001_initial') not in migrations, 'Migration should be unrecorded on default'
print('  ✓ Migration unrecorded on default')
print()

# Test 6: record_unapplied on other (should be no-op)
print('Test 6: record_unapplied on other')
r_other.record_unapplied('myapp', '0001_initial')
migrations = r_other.applied_migrations()
assert ('myapp', '0001_initial') not in migrations, 'Migration should still not be recorded'
print('  ✓ Unapplied is no-op (correct)')
print()

# Test 7: applied_migrations on default (empty after unapply)
print('Test 7: applied_migrations on default')
migrations = r_default.applied_migrations()
assert len(migrations) == 0, 'No migrations should be applied'
print('  ✓ No migrations applied on default')
print()

# Test 8: applied_migrations on other (empty since table does not exist)
print('Test 8: applied_migrations on other (table does not exist)')
migrations = r_other.applied_migrations()
assert len(migrations) == 0, 'No migrations should be applied'
print('  ✓ No migrations applied on other')
print()

print('=' * 60)
print('ALL TESTS PASSED!')
print('=' * 60)
""",
