with open('/testbed/django/db/migrations/autodetector.py', 'r') as f:
    content = f.read()

old = '''                    if to_field_rename_key in self.renamed_fields:
                        new_field.remote_field.field_name = old_field.remote_field.field_name'''

new = '''                    if to_field_rename_key in self.renamed_fields:
                        # If the old field_name was the primary key, the
                        # RenameField operation will handle updating the
                        # FK's to_field. Don't revert to the old name as
                        # that would create a spurious AlterField with the
                        # old to_field value.
                        if old_field.remote_field.field_name != old_field.remote_field.model._meta.pk.name:
                            new_field.remote_field.field_name = old_field.remote_field.field_name'''

if old in content:
    content = content.replace(old, new)
    with open('/testbed/django/db/migrations/autodetector.py', 'w') as f:
        f.write(content)
    print('Fix 2 applied successfully!')
else:
    print('Could not find the old text for Fix 2')
    # Debug
    import re
    escaped = re.escape(old)
    matches = list(re.finditer(escaped, content))
    print(f'Found {len(matches)} matches')
