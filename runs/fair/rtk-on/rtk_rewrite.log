import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    USE_TZ=True,
)
django.setup()

from django import forms

class TestForm(forms.Form):
    choices = forms.MultipleChoiceField(
        widget=forms.CheckboxSelectMultiple,
        choices=[('1', 'Option 1'), ('2', 'Option 2')],
    )

# Test 1: Default auto_id
form = TestForm()
bound_field = form['choices']
subwidgets = bound_field.subwidgets
print('Test 1 - Default auto_id:')
for sw in subwidgets:
    print(f'  id_for_label={sw.id_for_label!r}, attrs[id]={sw.data[\""attrs\""].get(\""id\"")!r}')

print()

# Test 2: Custom auto_id
class TestForm2(forms.Form):
    choices = forms.MultipleChoiceField(
        widget=forms.CheckboxSelectMultiple,
        choices=[('1', 'Option 1'), ('2', 'Option 2')],
    )

form2 = TestForm2(auto_id='myid_%s')
bound_field2 = form2['choices']
subwidgets2 = bound_field2.subwidgets
print('Test 2 - Custom auto_id (myid_%s):')
for sw in subwidgets2:
    print(f'  id_for_label={sw.id_for_label!r}, attrs[id]={sw.data[\""attrs\""].get(\""id\"")!r}')

print()

# Test 3: Custom widget attrs with id
class TestForm3(forms.Form):
    choices = forms.MultipleChoiceField(
        widget=forms.CheckboxSelectMultiple(attrs={'id': 'custom_id'}),
        choices=[('1', 'Option 1'), ('2', 'Option 2')],
    )

