import django
import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')
django.setup()

from django.db import models, connection
from django.db.models import Q

# Create a simple model to test with
class TestModel(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'

# Test 1: none() on normal queryset
qs = TestModel.objects.all()
print('Normal qs.none() SQL:', qs.none().query)

# Test 2: none() on | queryset
qs_or = TestModel.objects.filter(name='a') | TestModel.objects.filter(name='b')
print('OR qs.none() SQL:', qs_or.none().query)

# Test 3: none() on union queryset
qs_union = TestModel.objects.filter(name='a').union(TestModel.objects.filter(name='b'))
print('Union qs.none() SQL:', qs_union.none().query)

# Now let's see if the NothingNode is present
from django.db.models.sql.where import NothingNode

qs_union_none = qs_union.none()
print('Union none query has NothingNode in where:', any(isinstance(c, NothingNode) for c in qs_union_none.query.where.children))
print('Union none query is_empty:', qs_union_none.query.is_empty())

qs_or_none = qs_or.none()
print('OR none query has NothingNode in where:', any(isinstance(c, NothingNode) for c in qs_or_none.query.where.children))
print('OR none query is_empty:', qs_or_none.query.is_empty())
