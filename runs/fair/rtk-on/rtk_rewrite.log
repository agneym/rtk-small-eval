from enum import Enum, IntEnum
from django.db.migrations.serializer import serializer_factory

# Simulate what happens in a migration file - the enum class is
# defined in a module and imported.

# Let's test with a module-level enum
import sys

# Create a temporary module
class TestModule:
    pass

class Status(Enum):
    GOOD = 'Good'
    BAD = 'Bad'

class MyIntEnum(IntEnum):
    A = 1
    B = 2

# Test round-trip for regular enum
result, imports = serializer_factory(Status.GOOD).serialize()
print('Regular enum serialized:', result)

# Test round-trip for IntEnum
result2, imports2 = serializer_factory(MyIntEnum.B).serialize()
print('IntEnum serialized:', result2)

# Verify we can reconstruct by eval
# In a real migration, the module would be imported
# For __main__, we use the current module
import __main__
r1 = eval(result, {'__main__': __main__})
print('Reconstructed Status.GOOD:', r1, 'is same:', r1 is Status.GOOD)

r2 = eval(result2, {'__main__': __main__})
print('Reconstructed MyIntEnum.B:', r2, 'is same:', r2 is MyIntEnum.B)
""
