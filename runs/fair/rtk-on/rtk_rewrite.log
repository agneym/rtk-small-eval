from django.test import TestCase
from django.db.models import ExpressionWrapper, Value, IntegerField, Lower, Q, BooleanField
from django.db.models.functions import Lower

# Let's just import the test class and run a few tests
import unittest

# Simple test
from django.test import SimpleTestCase

class TestExpressionWrapper(SimpleTestCase):
    def test_repr(self):
        expr = ExpressionWrapper(Value(3), output_field=IntegerField())
        self.assertEqual(repr(expr), 'ExpressionWrapper(Value(3))')

    def test_no_source_expressions(self):
        expr = ExpressionWrapper(Value(3), output_field=IntegerField())
        self.assertEqual(expr.get_source_expressions(), [Value(3)])

suite = unittest.TestLoader().loadTestsFromTestCase(TestExpressionWrapper)
result = unittest.TextTestRunner(verbosity=2).run(suite)
print(f'Tests run: {result.testsRun}, Failures: {len(result.failures)}, Errors: {len(result.errors)}')
