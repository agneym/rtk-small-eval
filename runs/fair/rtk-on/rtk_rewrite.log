2026-06-24T10:54:07+00:00,7a575ed207fe40c2a3fc815e66e04a0c,1,"cd /testbed && python3 << 'EOF'
import sys
import os
import tempfile
import pathlib

# Test that iter_all_python_module_files includes __main__ file when running a script
# Since we're running with -c, __main__ doesn't have __file__ set, so let's test
# by simulating what happens when a script is run

from django.utils import autoreload

# Clear cache
autoreload.iter_modules_and_files.cache_clear()

# Get the list of files
files = set(autoreload.iter_all_python_module_files())

# Check that __main__ is NOT included (since __file__ is not set)
main = sys.modules.get('__main__')
main_file = getattr(main, '__file__', None)
print(f""__main__.__file__: {main_file!r}"")
print(f""Number of files: {len(files)}"")

# Now test with a mock module that has __spec__=None but __file__ set
import types

# Create a temporary file
tmpdir = tempfile.mkdtemp()
tmpfile = pathlib.Path(tmpdir) / 'test_script.py'
tmpfile.touch()

# Create a mock module with __spec__=None and __file__ set
mock_module = types.ModuleType('test_script')
mock_module.__file__ = str(tmpfile)
# Don't set __spec__ at all

# Test that iter_modules_and_files includes it
modules = (mock_module,)
extra = frozenset()
result = autoreload.iter_modules_and_files(modules, extra)
print(f""\nTest with mock __main__ module:"")
print(f""Module __spec__ exists: {hasattr(mock_module, '__spec__')}"")
print(f""Module __file__: {mock_module.__file__}"")
print(f""File in result: {pathlib.Path(str(tmpfile)).resolve().absolute() in result}"")

# Clean up
import shutil
shutil.rmtree(tmpdir)

print(""\nTest passed!"" if pathlib.Path(str(tmpfile)).resolve().absolute() in result else ""\nTest FAILED!"")
EOF",
