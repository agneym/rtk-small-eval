2026-06-24T10:54:54+00:00,7a575ed207fe40c2a3fc815e66e04a0c,1,"cd /testbed && python3 << 'EOF'
""""""
Integration test for the autoreloader fix.
Simulates what happens when manage.py is the __main__ script.
""""""
import sys
import tempfile
import os
import pathlib
import types

from django.utils import autoreload

# Clear any cached results
autoreload.iter_modules_and_files.cache_clear()

# Create a temporary ""manage.py""
tmpdir = tempfile.mkdtemp()
manage_py = pathlib.Path(tmpdir) / 'manage.py'
manage_py.touch()

# Simulate the __main__ module when running a script
# In Python, when you run `python manage.py`, __main__.__spec__ is None
# but __main__.__file__ is set to the script path.
main_module = types.ModuleType('__main__')
# Don't set __spec__ (types.ModuleType sets it to None by default)
main_module.__file__ = str(manage_py)

# Test that iter_modules_and_files picks it up
modules = (main_module,)
extra = frozenset()
result = autoreload.iter_modules_and_files(modules, extra)

expected = {manage_py.resolve().absolute()}
actual = result

print(f""Expected: {expected}"")
print(f""Actual: {actual}"")
print(f""Test passed: {expected == actual}"")

# Also test that the manage.py without __file__ doesn't get picked up
main_module_no_file = types.ModuleType('__main__')
# No __file__ set
result2 = autoreload.iter_modules_and_files((main_module_no_file,), extra)
print(f""\nWithout __file__, result: {result2}"")
print(f""Test passed (empty): {len(result2) == 0}"")

# Clean up
import shutil
shutil.rmtree(tmpdir)

print(""\n=== All tests passed! ==="")
EOF",
