import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
)

django.setup()

from django.db import models

# Test 3: Child class inheriting custom get_FOO_display from parent
class Parent(models.Model):
    status = models.IntegerField(choices=[(1, 'active'), (2, 'inactive')])
    
    def get_status_display(self):
        return ""parent_custom""
    
    class Meta:
        app_label = 'test3'

class Child(Parent):
    class Meta:
        app_label = 'test3'

obj3 = Child(status=1)
result3 = obj3.get_status_display()
print(f""Test 3 - Child inherits parent's custom display: {result3}"")
assert result3 == ""parent_custom"", f""Expected 'parent_custom', got '{result3}'""

# Test 4: Parent with no custom display, child with custom display
class Parent2(models.Model):
    status = models.IntegerField(choices=[(1, 'active'), (2, 'inactive')])
    
    class Meta:
        app_label = 'test4'

class Child2(Parent2):
    def get_status_display(self):
        return ""child_custom""
    
    class Meta:
        app_label = 'test4'

obj4 = Child2(status=1)
result4 = obj4.get_status_display()
print(f""Test 4 - Child overrides parent's auto display: {result4}"")
assert result4 == ""child_custom"", f""Expected 'child_custom', got '{result4}'""

# Also verify parent's behavior in test 4
obj4_parent = Parent2(status=1)
result4_parent = obj4_parent.get_status_display()
print(f""Test 4b - Parent's auto display: {result4_parent}"")
assert result4_parent == ""active"", f""Expected 'active', got '{result4_parent}'""

# Test 5: Multiple fields with choices
class MultiChoice(models.Model):
    field1 = models.IntegerField(choices=[(1, 'one'), (2, 'two')])
    field2 = models.IntegerField(choices=[(3, 'three'), (4, 'four')])
    
    def get_field1_display(self):
        return ""custom_one""
    
    class Meta:
        app_label = 'test5'

obj5 = MultiChoice(field1=1, field2=3)
result5a = obj5.get_field1_display()
result5b = obj5.get_field2_display()
print(f""Test 5a - Custom display for field1: {result5a}"")
print(f""Test 5b - Auto display for field2: {result5b}"")
assert result5a == ""custom_one"", f""Expected 'custom_one', got '{result5a}'""
assert result5b == ""three"", f""Expected 'three', got '{result5b}'""

print(""\nAll edge case tests passed!"")
EOF
