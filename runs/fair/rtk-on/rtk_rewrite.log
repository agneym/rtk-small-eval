for (al, mn), model_state in autodetector.to_state.models.items():
    for fname, field in model_state.fields:
        autodetector.new_field_keys.add((al, mn, fname))

print('old_field_keys:', autodetector.old_field_keys)
print('new_field_keys:', autodetector.new_field_keys)
print('new - old:', autodetector.new_field_keys - autodetector.old_field_keys)
print('old - new:', autodetector.old_field_keys - autodetector.new_field_keys)
print('old & new:', autodetector.old_field_keys & autodetector.new_field_keys)

