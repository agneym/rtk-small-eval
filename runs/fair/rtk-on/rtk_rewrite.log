import django
from django.conf import settings
settings.configure(
    DEBUG=True,
    ROOT_URLCONF='test_urls_mod',
    SECRET_KEY='test',
    MIDDLEWARE=[],
    ALLOWED_HOSTS=['testserver'],
)
django.setup()

from django.urls import path, register_converter
from django.http import Http404, HttpResponse
from django.urls.converters import StringConverter

# Test 1: Http404 raised in to_python results in 404 response
print('=== Test 1: Http404 in to_python ===')
class MyConverter(StringConverter):
    def to_python(self, value):
        raise Http404('Not found')

register_converter(MyConverter, 'myconv')

def my_view(request):
    return HttpResponse('Hello')

import sys
from types import ModuleType

mod = ModuleType('test_urls_mod')
mod.urlpatterns = [
    path('test/<myconv:value>/', my_view),
]
sys.modules['test_urls_mod'] = mod

from django.test.client import RequestFactory
from django.urls import set_urlconf, get_resolver, resolve
from django.core.handlers.exception import response_for_exception

factory = RequestFactory()
request = factory.get('/test/something/', HTTP_HOST='testserver')

set_urlconf(settings.ROOT_URLCONF)
resolver = get_resolver()
try:
    match = resolver.resolve(request.path_info)
    print('FAIL: Expected Http404, got match')
except Http404 as e:
    response = response_for_exception(request, e)
    print('Status:', response.status_code)
    content = response.content.decode() if isinstance(response.content, bytes) else response.content
    assert response.status_code == 404, 'Expected 404 status'
    assert 'Page not found' in content, 'Expected Page not found in response'
    print('PASS: Got 404 response with technical details')

# Test 2: ValueError still works as before (no match)
print()
print('=== Test 2: ValueError in to_python ===')
class ValueErrorConverter(StringConverter):
    def to_python(self, value):
        raise ValueError('Invalid')

register_converter(ValueErrorConverter, 'valerr')

mod2 = ModuleType('test_urls_mod2')
mod2.urlpatterns = [
    path('test/<valerr:value>/', my_view),
]
sys.modules['test_urls_mod2'] = mod2

from django.urls import set_urlconf
# Need to use a fresh settings
settings.ROOT_URLCONF = 'test_urls_mod2'
set_urlconf('test_urls_mod2')
from django.urls import get_resolver
resolver2 = get_resolver()

request2 = factory.get('/test/something/', HTTP_HOST='testserver')
try:
    match = resolver2.resolve(request2.path_info)
    print('FAIL: Expected Resolver404, got match')
except Resolver404 as e:
    print('Got Resolver404 as expected')
    print('PASS: ValueError still causes no match')

# Test 3: Normal converters still work
print()
print('=== Test 3: Normal converter ===')
settings.ROOT_URLCONF = 'test_urls_mod3'
set_urlconf('test_urls_mod3')
mod3 = ModuleType('test_urls_mod3')
mod3.urlpatterns = [
    path('test/<int:value>/', my_view),
]
sys.modules['test_urls_mod3'] = mod3

resolver3 = get_resolver()
request3 = factory.get('/test/42/', HTTP_HOST='testserver')
match = resolver3.resolve(request3.path_info)
print('Match:', match)
assert match is not None
assert match.kwargs == {'value': 42}
print('PASS: Normal int converter works')

# Test 4: Multiple patterns, Http404 on second pattern
print()
print('=== Test 4: Multiple patterns ===')
class Raise404Converter(StringConverter):
    def to_python(self, value):
        raise Http404('Not found')

register_converter(Raise404Converter, 'r404')

def view_a(request):
    return HttpResponse('A')
def view_b(request):
    return HttpResponse('B')

mod4 = ModuleType('test_urls_mod4')
mod4.urlpatterns = [
    path('articles/<r404:slug>/', view_a),
    path('articles/<slug:slug>/', view_b),
]
sys.modules['test_urls_mod4'] = mod4

settings.ROOT_URLCONF = 'test_urls_mod4'
set_urlconf('test_urls_mod4')
resolver4 = get_resolver()
request4 = factory.get('/articles/hello-world/', HTTP_HOST='testserver')
try:
    match = resolver4.resolve(request4.path_info)
    # The second pattern should match since the first raised Http404
    print('Match:', match)
    print('Match func:', match.func)
    assert match.func == view_b, 'Expected view_b to match'
    print('PASS: Falls through to next pattern')
except Http404 as e:
    print('Got Http404:', e)
    # This might also be acceptable if the first pattern caught and 
    # the second didn't match
    print('NOTE: Got Http404, which is also a valid outcome')

# Test 5: TypeErrors still propagate
print()
print('=== Test 5: TypeError in to_python ===')
class TypeErrorConverter(StringConverter):
    def to_python(self, value):
        raise TypeError('Type error')

register_converter(TypeErrorConverter, 'terr')

mod5 = ModuleType('test_urls_mod5')
mod5.urlpatterns = [
    path('test/<terr:value>/', my_view),
]
sys.modules['test_urls_mod5'] = mod5

settings.ROOT_URLCONF = 'test_urls_mod5'
set_urlconf('test_urls_mod5')
resolver5 = get_resolver()
request5 = factory.get('/test/something/', HTTP_HOST='testserver')
try:
    match = resolver5.resolve(request5.path_info)
    print('FAIL: Expected TypeError')
except TypeError as e:
    print('Got TypeError:', e)
    print('PASS: TypeError still propagates')

print()
print('All tests passed!')
