2026-06-24T09:33:01+00:00,f473ef7b50424a10b5a3cabe2a7bfff4,1,"cd /testbed && python -c ""
from astropy.table import QTable, Table
import astropy.units as u
from astropy.io.ascii import read
import sys
import io

# Write and then read back
tbl = QTable({'wave': [350, 950]*u.nm, 'response': [0.7, 1.2]*u.count})

# Write with header_rows
out = io.StringIO()
tbl.write(out, format='ascii.rst', header_rows=['name', 'unit'])
content = out.getvalue()
print('Written content:')
print(content)

# Read it back
print('Read back:')
result = read(content, format='rst')
print(result)
print('Column names:', result.colnames)

# Now also check that reading the default format still works
print()
print('=== Reading default RST format ===')
out2 = io.StringIO()
tbl.write(out2, format='ascii.rst')
content2 = out2.getvalue()
print(content2)
result2 = read(content2, format='rst')
print(result2)
""
