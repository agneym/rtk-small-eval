import django
from django.conf import settings
from django.urls import set_script_prefix, get_script_prefix

# Configure settings
settings.configure(
    INSTALLED_APPS=['django.contrib.staticfiles'],
    STATIC_URL='/static/',
    MEDIA_URL='/media/',
    STATIC_ROOT='/tmp/static_root',
    FORCE_SCRIPT_NAME='/app',
    DATABASES={},
    TEMPLATES=[{
        'BACKEND': 'django.template.backends.django.DjangoTemplates',
        'DIRS': [],
        'APP_DIRS': True,
        'OPTIONS': {},
    }],
)
django.setup()

from django.template import Context, Template
from django.template.engine import Engine
from django.contrib.staticfiles.storage import staticfiles_storage
from django.core.files.storage import FileSystemStorage
from django.templatetags.static import PrefixNode, static as static_fn

engine = Engine.get_default()

all_passed = True

def check(name, actual, expected):
    global all_passed
    ok = actual == expected
    status = ""PASS"" if ok else ""FAIL""
    if not ok:
        all_passed = False
    print(f""{status}: {name}"")
    print(f""  Actual:   {actual!r}"")
    print(f""  Expected: {expected!r}"")

# ===== Test with SCRIPT_NAME = '/app/' =====

print(""\n=== Testing with SCRIPT_NAME='/app/' (FORCE_SCRIPT_NAME='/app') ==="")

# Test 1: {% static %} tag
t = engine.from_string('{% load static %}{% static ""test.css"" %}')
result = t.render(Context())
check(""{% static 'test.css' %}"", result, ""/app/static/test.css"")

# Test 2: {% get_static_prefix %}
t = engine.from_string('{% load static %}{% get_static_prefix %}')
result = t.render(Context())
check(""{% get_static_prefix %}"", result, ""/app/static/"")

# Test 3: {% get_media_prefix %}
t = engine.from_string('{% load static %}{% get_media_prefix %}')
result = t.render(Context())
check(""{% get_media_prefix %}"", result, ""/app/media/"")

# Test 4: staticfiles_storage.url()
result = staticfiles_storage.url('test.css')
check(""staticfiles_storage.url('test.css')"", result, ""/app/static/test.css"")

# Test 5: FileSystemStorage.url()
fs = FileSystemStorage(location='/tmp', base_url='/media/')
result = fs.url('test.jpg')
check(""FileSystemStorage.url('test.jpg')"", result, ""/app/media/test.jpg"")

# Test 6: static() function
result = static_fn('test.css')
check(""static('test.css')"", result, ""/app/static/test.css"")

# Test 7: {% static %} with 'as' variable
t = engine.from_string('{% load static %}{% static ""test.css"" as var %}{{ var }}')
result = t.render(Context())
check(""{% static 'test.css' as var %}{{ var }}"", result, ""/app/static/test.css"")

# Test 8: {% get_static_prefix as var %}
t = engine.from_string('{% load static %}{% get_static_prefix as p %}{{ p }}')
result = t.render(Context())
check(""{% get_static_prefix as p %}{{ p }}"", result, ""/app/static/"")

# ===== Test with NO SCRIPT_NAME =====

print(""\n=== Testing without SCRIPT_NAME (default '/') ==="")

# We need to simulate the default state. Let's manually set the script prefix to '/'
set_script_prefix('/')

# Test 1: {% static %} tag
result = engine.from_string('{% load static %}{% static ""test.css"" %}').render(Context())
check(""{% static 'test.css' %}"", result, ""/static/test.css"")

# Test 2: get_static_prefix
result = engine.from_string('{% load static %}{% get_static_prefix %}').render(Context())
check(""{% get_static_prefix %}"", result, ""/static/"")

# Test 3: staticfiles_storage.url()
result = staticfiles_storage.url('test.css')
check(""staticfiles_storage.url('test.css')"", result, ""/static/test.css"")

# Test 4: static() function
result = static_fn('test.css')
check(""static('test.css')"", result, ""/static/test.css"")

# ===== Test with absolute URL STATIC_URL =====

print(""\n=== Testing with absolute STATIC_URL (CDN) ==="")

# Set script prefix back to /app/
set_script_prefix('/app/')

# We can't change STATIC_URL after setup, but we can test PrefixNode.handle_simple directly
# and the storage separately

# Test FileSystemStorage with absolute base_url
fs_abs = FileSystemStorage(location='/tmp', base_url='http://cdn.example.com/static/')
result = fs_abs.url('test.css')
check(""FileSystemStorage.url() with CDN base_url"", result, ""http://cdn.example.com/static/test.css"")

# ===== Test with MEDIA_URL =====

print(""\n=== Testing MEDIA_URL support ==="")

set_script_prefix('/app/')
fs_media = FileSystemStorage(location='/tmp', base_url='/media/')
result = fs_media.url('photo.jpg')
check(""FileSystemStorage.url() for media"", result, ""/app/media/photo.jpg"")

# ===== Summary =====

print(f""\n{'='*40}"")
if all_passed:
    print(""ALL TESTS PASSED!"")
else:
    print(""SOME TESTS FAILED!"")
print(f""{'='*40}"")
