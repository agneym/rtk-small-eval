with open('django/db/models/fields/__init__.py', 'r', encoding='utf-8') as f:
    content = f.read()

# Fix __lt__ to handle model comparison properly
old_lt = '''    def __lt__(self, other):
        # This is needed because bisect does not take a comparison function.
        if isinstance(other, Field):
            if self.creation_counter != other.creation_counter:
                return self.creation_counter < other.creation_counter
            return (
                getattr(self, 'model', None) or 'None'
            ) < (
                getattr(other, 'model', None) or 'None'
            )
        return NotImplemented'''

new_lt = '''    def __lt__(self, other):
        # This is needed because bisect does not take a comparison function.
        if isinstance(other, Field):
            if self.creation_counter != other.creation_counter:
                return self.creation_counter < other.creation_counter
            return (
                (self.model.__module__, self.model.__qualname__)
                if hasattr(self, 'model')
                else ('', '')
            ) < (
                (other.model.__module__, other.model.__qualname__)
                if hasattr(other, 'model')
                else ('', '')
            )
        return NotImplemented'''

content = content.replace(old_lt, new_lt)

with open('django/db/models/fields/__init__.py', 'w', encoding='utf-8') as f:
    f.write(content)

print('Done')
