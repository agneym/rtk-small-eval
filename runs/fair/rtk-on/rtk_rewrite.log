from django.urls import path, register_converter
from django.http import Http404, HttpResponse
from django.urls.converters import StringConverter
from django.urls.exceptions import Resolver404

# Test 1: Http404 raised in to_python results in 404 response
print('=== Test 1: Http404 in to_python ===')
class MyConverter(StringConverter):
    def to_python(self, value):
        raise Http404('Not found')

register_converter(MyConverter, 'myconv')

def my_view(request):
    return HttpResponse('Hello')

import sys
from types import ModuleType

mod = ModuleType('test_urls_mod')
mod.urlpatterns = [
    path('test/<myconv:value>/', my_view),
]
sys.modules['test_urls_mod'] = mod

from django.test.client import RequestFactory
from django.urls import set_urlconf, get_resolver, resolve
from django.core.handlers.exception import response_for_exception

factory = RequestFactory()
request = factory.get('/test/something/', HTTP_HOST='testserver')

set_urlconf(settings.ROOT_URLCONF)
resolver = get_resolver()
try:
    match = resolver.resolve(request.path_info)
    print('FAIL: Expected Http404, got match')
except Http404 as e:
    response = response_for_exception(request, e)
    print('Status:', response.status_code)
    content = response.content.decode() if isinstance(response.content, bytes) else response.content
    assert response.status_code == 404, 'Expected 404 status'
    assert 'Page not found' in content, 'Expected Page not found in response'
    print('PASS: Got 404 response with technical details')

