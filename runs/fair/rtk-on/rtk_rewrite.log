    DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
)
django.setup()

from django.db import models, connection
from django.db.models import Q, ExpressionWrapper, BooleanField, Value, F, Case, When
from django.db.models.functions import Lower

class TestModel(models.Model):
    name = models.CharField(max_length=100)
    age = models.IntegerField(default=0)
    class Meta:
        app_label = 'test'

qs = TestModel.objects.all()

# Test 1: Simple ExpressionWrapper with a field
print('=== F(\""age\"") ===')
print(qs.annotate(foo=ExpressionWrapper(F('age'), output_field=BooleanField())).values('foo').query)

# Test 2: ExpressionWrapper with a regular Q
print()
print('=== Q(age__gt=5) ===')
print(qs.annotate(foo=ExpressionWrapper(Q(age__gt=5), output_field=BooleanField())).values('foo').query)

# Test 3: ExpressionWrapper with ~Q(age__gt=5)
print()
print('=== ~Q(age__gt=5) ===')
print(qs.annotate(foo=ExpressionWrapper(~Q(age__gt=5), output_field=BooleanField())).values('foo').query)

# Test 4: ExpressionWrapper with combined Q
print()
print('=== Q(age__gt=5) | Q(age__lt=3) ===')
print(qs.annotate(foo=ExpressionWrapper(Q(age__gt=5) | Q(age__lt=3), output_field=BooleanField())).values('foo').query)

# Test 5: ExpressionWrapper with Q(pk__in=[]) - actually run the query
from django.db import connection as db_connection
with db_connection.schema_editor() as schema_editor:
    schema_editor.create_model(TestModel)

# Insert a test record
TestModel.objects.create(name='test', age=10)

print()
print('=== Query execution: ExpressionWrapper(~Q(pk__in=[])) ===')
result = TestModel.objects.annotate(
    foo=ExpressionWrapper(~Q(pk__in=[]), output_field=BooleanField())
).values('foo').first()
print(f'Result: {result}')

# Test 6: ExpressionWrapper(Q(pk__in=[])) 
print()
print('=== Query execution: ExpressionWrapper(Q(pk__in=[])) ===')
result = TestModel.objects.annotate(
    foo=ExpressionWrapper(Q(pk__in=[]), output_field=BooleanField())
).values('foo').first()
print(f'Result: {result}')
