import os
import sys
sys.path.insert(0, 'tests')

os.environ['DJANGO_SETTINGS_MODULE'] = 'test_sqlite'

import django
from django.conf import settings
settings.DATABASES['default']['NAME'] = ':memory:'

django.setup()

from django.db import connection
from django.db.migrations.state import ProjectState, ModelState
import django.db.models as models

# Check what suffix different model options use
print(""Checking auto-generated index names..."")

app_label = 'test_suffix'
project_state = ProjectState()

# Case 1: index_together
model_state_1 = ModelState(
    app_label,
    'Pony',
    [
        ('id', models.AutoField(primary_key=True)),
        ('pink', models.IntegerField(default=3)),
        ('weight', models.FloatField()),
    ],
    options={
        'index_together': {('weight', 'pink')},
    },
)
project_state.add_model(model_state_1)

# Create table
with connection.schema_editor() as editor:
    for model in project_state.apps.get_models():
        editor.create_model(model)

model = project_state.apps.get_model(app_label, 'Pony')
table_name = model._meta.db_table

with connection.cursor() as cursor:
    cursor.execute(f""SELECT name FROM sqlite_master WHERE type='index' AND tbl_name='{table_name}' AND name NOT LIKE 'sqlite_%'"")
    indexes = [r[0] for r in cursor.fetchall()]
    print(f""index_together DB indexes: {indexes}"")

with connection.schema_editor() as editor:
    computed = editor._create_index_name(table_name, ['weight', 'pink'], suffix=""_idx"")
    print(f""_create_index_name (suffix='_idx'): {computed}"")
    print(f""Match: {computed == indexes[0] if indexes else 'N/A'}"")

# Clean up
with connection.schema_editor() as editor:
    editor.delete_model(model)

# Case 2: unique_together
app_label2 = 'test_suffix2'
project_state2 = ProjectState()
model_state_2 = ModelState(
    app_label2,
    'Pony',
    [
        ('id', models.AutoField(primary_key=True)),
        ('pink', models.IntegerField(default=3)),
        ('weight', models.FloatField()),
    ],
    options={
        'unique_together': {('pink', 'weight')},
    },
)
project_state2.add_model(model_state_2)

with connection.schema_editor() as editor:
    for model in project_state2.apps.get_models():
        editor.create_model(model)

model2 = project_state2.apps.get_model(app_label2, 'Pony')
table_name2 = model2._meta.db_table

with connection.cursor() as cursor:
    cursor.execute(f""SELECT name FROM sqlite_master WHERE type='index' AND tbl_name='{table_name2}' AND name NOT LIKE 'sqlite_%'"")
    indexes2 = [r[0] for r in cursor.fetchall()]
    print(f""\nunique_together DB indexes: {indexes2}"")

# Check what constraint_names returns with index=True
with connection.schema_editor() as editor:
    matching = editor._constraint_names(
        model2, column_names=['pink', 'weight'], index=True
    )
    print(f""_constraint_names (index=True): {matching}"")

# What about with unique=True?
with connection.schema_editor() as editor:
    matching = editor._constraint_names(
        model2, column_names=['pink', 'weight'], unique=True
    )
    print(f""_constraint_names (unique=True): {matching}"")

# What about both?
with connection.schema_editor() as editor:
    matching = editor._constraint_names(
        model2, column_names=['pink', 'weight'], index=True, unique=True
    )
    print(f""_constraint_names (index=True, unique=True): {matching}"")

# Clean up
with connection.schema_editor() as editor:
    editor.delete_model(model2)

print(""\nDone!"")
EOF
