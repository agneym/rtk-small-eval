2026-06-24T20:03:28+00:00,ee4046ac48d3433da32b6fc129e56572,1,"cd /testbed && python -c ""
from django.views.static import was_modified_since
import time
from django.utils.http import http_date

# Test with empty string (should return True - treated as modified)
result = was_modified_since('')
print(f'Empty string result: {result}')
assert result == True, f'Expected True, got {result}'

# Test with None (should return True - treated as modified)
result = was_modified_since(None)
print(f'None result: {result}')
assert result == True, f'Expected True, got {result}'

# Test with valid date and current mtime - file NOT modified
now = time.time()
valid_date = http_date(now)
result = was_modified_since(valid_date, mtime=now, size=100)
print(f'Valid date, same mtime: {result}')
assert result == False, f'Expected False (not modified), got {result}'

# Test with valid date but older mtime - file NOT modified (mtime <= header)
old_mtime = 0
result = was_modified_since(valid_date, mtime=old_mtime, size=100)
print(f'Valid date, older mtime: {result}')
assert result == False, f'Expected False (not modified), got {result}'

# Test with invalid date (bogus)
result = was_modified_since('Mon, 28 May 999999999999 28:25:26 GMT')
print(f'Invalid date result: {result}')
assert result == True, f'Expected True, got {result}'

print('All tests passed!')
""
