import django
import os
os.environ['DJANGO_ALLOW_ASYNC_UNSAFE'] = 'true'
import sys
sys.path.insert(0, '/testbed')

import django.conf
django.conf.settings.configure(
    DATABASES={
        'default': {
            'ENGINE': 'django.db.backends.sqlite3',
            'NAME': ':memory:',
        },
    },
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.AutoField',
)
django.setup()

from django.db import models, connection

class Product(models.Model):
    sku = models.CharField(primary_key=True, max_length=50)
    class Meta:
        app_label = 'test_app'

class Order(models.Model):
    product = models.ForeignKey(Product, on_delete=models.CASCADE)
    class Meta:
        app_label = 'test_app'

# Check the defaults
print(""Product._meta.pk:"", Product._meta.pk)
print(""Product._meta.pk.default:"", repr(Product._meta.pk.default))
print(""Product._meta.pk.get_default():"", repr(Product._meta.pk.get_default()))

# Check the FK field
for f in Order._meta.concrete_fields:
    if f.name == 'product':
        print(f""\nOrder FK field: {f}"")
        print(f""FK attname: {f.attname}"")
        print(f""FK default: {repr(f.default)}"")

# Check what happens with assignment
p = Product()
print(f""\nProduct() pk: {repr(p.pk)}"")
print(f""Product()._state.adding: {p._state.adding}"")

# The FK field value after assignment
o = Order()
o.product = p
print(f""\nAfter order.product = Product():"")
print(f""order.product_id: {repr(o.product_id)}"")
print(f""order.product_id is None: {o.product_id is None}"")

# Now modify the product
p.sku = ""foo""
print(f""\nAfter product.sku = 'foo':"")
print(f""product.pk: {repr(p.pk)}"")
print(f""order.product_id: {repr(o.product_id)}"")

# Now save the product
p.save()
print(f""\nAfter product.save():"")
print(f""product.pk: {repr(p.pk)}"")
print(f""order.product_id: {repr(o.product_id)}"")
print(f""order.product: {o.product}"")

# Check what _prepare_related_fields_for_save does
print(f""\nChecking _prepare_related_fields_for_save conditions:"")
for field in o._meta.concrete_fields:
    if field.is_relation and field.is_cached(o):
        obj = getattr(o, field.name, None)
        print(f""  field: {field.name}"")
        print(f""  obj: {obj}"")
        print(f""  obj.pk: {repr(obj.pk)}"")
        print(f""  obj.pk is None: {obj.pk is None}"")
        print(f""  getattr(o, field.attname): {repr(getattr(o, field.attname))}"")
        print(f""  getattr(o, field.attname) is None: {getattr(o, field.attname) is None}"")
        print(f""  obj._state.adding: {obj._state.adding}"")
        print(f""  field.target_field.attname: {field.target_field.attname}"")
        print(f""  getattr(obj, field.target_field.attname): {repr(getattr(obj, field.target_field.attname))}"")
        print(f""  match: {getattr(obj, field.target_field.attname) == getattr(o, field.attname)}"")
