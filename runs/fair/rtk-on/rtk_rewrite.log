from functools import wraps
from django.utils.decorators import method_decorator

# Test 1: Multiple decorators
def logger1(func):
    @wraps(func)
    def inner(*args, **kwargs):
        print(f'logger1: {func.__name__}')
        return func(*args, **kwargs)
    return inner

def logger2(func):
    @wraps(func)
    def inner(*args, **kwargs):
        print(f'logger2: {func.__name__}')
        return func(*args, **kwargs)
    return inner

class Test1:
    @method_decorator([logger1, logger2])
    def hello(self):
        return 'hello'

t1 = Test1()
print('Test 1 - Multiple decorators:', t1.hello())
print()

# Test 2: Decorator that checks __module__
def check_module(func):
    @wraps(func)
    def inner(*args, **kwargs):
        print(f'module: {func.__module__}, qualname: {func.__qualname__}')
        return func(*args, **kwargs)
    return inner

class Test2:
    @method_decorator(check_module)
    def hello(self):
        return 'hello'

t2 = Test2()
print('Test 2 - Module and qualname:', t2.hello())
print()

# Test 3: Decorating a standalone function
@method_decorator(logger1)
def standalone():
    return 'standalone'

print('Test 3 - Standalone:', standalone())
print()

# Test 4: Using method_decorator on a class
class Test4:
    def hello(self):
        return 'hello'

Test4 = method_decorator(logger1, name='hello')(Test4)
t4 = Test4()
print('Test 4 - Class decoration:', t4.hello())
