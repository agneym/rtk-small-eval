from django.utils.cache import get_conditional_response
from django.http import HttpRequest, HttpResponse

# Test with empty If-Modified-Since header
request = HttpRequest()
request.META['HTTP_IF_MODIFIED_SINCE'] = ''
request.META['REQUEST_METHOD'] = 'GET'
response = HttpResponse(status=200)
response['Last-Modified'] = 'Mon, 28 May 2023 12:00:00 GMT'

try:
    result = get_conditional_response(request, last_modified=1685275200, response=response)
    print(f'Empty If-Modified-Since header result status: {result.status_code}')
    print('SUCCESS: Empty string handled without exception')
except Exception as e:
    print(f'ERROR: {type(e).__name__}: {e}')
""
