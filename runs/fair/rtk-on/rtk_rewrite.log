import base64

from django.conf import settings
settings.configure(
    SECRET_KEY='test-secret-key',
    SESSION_SERIALIZER='django.contrib.sessions.serializers.JSONSerializer',
    DEFAULT_HASHING_ALGORITHM='sha1',
)

from django.contrib.sessions.backends.base import SessionBase

class SimpleSessionStore(SessionBase):
    def exists(self, session_key):
        return False
    def create(self):
        pass
    def save(self, must_create=False):
        pass
    def delete(self, session_key=None):
        pass
    def load(self):
        return {}

store = SimpleSessionStore()

# Test 1: Invalid base64 data (incorrect padding)
try:
    result = store._legacy_decode('invalid-base64!!!')
    print('Test 1 - No exception raised, result:', result)
except Exception as e:
    print('Test 1 - Exception raised:', type(e).__name__, str(e))

# Test 2: Try decode method directly (invalid base64 data)
try:
    result = store.decode('invalid-base64!!!')
    print('Test 2 - No exception raised, result:', result)
except Exception as e:
    print('Test 2 - Exception raised:', type(e).__name__, str(e))

# Test 3: Valid legacy encoded data (should still work)
data = {'test': 'value'}
encoded = store._legacy_encode(data)
print('Test 3 - Encoded:', encoded)
try:
    result = store._legacy_decode(encoded)
    print('Test 3 - Decoded result:', result)
    print('Test 3 - Match:', result == data)
except Exception as e:
    print('Test 3 - Exception raised:', type(e).__name__, str(e))

# Test 4: Empty string
try:
    result = store._legacy_decode('')
    print('Test 4 - Empty string result:', result)
except Exception as e:
    print('Test 4 - Exception raised:', type(e).__name__, str(e))

# Test 5: Corrupted data (valid base64 but invalid format)
corrupted = base64.b64encode(b'not-valid-format').decode('ascii')
try:
    result = store._legacy_decode(corrupted)
    print('Test 5 - Corrupted data result:', result)
except Exception as e:
    print('Test 5 - Exception raised:', type(e).__name__, str(e))

print()
print('All tests passed!')
""
