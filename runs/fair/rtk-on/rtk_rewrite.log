import django
from django.conf import settings
settings.configure(DEFAULT_CHARSET='utf-8')

from django.http import HttpResponse

# String content
response = HttpResponse('My Content')
print('String:', repr(response.content))
assert response.content == b'My Content', f'Expected b\""My Content\"", got {response.content}'

# Bytes content
response = HttpResponse(b'My Content')
print('Bytes:', repr(response.content))
assert response.content == b'My Content', f'Expected b\""My Content\"", got {response.content}'

# memoryview content
response = HttpResponse(memoryview(b'My Content'))
print('memoryview:', repr(response.content))
assert response.content == b'My Content', f'Expected b\""My Content\"", got {response.content}'

print()
print('All tests passed!')

# Additional edge cases
print()
print('Edge cases:')

# Empty memoryview
response = HttpResponse(memoryview(b''))
print('Empty memoryview:', repr(response.content))
assert response.content == b'', f'Expected b\""\"", got {response.content}'

# memoryview in iterable (list)
response = HttpResponse([memoryview(b'Hello '), memoryview(b'World')])
print('List of memoryviews:', repr(response.content))
assert response.content == b'Hello World', f'Expected b\""Hello World\"", got {response.content}'

# Nested with bytes
response = HttpResponse([b'Hello ', memoryview(b'World')])
print('Mixed bytes/memoryview:', repr(response.content))
assert response.content == b'Hello World', f'Expected b\""Hello World\"", got {response.content}'

print()
print('All edge case tests passed!')
