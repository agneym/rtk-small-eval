    DATABASES={
        'default': {
            'ENGINE': 'django.db.backends.sqlite3',
            'NAME': ':memory:',
        },
    },
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.AutoField',
)
django.setup()

from django.db import models, connection, transaction
from django.db.models import ForeignKey, CASCADE, CharField

# Create test models
class Product(models.Model):
    sku = models.CharField(primary_key=True, max_length=50)
    name = models.CharField(max_length=100, default='')

    class Meta:
        app_label = 'test_app'

class Order(models.Model):
    product = ForeignKey(Product, on_delete=CASCADE)
    description = models.CharField(max_length=100, default='')

    class Meta:
        app_label = 'test_app'

# Create tables
with connection.schema_editor() as schema_editor:
    schema_editor.create_model(Product)
    schema_editor.create_model(Order)

# Test 1: Non-numeric PK, set PK after assignment
print(""Test 1: Non-numeric PK, set PK after assignment"")
try:
    with transaction.atomic():
        order = Order()
        order.product = Product()
        print(f""  After assignment: product_id = '{order.product_id}' (len={len(order.product_id)})"")
        order.product.sku = ""foo""
        print(f""  After setting sku: product_id = '{order.product_id}' (len={len(order.product_id)})"")
        order.product.save()
        print(f""  After product.save(): product_id = '{order.product_id}' (len={len(order.product_id)})"")
        order.save()
        print(f""  After order.save(): product_id = '{order.product_id}' (len={len(order.product_id)})"")
        print(f""  Order.objects.filter(product_id='').exists() = {Order.objects.filter(product_id='').exists()}"")
        print(f""  Order.objects.filter(product=order.product).exists() = {Order.objects.filter(product=order.product).exists()}"")
except Exception as e:
    print(f""  Exception: {type(e).__name__}: {e}"")

# Test 2: Non-numeric PK, set PK before assignment
print(""\nTest 2: Non-numeric PK, set PK before assignment"")
try:
    with transaction.atomic():
        order = Order()
        order.product = Product(sku=""foo"")
        print(f""  After assignment: product_id = '{order.product_id}'"")
        order.product.save()
        order.save()
        print(f""  Order.objects.filter(product=order.product).exists() = {Order.objects.filter(product=order.product).exists()}"")
except Exception as e:
    print(f""  Exception: {type(e).__name__}: {e}"")

# Clean up
with connection.schema_editor() as schema_editor:
    schema_editor.delete_model(Order)
    schema_editor.delete_model(Product)
EOF
