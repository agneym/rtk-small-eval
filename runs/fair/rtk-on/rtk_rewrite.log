from django.db import models
from django import forms

# Create models
class Publication(models.Model):
    class Meta:
        app_label = 'test'

class Article(models.Model):
    publications = models.ManyToManyField(to=Publication, blank=True, null=True)
    class Meta:
        app_label = 'test'

# Simulate the form behavior
# When a ModelMultipleChoiceField with a union queryset is submitted empty,
# it calls .none() on the queryset to get the values to save

# Create the queryset
qs_union = Publication.objects.filter(id__lt=2).union(Publication.objects.filter(id__gt=5))
print('Union queryset:', qs_union)
print()

# This is what happens when form is submitted empty
try:
    none_qs = qs_union.none()
    print('none() returned:', none_qs)
    print('Count:', none_qs.count())
except Exception as e:
    print(f'Error: {type(e).__name__}: {e}')

# Also test with OR for comparison
qs_or = Publication.objects.filter(id__lt=2) | Publication.objects.filter(id__gt=5)
print()
print('OR queryset:', qs_or)
try:
    none_qs = qs_or.none()
    print('none() returned:', none_qs)
    print('Count:', none_qs.count())
except Exception as e:
    print(f'Error: {type(e).__name__}: {e}')
