from datetime import datetime

# Verify: in 2026
# year 70 -> 2070, 2070-2026=44 <=50 -> 2070
# year 99 -> 2099, 2099-2026=73 >50 -> 1999
# year 37 -> 2037, 2037-2026=11 <=50 -> 2037
# year 94 -> 2094, 2094-2026=68 >50 -> 1994

current_year = datetime.now().year
print(f'Current year: {current_year}')

for y in [70, 99, 37, 94, 0, 24]:
    yr = y
    yr += current_year - (current_year % 100)
    if yr - current_year > 50:
        yr -= 100
    print(f'Year {y} -> {yr}')
