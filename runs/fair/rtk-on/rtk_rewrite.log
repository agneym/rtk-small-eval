import django
from django.conf import settings
from django.urls import re_path, resolve
from django.http import HttpResponse

settings.configure(
    ROOT_URLCONF=__name__,
    DEBUG=True,
    ALLOWED_HOSTS=['*'],
)

def modules(request, format='html'):
    return HttpResponse(f""format={format}"")

urlpatterns = [
    re_path(r'^module/(?P<format>(html|json|xml))?/?$', modules, name='modules'),
]

from django.test import RequestFactory
rf = RequestFactory()

print(""=== PR Description Test Case ==="")
print()

# The exact scenario described in the PR
request = rf.get('/module/')
match = resolve('/module/')
print(f""URL: /module/"")
print(f""resolve args: {match.args}, kwargs: {match.kwargs}"")

# Simulate what Django's URL resolver does when calling the view
try:
    response = match.func(request, *match.args, **match.kwargs)
    print(f""SUCCESS: Response: {response.content.decode()}"")
    print(f""Expected: format=html"")
except TypeError as e:
    print(f""FAILURE: {e}"")

print()

# When format IS provided
request2 = rf.get('/module/json/')
match2 = resolve('/module/json/')
print(f""URL: /module/json/"")
print(f""resolve args: {match2.args}, kwargs: {match2.kwargs}"")
response2 = match2.func(request2, *match2.args, **match2.kwargs)
print(f""SUCCESS: Response: {response2.content.decode()}"")
print(f""Expected: format=json"")

print()
print(""=== All tests passed! ==="")
PYEOF",
