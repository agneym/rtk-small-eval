import re

with open('django/db/models/sql/compiler.py', 'r') as f:
    content = f.read()

old = '''    def get_combinator_sql(self, combinator, all):
        features = self.connection.features'''

new = '''    def get_combinator_sql(self, combinator, all):
        if self.query.is_empty():
            raise EmptyResultSet
        features = self.connection.features'''

if old in content:
    content = content.replace(old, new, 1)
    with open('django/db/models/sql/compiler.py', 'w') as f:
        f.write(content)
    print('Patch applied successfully')
else:
    print('Could not find the target text')
    # Debug: show the surrounding text
    import re
    match = re.search(r'def get_combinator_sql.*?\n.*?features', content, re.DOTALL)
    if match:
        print(repr(match.group()))
