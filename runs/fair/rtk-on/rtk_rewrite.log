django.setup()

from django.db import models, connection
from django.db.models import Q
from model_fields.models import Foo, Bar

# Create a new model that has a FK to Foo with limit_choices_to using a Q object
# that involves a join (to Bar)
class Baz(models.Model):
    foo = models.ForeignKey(Foo, models.CASCADE, limit_choices_to=Q(bars__b__startswith='test'))
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'model_fields'

# Create tables
with connection.schema_editor() as schema_editor:
    schema_editor.create_model(Baz)

# Create test data
foo1 = Foo.objects.create(a='val1', d='1.000')
foo2 = Foo.objects.create(a='val2', d='2.000')
foo3 = Foo.objects.create(a='val3', d='3.000')

bar1 = Bar.objects.create(b='test1', a=foo1)
bar2 = Bar.objects.create(b='test2', a=foo1)  # foo1 has 2 bars starting with 'test'
bar3 = Bar.objects.create(b='other', a=foo2)   # foo2 has 1 bar NOT starting with 'test'
bar4 = Bar.objects.create(b='test3', a=foo3)   # foo3 has 1 bar starting with 'test'

# Test get_choices on the Baz.foo field
field = Baz._meta.get_field('foo')
print(""Testing get_choices..."")
choices = field.get_choices(include_blank=False)
print(f""Number of choices: {len(choices)}"")
for choice in choices:
    print(f""  {choice}"")

# Check for duplicates
ids = [c[0] for c in choices]
if len(ids) != len(set(ids)):
    print('BUG: DUPLICATE OPTIONS FOUND!')
else:
    print('OK: No duplicates')

print(f""\nExpected: foo1 (id={foo1.id}) and foo3 (id={foo3.id})"")
print(f""Got ids: {ids}"")

# Clean up
with connection.schema_editor() as se:
    se.delete_model(Baz)
