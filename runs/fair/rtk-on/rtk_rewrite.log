import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')

# Test full Django migration scenario
import sys
sys.path.insert(0, '.')
import django
django.setup()

from django.db import models
from django.db.migrations.writer import MigrationWriter
from django.db.migrations.serializer import serializer_factory

# Test 1: Simulate the EnumField case from the PR
class Thing(models.Model):
    class State(models.TextChoices):
        ON = 'on', 'On'
        OFF = 'off', 'Off'
    
    class Meta:
        app_label = 'test'

# Serialize State enum
value = Thing.State
result, imports = serializer_factory(value).serialize()
print(f'Enum type serialization: {result}')
print(f'Imports: {imports}')

# Test 2: TypeSerializer with inner class
class Outer:
    class Inner:
        pass

ts = serializer_factory(Outer.Inner)
result, imports = ts.serialize()
print(f'\\nInner class type serialization: {result}')
print(f'Imports: {imports}')

# Test 3: deconstructible inner class
from django.utils.deconstruct import deconstructible

@deconstructible
class Outer2:
    @deconstructible
    class Inner2(models.CharField):
        def __init__(self, max_length=20, *args, **kwargs):
            super().__init__(max_length=max_length, *args, **kwargs)

obj = Outer2.Inner2(max_length=20)
path, args, kwargs = obj.deconstruct()
print(f'\\nDeconstructible inner class path: {path}')
print(f'Path is correct: {path == \""__main__.Outer2.Inner2\""}')

print('\\nAll tests passed!')
