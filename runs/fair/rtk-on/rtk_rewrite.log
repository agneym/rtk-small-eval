import os
os.environ['DJANGO_SETTINGS_MODULE'] = 'test_settings'

import django
from django.conf import settings
if not settings.configured:
    settings.configure(
        DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
        INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
        SECRET_KEY='test-secret-key',
    )
    django.setup()

from django.db.models import Q
from django.db.models.expressions import Exists, Subquery
from django.contrib.auth.models import User

print('=== More complex scenarios ===')

# Chained operations
try:
    result = Q(x=1) & Exists(User.objects.all()) & Q(y=2)
    print(f'Q(x=1) & Exists() & Q(y=2): {result}')
except Exception as e:
    print(f'Error: {type(e).__name__}: {e}')

# Mixed & and |
try:
    result = Q(x=1) | Exists(User.objects.all()) & Q(y=2)
    print(f'Q(x=1) | Exists() & Q(y=2): {result}')
except Exception as e:
    print(f'Error: {type(e).__name__}: {e}')

# Double Exists
try:
    result = Q() & Exists(User.objects.all()) & Exists(User.objects.filter(is_staff=True))
    print(f'Q() & Exists() & Exists(): {result}')
except Exception as e:
    print(f'Error: {type(e).__name__}: {e}')

# Inverted Exists
try:
    result = Q() & ~Exists(User.objects.all())
    print(f'Q() & ~Exists(): {result}')
except Exception as e:
    print(f'Error: {type(e).__name__}: {e}')

# Non-conditional expression - should still raise TypeError
from django.db.models.expressions import Value
try:
    result = Q() & Value(1)
    print(f'Q() & Value(1): {result}')
except TypeError as e:
    print(f'Q() & Value(1) correctly raised TypeError: {e}')

print()
print('All edge cases pass!')
""
