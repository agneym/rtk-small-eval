import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
)
django.setup()

from django.db import models, connection
from django.db.models import Count, Subquery, OuterRef, Value

class TestModel(models.Model):
    name = models.CharField(max_length=100)
    status = models.IntegerField(default=0)
    class Meta:
        app_label = 'test'

with connection.schema_editor() as schema_editor:
    schema_editor.create_model(TestModel)

subq = TestModel.objects.filter(id=OuterRef('id')).values('status')[:1]
query = TestModel.objects.annotate(
    my_status=Subquery(subq),
    total=Count('id'),
)
answer = query.values('my_status').annotate(total_count=Count('my_status'))

# Let's look at the compiler setup
compiler = answer.query.get_compiler(using='default')
compiler.pre_sql_setup()
print('Select:')
for expr, alias in compiler.select:
    print(f'  expr: {expr}, type: {type(expr).__name__}')
    if hasattr(expr, 'get_group_by_cols'):
        cols = expr.get_group_by_cols()
        print(f'    get_group_by_cols(): {cols}')
        for col in cols:
            print(f'      type: {type(col).__name__}')
            if hasattr(col, 'as_sql'):
                sql, params = col.as_sql(compiler, connection)
                print(f'      sql: {sql}')
    print()

print('Annotation select:')
for alias, annotation in answer.query.annotation_select.items():
    print(f'  {alias}: {annotation}, type: {type(annotation).__name__}')
    if hasattr(annotation, 'get_group_by_cols'):
        cols = annotation.get_group_by_cols(alias=alias)
        print(f'    get_group_by_cols(alias={alias!r}): {cols}')
        for col in cols:
            print(f'      type: {type(col).__name__}')
            if hasattr(col, 'as_sql'):
                sql, params = col.as_sql(compiler, connection)
                print(f'      sql: {sql}')
    print()
