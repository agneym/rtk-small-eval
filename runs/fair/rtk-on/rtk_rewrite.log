import re

# Read the file
with open('django/utils/http.py', 'r') as f:
    content = f.read()

# Replace the old two-digit year logic with the new dynamic one
old = '''        year = int(m.group('year'))
        if year < 100:
            if year < 70:
                year += 2000
            else:
                year += 1900'''

new = '''        year = int(m.group('year'))
        if year < 100:
            current_year = datetime.datetime.now().year
            year += current_year - (current_year % 100)
            if year - current_year > 50:
                year -= 100'''

content = content.replace(old, new)

with open('django/utils/http.py', 'w') as f:
    f.write(content)

print('Done')
""
