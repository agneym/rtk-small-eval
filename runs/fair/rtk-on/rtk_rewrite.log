""""""
Comprehensive tests for callable path in FilePathField.
""""""
import os
import sys
import tempfile

os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')
sys.path.insert(0, '/testbed')

import django
from django.conf import settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
    DEFAULT_AUTO_FIELD='django.db.models.AutoField',
)
django.setup()

from django.db import models
from django import forms

# Create a temp directory with a file for testing
tmpdir = tempfile.mkdtemp()
testfile = os.path.join(tmpdir, 'test_file.txt')
open(testfile, 'w').close()

print(""="" * 60)
print(""Test 1: String path (basic)"")
print(""="" * 60)
field = models.FilePathField(path=tmpdir)
form_field = field.formfield()
print(f""  Model path: {field.path!r}"")
print(f""  Form path: {form_field.path!r}"")
choices = [v for k, v in form_field.choices if v != '---------']
print(f""  Choices: {choices}"")
assert isinstance(field.path, str)
assert isinstance(form_field.path, str)
print(""  PASS"")

print(""="" * 60)
print(""Test 2: Callable path (function)"")
print(""="" * 60)
def get_path():
    return tmpdir

field2 = models.FilePathField(path=get_path)
form_field2 = field2.formfield()
print(f""  Model path: {field2.path!r}"")
print(f""  Form path: {form_field2.path!r}"")
choices2 = [v for k, v in form_field2.choices if v != '---------']
print(f""  Choices: {choices2}"")
assert callable(field2.path)
assert isinstance(form_field2.path, str)
assert form_field2.path == tmpdir
print(""  PASS"")

print(""="" * 60)
print(""Test 3: Callable path (lambda)"")
print(""="" * 60)
field3 = models.FilePathField(path=lambda: tmpdir)
form_field3 = field3.formfield()
print(f""  Model path: {field3.path!r}"")
print(f""  Form path: {form_field3.path!r}"")
print(f""  path is callable: {callable(field3.path)}"")
assert callable(field3.path)
assert isinstance(form_field3.path, str)
print(""  PASS"")

print(""="" * 60)
print(""Test 4: Deconstruct with callable"")
print(""="" * 60)
name, path, args, kwargs = field2.deconstruct()
print(f""  name: {name}"")
print(f""  path: {path}"")
print(f""  kwargs: {kwargs}"")
assert 'path' in kwargs
assert kwargs['path'] is get_path  # The function reference is preserved
print(""  PASS"")

print(""="" * 60)
print(""Test 5: Form field directly with callable"")
print(""="" * 60)
form_field5 = forms.FilePathField(path=lambda: tmpdir)
print(f""  Form path: {form_field5.path!r}"")
assert isinstance(form_field5.path, str)
assert form_field5.path == tmpdir
print(""  PASS"")

print(""="" * 60)
print(""Test 6: Class-based callable"")
print(""="" * 60)
class PathProvider:
    def __call__(self):
        return tmpdir

field6 = models.FilePathField(path=PathProvider())
form_field6 = field6.formfield()
print(f""  Model path: {field6.path!r}"")
print(f""  Form path: {form_field6.path!r}"")
assert callable(field6.path)
assert isinstance(form_field6.path, str)
assert form_field6.path == tmpdir
print(""  PASS"")

print(""="" * 60)
print(""Test 7: FilePathField with match and callable path"")
print(""="" * 60)
field7 = models.FilePathField(path=lambda: tmpdir, match=r'\.txt$')
form_field7 = field7.formfield()
print(f""  Form path: {form_field7.path!r}"")
print(f""  Choices: {[(k, v) for k, v in form_field7.choices if v != '---------']}"")
assert isinstance(form_field7.path, str)
print(""  PASS"")

# Cleanup
os.remove(testfile)
os.rmdir(tmpdir)

print(""\n"" + ""="" * 60)
print(""ALL TESTS PASSED"")
print(""="" * 60)
EOF
