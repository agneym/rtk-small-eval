for child in b.query.where.children:
    print('Child:', child)
    print('LHS:', child.lhs)
    print('RHS:', child.rhs)
    print('RHS type:', type(child.rhs))
    if hasattr(child.rhs, 'query'):
        print('RHS.query.group_by:', child.rhs.query.group_by)
        print('RHS.query.values_select:', child.rhs.query.values_select)
