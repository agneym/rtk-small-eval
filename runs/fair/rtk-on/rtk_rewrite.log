import django
import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')

from django.db.models import BigAutoField, SmallAutoField, AutoField

class MyBigAutoField(BigAutoField):
    pass

class MySmallAutoField(SmallAutoField):
    pass

# These should now all be True
print('issubclass(MyBigAutoField, AutoField):', issubclass(MyBigAutoField, AutoField))
print('issubclass(MySmallAutoField, AutoField):', issubclass(MySmallAutoField, AutoField))
print('issubclass(BigAutoField, AutoField):', issubclass(BigAutoField, AutoField))
print('issubclass(SmallAutoField, AutoField):', issubclass(SmallAutoField, AutoField))
print('issubclass(AutoField, AutoField):', issubclass(AutoField, AutoField))

# Also test __instancecheck__
class MyModel:
    pass

my_big = MyBigAutoField()
my_small = MySmallAutoField()
big = BigAutoField()
small = SmallAutoField()

print()
print('isinstance(my_big, AutoField):', isinstance(my_big, AutoField))
print('isinstance(my_small, AutoField):', isinstance(my_small, AutoField))
print('isinstance(big, AutoField):', isinstance(big, AutoField))
print('isinstance(small, AutoField):', isinstance(small, AutoField))

# Test that completely unrelated classes don't match
from django.db.models import CharField, IntegerField
print()
print('issubclass(CharField, AutoField):', issubclass(CharField, AutoField))
print('issubclass(IntegerField, AutoField):', issubclass(IntegerField, AutoField))
""
