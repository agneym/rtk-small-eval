from django.contrib.syndication.views import Feed
from django.http import HttpRequest
from django.contrib.sites.models import Site
from django.contrib.sites.shortcuts import get_current_site

# Monkey-patch get_current_site
import django.contrib.syndication.views as views
def mock_get_current_site(request):
    return Site(domain='example.com', name='Example')
views.get_current_site = mock_get_current_site

class TestFeed(Feed):
    title = 'Test Feed'
    link = '/blog/'
    description = 'Test Description'
    
    def items(self):
        return [{'title': 'Item 1', 'link': '/item1/', 'comments_url': 'http://example.com/comments/1'}]
    
    def item_title(self, item):
        return item['title']
    
    def item_link(self, item):
        return item['link']
    
    def item_comments(self, item):
        return item['comments_url']

request = HttpRequest()
request.META['SERVER_NAME'] = 'example.com'
request.META['SERVER_PORT'] = '80'

feed = TestFeed()
feedgen = feed.get_feed(None, request)

# Write to string
from io import StringIO
output = StringIO()
feedgen.write(output, 'utf-8')
rss_output = output.getvalue()

