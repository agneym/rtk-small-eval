from django.db import models
from django.core import checks

# Test the hint message for E334 (seen_from > 1)
class Person(models.Model):
    pass

class Group(models.Model):
    field = models.ManyToManyField('Person', through='AmbiguousFromRel', related_name='tertiary')

class AmbiguousFromRel(models.Model):
