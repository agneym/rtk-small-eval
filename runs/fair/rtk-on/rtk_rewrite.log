import os, sys
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')
sys.path.insert(0, '/testbed/tests')

import django
from django.conf import settings
django.setup()

from django.test.utils import isolate_apps

# We need to use isolate_apps to properly test this
from django.db import models
from django.core import checks

# Let's test with the proper infrastructure
from django.apps import apps

@isolate_apps('check_framework')
def test():
    class ParentModel(models.Model):
        name = models.CharField(max_length=100)
        class Meta:
            app_label = 'check_framework'

    class ChildModel(ParentModel):
        age = models.IntegerField()
        class Meta:
            app_label = 'check_framework'

    class StandaloneModel(models.Model):
        name = models.CharField(max_length=100)
        class Meta:
            app_label = 'check_framework'

    errors_child = ChildModel.check()
    errors_standalone = StandaloneModel.check()
    
    w042_child = [e for e in errors_child if e.id == 'models.W042']
    w042_standalone = [e for e in errors_standalone if e.id == 'models.W042']
    
    print('Child W042:', len(w042_child))
    print('Standalone W042:', len(w042_standalone))
    
    print('Child parents:', ChildModel._meta.parents)
    print('Standalone parents:', StandaloneModel._meta.parents)
    print('Child app_config._is_default_auto_field_overridden:', 
          ChildModel._meta.app_config._is_default_auto_field_overridden)
    print('Standalone app_config._is_default_auto_field_overridden:', 
          StandaloneModel._meta.app_config._is_default_auto_field_overridden)

test()
