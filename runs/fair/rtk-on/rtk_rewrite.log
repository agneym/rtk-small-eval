from django.utils.dateparse import parse_duration

# Test various formats
tests = [
    ('14:00', 'MM:ss'),          # 14 minutes
    ('1:14:00', 'HH:MM:ss'),     # 1 hour 14 minutes
    ('00:14:00', 'HH:MM:ss'),    # 14 minutes (with hours=0)
    ('30', 'ss'),                # 30 seconds
    ('1:30', 'MM:ss'),           # 1 minute 30 seconds
    ('1:2:30', 'HH:MM:ss'),      # 1 hour 2 minutes 30 seconds
]

for val, desc in tests:
    result = parse_duration(val)
    print(f'{val:15s} ({desc:15s}) -> {result}')

# Now test what format DURATION field accepts
from django.db import models
f = models.DurationField()
print()
# Test parsing various strings through the field
for val in ['14:00', '1:14:00', '30', '1:30', '00:14:00']:
    try:
        result = f.to_python(val)
        print(f'{val:15s} -> {result}')
    except Exception as e:
        print(f'{val:15s} -> ERROR: {e}')
""
