# Test empty tuple
result = query.resolve_lookup_value((), can_reuse=None, allow_joins=True)
assert result == ()

# Test empty list
result = query.resolve_lookup_value([], can_reuse=None, allow_joins=True)
assert result == []

# Test 2-element named tuple
MyRange = namedtuple('MyRange', ['start', 'end'])
result = query.resolve_lookup_value(MyRange(1, 2), can_reuse=None, allow_joins=True)
assert result == MyRange(None, None)
assert type(result) is MyRange

# Test 3-element named tuple
Triple = namedtuple('Triple', ['a', 'b', 'c'])
result = query.resolve_lookup_value(Triple(1, 2, 3), can_reuse=None, allow_joins=True)
assert result == Triple(None, None, None)
assert type(result) is Triple

# Test single-element named tuple
Single = namedtuple('Single', ['x'])
result = query.resolve_lookup_value(Single(1), can_reuse=None, allow_joins=True)
assert result == Single(None)

# Test single-element tuple
result = query.resolve_lookup_value((1,), can_reuse=None, allow_joins=True)
assert result == (None,)

# Test nested named tuple in list
result = query.resolve_lookup_value([MyRange(1, 2), MyRange(3, 4)], can_reuse=None, allow_joins=True)
assert result == [MyRange(None, None), MyRange(None, None)]
assert type(result) is list
assert type(result[0]) is MyRange

print('All tests passed!')
