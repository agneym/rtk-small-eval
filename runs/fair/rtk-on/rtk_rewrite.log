import os, sys
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'test_sqlite')
sys.path.insert(0, 'tests')

import django
django.setup()

from django.test import Client
from django.conf import settings
from django.http import HttpResponseNotModified

# Create a test file
import tempfile
tmpdir = tempfile.mkdtemp()
testfile = os.path.join(tmpdir, 'test.txt')
with open(testfile, 'w') as f:
    f.write('test content')

# Test with empty If-Modified-Since header
client = Client()
response = client.get('/static/test.txt' if hasattr(settings, 'STATIC_URL') else '/',
    HTTP_IF_MODIFIED_SINCE='',
    SCRIPT_NAME='')
print(f'Test with empty header completed - status: {response.status_code}')
print('SUCCESS: No exception raised!')
""
