2026-06-24T10:29:23+00:00,b700e0db0af5457297316ccaf3cb803e,1,"cd /testbed && python3 -c ""
import django
import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')
# Just test the regex directly
import re
from django.contrib.auth.validators import ASCIIUsernameValidator, UnicodeUsernameValidator

# Test with normal valid usernames
valid_usernames = ['testuser', 'user123', 'user.name', 'user@name', 'user+name', 'user-name', 'user_name', 'a'*150]
for u in valid_usernames:
    try:
        ASCIIUsernameValidator()(u)
        UnicodeUsernameValidator()(u)
        print(f'OK: {repr(u)}')
    except Exception as e:
        print(f'UNEXPECTED ERROR: {repr(u)} -> {e}')

# Test with invalid usernames (with trailing newline)
invalid_usernames = ['testuser\n', 'testuser\r\n', 'test\nuser', '']
for u in invalid_usernames:
    ascii_valid = True
    unicode_valid = True
    try:
        ASCIIUsernameValidator()(u)
        ascii_valid = True
    except:
        ascii_valid = False
    try:
        UnicodeUsernameValidator()(u)
        unicode_valid = True
    except:
        unicode_valid = False
    print(f'ASCII rejects {repr(u)}: {not ascii_valid}, Unicode rejects {repr(u)}: {not unicode_valid}')
""
