from django.db import models, connection
from django.db.models import Q
from model_fields.models import Foo, Bar

class Baz(models.Model):
    foo = models.ForeignKey(Foo, models.CASCADE, limit_choices_to=Q(bars__b__startswith='test'))
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'model_fields'

with connection.schema_editor() as schema_editor:
    schema_editor.create_model(Foo)
    schema_editor.create_model(Bar)
    schema_editor.create_model(Baz)

foo1 = Foo.objects.create(a='val1', d='1.000')
foo2 = Foo.objects.create(a='val2', d='2.000')
foo3 = Foo.objects.create(a='val3', d='3.000')

bar1 = Bar.objects.create(b='test1', a=foo1)
bar2 = Bar.objects.create(b='test2', a=foo1)
bar3 = Bar.objects.create(b='other', a=foo2)
bar4 = Bar.objects.create(b='test3', a=foo3)

# Now test the formfield creation
from django import forms
from django.forms import models as forms_models

# Create a ModelForm for Baz
class BazForm(forms.ModelForm):
    class Meta:
        model = Baz
        fields = ['foo']

form = BazForm()
foo_field = form.fields['foo']
print('Form field queryset:', list(foo_field.queryset))
print('Form field choices:', list(foo_field.choices))

# Check for duplicates in the queryset
qs = list(foo_field.queryset)
ids = [obj.id for obj in qs]
if len(ids) != len(set(ids)):
    print('BUG: DUPLICATES IN FORM QUERYSET!')
else:
    print('OK: No duplicates in form queryset')

with connection.schema_editor() as se:
    se.delete_model(Baz)
    se.delete_model(Bar)
    se.delete_model(Foo)
