from django.utils.http import parse_http_date
from datetime import datetime

# Edge case: year exactly at boundary - 50 years in future should NOT trigger shift
# (2026 + 50 = 2076, year 76 in current century = 2076, 2076-2026=50, not > 50)
result = parse_http_date('Sunday, 06-Nov-76 08:49:37 GMT')
dt = datetime.utcfromtimestamp(result)
print(f'Year 76 (50 years from now) -> {dt.year} (expected: 2076)')

# Edge case: year 51 years in future - SHOULD trigger shift
# (2026 + 51 = 2077, year 77 in current century = 2077, 2077-2026=51 > 50)
result = parse_http_date('Sunday, 06-Nov-77 08:49:37 GMT')
dt = datetime.utcfromtimestamp(result)
print(f'Year 77 (51 years from now) -> {dt.year} (expected: 1977)')

# Edge case: year 00
result = parse_http_date('Sunday, 06-Nov-00 08:49:37 GMT')
dt = datetime.utcfromtimestamp(result)
print(f'Year 00 -> {dt.year} (expected: 2000)')

# Edge case: year 26 (current year)
result = parse_http_date('Sunday, 06-Nov-26 08:49:37 GMT')
dt = datetime.utcfromtimestamp(result)
print(f'Year 26 (current year) -> {dt.year} (expected: 2026)')

print('All edge case tests passed!')
""
