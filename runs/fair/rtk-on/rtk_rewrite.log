from urllib.parse import urlsplit

# Let's try to find edge cases that match the pattern but fail urlsplit
# The ipv6_re is: \[[0-9a-f:.]+\]
# What characters are problematic?

# Try various IPv6-like patterns
test_cases = [
    'http://[a:b:c:d:e:f:1.2.3.4]',  # IPv4-mapped IPv6
    'http://[::1.2.3.4]',  # IPv4-compatible
    'http://[::ffff:1.2.3.4]',
    'http://[2001:db8::1]',
    'http://[2001:db8:0:0:0:0:0:1]',
    'http://[2001:db8:0:0:0:0:0:1:extra]',
    'http://[::]',
    'http://[:::',
    'http://[::::]',
    'http://[a:b:c:d:e:f:g:h:i]',
    'http://[a:b:c:d:e:f:g:h:i:j]',
    'http://[a:b:c:d:e:f:1.2.3.4.5]',  # too many dots
]

for url in test_cases:
    try:
        parsed = urlsplit(url)
        print(f'OK:   {url!r} -> netloc={parsed.netloc!r}')
    except ValueError as e:
        print(f'ERR:  {url!r} -> {e}')
""",
