with open('django/db/models/expressions.py', 'r') as f:
    content = f.read()

old = '''    def as_sql(self, compiler, connection):
        return compiler.compile(self.expression)'''

new = '''    def as_sql(self, compiler, connection):
        try:
            sql, params = compiler.compile(self.expression)
        except EmptyResultSet:
            sql, params = compiler.compile(Value(False))
        if not sql:
            sql, params = compiler.compile(Value(True))
        return sql, params'''

if old in content:
    content = content.replace(old, new)
    with open('django/db/models/expressions.py', 'w') as f:
        f.write(content)
    print('Successfully replaced')
else:
    print('Could not find the old text')
    # Let's check what's there
    import re
    match = re.search(r'def as_sql\(self, compiler, connection\):\s+return compiler\.compile\(self\.expression\)', content)
    if match:
        print('Found with regex')
        print(repr(match.group()))
""
