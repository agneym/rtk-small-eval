# str.__eq__ compares the string VALUE of the object
# For enum, str(Event.C) returns 'Event.C' but the actual string value is Event.C.value = 'Carnival!'
# Actually, let me check what str.__eq__ does...
print(f""Is Event.C a str? {isinstance(Event.C, str)}"")
# str.__eq__ compares using the str value (not via str()) but via the internal value
# Since TextChoices extends str, the __eq__ of str compares the character data
# which is 'Carnival!' for Event.C
print(f""Event.C == 'Carnival!' (2): {Event.C == 'Carnival!'}"")
