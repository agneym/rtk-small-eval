from astropy.modeling import models as m
from astropy.modeling.separable import separability_matrix, _separable

cm = m.Linear1D(10) & m.Linear1D(5)

# Let's trace through manually
from astropy.modeling.separable import _cstack, _coord_matrix, _compute_n_outputs
import numpy as np

# Trace _separable for cm
sepleft2 = _separable(m.Linear1D(10))
print('sepleft2 (Linear1D(10)):', sepleft2)

sepright2 = _separable(m.Linear1D(5))
print('sepright2 (Linear1D(5)):', sepright2)

result = _cstack(sepleft2, sepright2)
print('_cstack result for Linear1D(10) & Linear1D(5):')
print(result)

# So for the outer model: Pix2Sky_TAN() & cm
sepleft = _separable(m.Pix2Sky_TAN())
print()
print('sepleft (Pix2Sky_TAN()):')
print(sepleft)

print()
print('sepright (cm result):')
print(result)

# This is the problematic call
outer_result = _cstack(sepleft, result)
print()
print('outer _cstack result (buggy):')
print(outer_result)

# What it SHOULD be:
print()
print('Expected (what we get from flat version):')
from astropy.modeling.separable import separability_matrix
print(separability_matrix(m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)))
""",
