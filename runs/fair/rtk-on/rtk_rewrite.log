# Read the file
with open('django/db/models/fields/__init__.py', 'r') as f:
    content = f.read()

# Modify the check method to add _check_max_length_choices
old_check = '''    def check(self, **kwargs):
        return [
            *super().check(**kwargs),
            *self._check_max_length_attribute(**kwargs),
        ]'''

new_check = '''    def check(self, **kwargs):
        return [
            *super().check(**kwargs),
            *self._check_max_length_attribute(**kwargs),
            *self._check_max_length_choices(),
        ]'''

content = content.replace(old_check, new_check)

# Add the _check_max_length_choices method after _check_max_length_attribute
old_method_end = '''    def _check_max_length_attribute(self, **kwargs):
        if self.max_length is None:
            return [
                checks.Error(
                    \""CharFields must define a 'max_length' attribute.\"",
                    obj=self,
                    id='fields.E120',
                )
            ]
        elif (not isinstance(self.max_length, int) or isinstance(self.max_length, bool) or
                self.max_length <= 0):
            return [
                checks.Error(
                    \""'max_length' must be a positive integer.\"",
                    obj=self,
                    id='fields.E121',
                )
            ]
        else:
            return []

    def cast_db_type'''

new_method = '''    def _check_max_length_attribute(self, **kwargs):
        if self.max_length is None:
            return [
                checks.Error(
                    \""CharFields must define a 'max_length' attribute.\"",
                    obj=self,
                    id='fields.E120',
                )
            ]
        elif (not isinstance(self.max_length, int) or isinstance(self.max_length, bool) or
                self.max_length <= 0):
            return [
                checks.Error(
                    \""'max_length' must be a positive integer.\"",
                    obj=self,
                    id='fields.E121',
                )
            ]
        else:
            return []

    def _check_max_length_choices(self):
        if self.choices is None or self.max_length is None:
            return []
        if self.max_length is not None:
            max_choice_length = 0
            for choice, _ in self.flatchoices:
                if isinstance(choice, str):
                    max_choice_length = max(max_choice_length, len(choice))
                elif isinstance(choice, bytes):
                    max_choice_length = max(max_choice_length, len(choice))
            if max_choice_length > self.max_length:
                return [
                    checks.Error(
                        \""'max_length' is too small to fit the longest choice \""\n                        \""value (%d characters).\"" % max_choice_length,\n                        obj=self,\n                        id='fields.E122',\n                    )\n                ]\n        return []\n\n    def cast_db_type'''

content = content.replace(old_method_end, new_method)

with open('django/db/models/fields/__init__.py', 'w') as f:
    f.write(content)

print('Done')
""
