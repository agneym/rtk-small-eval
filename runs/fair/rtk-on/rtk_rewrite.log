os.environ['DJANGO_SETTINGS_MODULE'] = 'test_settings'

import django
from django.conf import settings

if not settings.configured:
    settings.configure(
        DATABASES={
            'default': {
                'ENGINE': 'django.db.backends.sqlite3',
                'NAME': ':memory:',
            },
            'other': {
                'ENGINE': 'django.db.backends.sqlite3',
                'NAME': ':memory:',
            }
        },
        DATABASE_ROUTERS=[],
        INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
        DEFAULT_AUTO_FIELD='django.db.models.AutoField',
        SECRET_KEY='test-secret-key',
    )

django.setup()

from django.db import connections, router
from django.db.migrations.recorder import MigrationRecorder

# Router that only allows specific apps on 'other'
class SpecificAppRouter:
    def allow_migrate(self, db, app_label, model_name=None, **hints):
        if db == 'default':
            return True
        # On 'other', only allow the 'allowed_app'
        if db == 'other' and app_label == 'allowed_app':
            return True
        if db == 'other':
            return False
        return None

router.routers = [SpecificAppRouter()]

# Check that router works
print('Router checks:')
print('  allow_migrate(default, migrations):', router.allow_migrate('default', 'migrations'))
print('  allow_migrate(other, migrations):', router.allow_migrate('other', 'migrations'))
print('  allow_migrate(other, allowed_app):', router.allow_migrate('other', 'allowed_app'))
print('  allow_migrate(other, blocked_app):', router.allow_migrate('other', 'blocked_app'))

# Test with SpecificAppRouter
recorder = MigrationRecorder(connections['other'])

# ensure_schema - should not create table because 'migrations' is not allowed on 'other'
recorder.ensure_schema()
print()
print('Has table on other:', recorder.has_table())

# Record an allowed app - should work because ensure_schema will be called
# and 'allowed_app' is allowed on 'other'
print('Record allowed_app on other:')
recorder.record_applied('allowed_app', '0001_initial')
print('  Applied migrations:', recorder.applied_migrations())

# Record a blocked app - should not work
print('Record blocked_app on other:')
recorder.record_applied('blocked_app', '0001_initial')
print('  Applied migrations:', recorder.applied_migrations())

print()
print('All tests passed!')
