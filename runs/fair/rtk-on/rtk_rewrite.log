import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'test_settings')

import django
from django.conf import settings
if not settings.configured:
    settings.configure(
        DATABASES={
            'default': {
                'ENGINE': 'django.db.backends.sqlite3',
                'NAME': ':memory:',
            },
        },
        INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
        DEFAULT_AUTO_FIELD='django.db.models.AutoField',
    )
    django.setup()

from django.db import models, connection

# Create models with dependencies
class Parent(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test_app'

class Child(models.Model):
    parent = models.ForeignKey(Parent, models.CASCADE)
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test_app'

# Create tables
with connection.schema_editor() as schema_editor:
    schema_editor.create_model(Parent)
    schema_editor.create_model(Child)

# Test 1: Simple model without dependencies - PK should be set to None
print(""=== Test 1: Simple model without dependencies ==="")
p = Parent.objects.create(name='parent1')
print('Before delete: pk =', p.pk)
p.delete()
print('After delete: pk =', p.pk, '(expected: None)')
assert p.pk is None, f""FAIL: pk is {p.pk}, expected None""
print(""PASS"")

# Test 2: Model with dependencies - PK should also be set to None
print(""\n=== Test 2: Model with dependencies ==="")
p2 = Parent.objects.create(name='parent2')
c = Child.objects.create(parent=p2, name='child')
print('Before delete - parent pk =', p2.pk)
print('Before delete - child pk =', c.pk)
p2.delete()
print('After delete - parent pk =', p2.pk, '(expected: None)')
print('After delete - child pk =', c.pk, '(expected: None)')
# Note: child's PK is set to None because it was cascade-deleted
assert p2.pk is None, f""FAIL: parent pk is {p2.pk}, expected None""
assert c.pk is None, f""FAIL: child pk is {c.pk}, expected None""
print(""PASS"")

# Test 3: Bulk delete via queryset - PKs should NOT be set to None (queryset delete doesn't update instances)
print(""\n=== Test 3: Bulk delete via queryset ==="")
p3 = Parent.objects.create(name='parent3')
p4 = Parent.objects.create(name='parent4')
print('Before delete: pk3 =', p3.pk, ', pk4 =', p4.pk)
Parent.objects.all().delete()
print('After delete: pk3 =', p3.pk, ', pk4 =', p4.pk)
# queryset delete doesn't update instance PKs, which is expected
print(""NOTE: queryset delete doesn't update instance PKs - this is expected behavior"")

print(""\nAll tests passed!"")
EOF
