import django
from django.conf import settings
from django.contrib import admin
from django.db import models

# Configure minimal Django settings
settings.configure(
    DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
    INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth', 'django.contrib.admin'],
    USE_I18N=False,
)
django.setup()

# Create test models
class Book(models.Model):
    title = models.CharField(max_length=100)
    class Meta:
        app_label = 'test_app'
        verbose_name = 'Book'
        verbose_name_plural = 'Books'

class Author(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test_app'
        verbose_name = 'Author'
        verbose_name_plural = 'Authors'

class BookInline(admin.TabularInline):
    model = Book
    verbose_name = 'Custom Book Name'
    # verbose_name_plural not set - should default from verbose_name

class AuthorInline(admin.TabularInline):
    model = Author
    # verbose_name_plural not set - should use model's default

class BookInlineWithPlural(admin.TabularInline):
    model = Book
    verbose_name = 'Custom Book Name'
    verbose_name_plural = 'Custom Book Names Plural'

# Create instances like Django admin would
from django.contrib.admin.options import InlineModelAdmin

# Simulate what happens when inline is instantiated
parent_model = Author  # using Author as parent
admin_site = admin.AdminSite()

# Test 1: verbose_name set, verbose_name_plural not set
inline1 = BookInline(parent_model, admin_site)
print(f""Test 1 - verbose_name='Custom Book Name', verbose_name_plural=None"")
print(f""  verbose_name: {inline1.verbose_name}"")
print(f""  verbose_name_plural: {inline1.verbose_name_plural}"")
print(f""  Expected verbose_name_plural: Custom Book Names"")
print()

# Test 2: neither verbose_name nor verbose_name_plural set
inline2 = AuthorInline(parent_model, admin_site)
print(f""Test 2 - verbose_name=None, verbose_name_plural=None"")
print(f""  verbose_name: {inline2.verbose_name}"")
print(f""  verbose_name_plural: {inline2.verbose_name_plural}"")
print(f""  Expected verbose_name_plural: Authors (from model Meta)"")
print()

# Test 3: both verbose_name and verbose_name_plural set
inline3 = BookInlineWithPlural(parent_model, admin_site)
print(f""Test 3 - both set"")
print(f""  verbose_name: {inline3.verbose_name}"")
print(f""  verbose_name_plural: {inline3.verbose_name_plural}"")
print(f""  Expected verbose_name_plural: Custom Book Names Plural"")
EOF
