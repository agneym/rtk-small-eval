with open('django/views/static.py', 'r') as f:
    content = f.read()

old = '''        matches = re.match(r\""^([^;]+)(; length=([0-9]+))?$\"", header, re.IGNORECASE)
        header_mtime = parse_http_date(matches[1])'''

new = '''        matches = re.match(r\""^([^;]+)(; length=([0-9]+))?$\"", header, re.IGNORECASE)
        if matches is None:
            raise ValueError
        header_mtime = parse_http_date(matches[1])'''

content = content.replace(old, new)

with open('django/views/static.py', 'w') as f:
    f.write(content)
