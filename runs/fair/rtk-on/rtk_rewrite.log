2026-06-24T18:33:33+00:00,0c640f6aa06d48d5b78f9a75ef15c16b,1,"cd /testbed && python -c ""
from functools import wraps, partial
from django.utils.decorators import method_decorator

def logger(func):
    @wraps(func)
    def inner(*args, **kwargs):
        try:
            result = func(*args, **kwargs)
        except Exception as e:
            result = str(e)
        # This accesses func.__name__ which fails for partial objects
        print(f'{func.__name__} called with args: {args} kwargs: {kwargs} result: {result}')
        return result
    return inner

class Test:
    @method_decorator(logger)
    def hello_world(self):
        return 'hello'

t = Test()
t.hello_world()
""
