)
django.setup()

from django.db.models.expressions import F, ExpressionList
from django.db.models.sql import Query
from django.db import models, connection

class Tag(models.Model):
    name = models.SlugField()
    value = models.CharField(max_length=150)
    class Meta:
        app_label = 'myapp'
        db_table = 'myapp_tag'

# Simulating what _create_unique_sql does
query = Query(Tag, alias_cols=False)
from django.db.models.expressions import ExpressionList, IndexExpression
expressions = F('name'), F('value')
index_expressions = []
for expression in expressions:
    index_expression = IndexExpression(expression)
    index_expressions.append(index_expression)
expr_list = ExpressionList(*index_expressions).resolve_expression(query)
compiler = query.get_compiler(connection=connection)
sql, params = compiler.compile(expr_list)
print('SQL:', sql)
print('Params:', params)
