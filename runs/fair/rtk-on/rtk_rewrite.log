2026-06-24T18:08:55+00:00,7b70518f8b1b4dfca241e4d54c259a20,1,"cd /testbed && python -c ""
import django
from django.conf import settings
if not settings.configured:
    settings.configure(
        DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
        INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
        DEFAULT_AUTO_FIELD='django.db.models.AutoField',
    )
    django.setup()

from django.db.models.fields.reverse_related import ManyToManyRel
from django.utils.hashable import make_hashable

# Test that the identity property works with through_fields as a list
rel = ManyToManyRel.__new__(ManyToManyRel)
rel.field = None
rel.model = None
rel.related_name = None
rel.related_query_name = None
rel.limit_choices_to = {}
rel.parent_link = False
rel.on_delete = None
rel.symmetrical = True
rel.multiple = True
rel.through = None
rel.through_fields = ['child', 'parent']  # This is a list, was causing the issue
rel.db_constraint = True

try:
    h = hash(rel)
    print(f'SUCCESS: Hash of ManyToManyRel with list through_fields: {h}')
except TypeError as e:
    print(f'FAILED: {e}')

# Also test equality comparison
rel2 = ManyToManyRel.__new__(ManyToManyRel)
rel2.field = None
rel2.model = None
rel2.related_name = None
rel2.related_query_name = None
rel2.limit_choices_to = {}
rel2.parent_link = False
rel2.on_delete = None
rel2.symmetrical = True
rel2.multiple = True
rel2.through = None
rel2.through_fields = ['child', 'parent']
rel2.db_constraint = True

try:
    print(f'Equality works: {rel == rel2}')
except TypeError as e:
    print(f'FAILED equality: {e}')

# Test with through_fields as tuple (should still work)
rel3 = ManyToManyRel.__new__(ManyToManyRel)
rel3.field = None
rel3.model = None
rel3.related_name = None
rel3.related_query_name = None
rel3.limit_choices_to = {}
rel3.parent_link = False
rel3.on_delete = None
rel3.symmetrical = True
rel3.multiple = True
rel3.through = None
rel3.through_fields = ('child', 'parent')
rel3.db_constraint = True

try:
    h3 = hash(rel3)
    print(f'SUCCESS: Hash of ManyToManyRel with tuple through_fields: {h3}')
    print(f'List and tuple versions equal: {rel == rel3}')
except TypeError as e:
    print(f'FAILED: {e}')

# Test with through_fields as None (should still work)
rel4 = ManyToManyRel.__new__(ManyToManyRel)
rel4.field = None
rel4.model = None
rel4.related_name = None
rel4.related_query_name = None
rel4.limit_choices_to = {}
rel4.parent_link = False
rel4.on_delete = None
rel4.symmetrical = True
rel4.multiple = True
rel4.through = None
rel4.through_fields = None
rel4.db_constraint = True

try:
    h4 = hash(rel4)
    print(f'SUCCESS: Hash of ManyToManyRel with None through_fields: {h4}')
except TypeError as e:
    print(f'FAILED: {e}')
"" 2>&1",
