from django.conf import settings
settings.INSTALLED_APPS = [
    'django.contrib.contenttypes',
    'django.contrib.auth',
]

# Need to configure the database properly
settings.DATABASES['default']['NAME'] = ':memory:'

django.setup()

from django.db import models, connection
from django.db.models import Q

# Create schema
with connection.schema_editor() as schema_editor:
    class Category(models.Model):
        name = models.CharField(max_length=100)
        class Meta:
            app_label = 'test'
    
    class Book(models.Model):
        title = models.CharField(max_length=100)
        class Meta:
            app_label = 'test'
    
    class BookCategory(models.Model):
        book = models.ForeignKey(Book, models.CASCADE, related_name='book_categories')
        category = models.ForeignKey(Category, models.CASCADE, related_name='book_categories')
        class Meta:
            app_label = 'test'
    
    class Page(models.Model):
        book = models.ForeignKey(Book, models.CASCADE, related_name='pages')
        content = models.TextField()
        class Meta:
            app_label = 'test'
    
    # EditorialReview has a FK to Book with limit_choices_to that involves
    # a join through Book -> BookCategory -> Category
    class EditorialReview(models.Model):
        book = models.ForeignKey(Book, models.CASCADE, related_name='reviews',
                                  limit_choices_to=Q(book_categories__category__name='Fiction'))
        rating = models.IntegerField()
        class Meta:
            app_label = 'test'
    
    schema_editor.create_model(Category)
    schema_editor.create_model(Book)
    schema_editor.create_model(BookCategory)
    schema_editor.create_model(Page)
    schema_editor.create_model(EditorialReview)

# Insert some data
cat_fiction = Category.objects.create(name='Fiction')
cat_non_fiction = Category.objects.create(name='Non-Fiction')
cat_sci_fi = Category.objects.create(name='Sci-Fi')

book1 = Book.objects.create(title='Book 1 - Multi-category')
BookCategory.objects.create(book=book1, category=cat_fiction)
BookCategory.objects.create(book=book1, category=cat_non_fiction)
BookCategory.objects.create(book=book1, category=cat_sci_fi)

book2 = Book.objects.create(title='Book 2 - Single category')
BookCategory.objects.create(book=book2, category=cat_fiction)

book3 = Book.objects.create(title='Book 3 - No fiction')
BookCategory.objects.create(book=book3, category=cat_non_fiction)

# Now test get_choices on EditorialReview.book
field = EditorialReview._meta.get_field('book')
print(""Testing get_choices..."")
choices = field.get_choices(include_blank=False)
print(f""Number of choices: {len(choices)}"")
for choice in choices:
    print(f""  {choice}"")

# Book 1 matches because it has a 'Fiction' category, and it has 3 categories.
# The join will produce 3 rows for book1 but only 1 matches the WHERE.
# Wait, actually: 
# The join will be: book INNER JOIN book_category ON ... INNER JOIN category ON ...
# WHERE category.name = 'Fiction'
# 
# book1 has 3 book_categories, but only 1 has category.name='Fiction'
# So the join produces 1 row for book1.
# book2 has 1 book_category with category.name='Fiction'
# So the join produces 1 row for book2.
# 
# Hmm, this won't produce duplicates either. The WHERE clause filters after the join.
# 
# Let me think of when duplicates occur...
# If the limit_choices_to is something like Q(book_categories__category__name__in=['Fiction', 'Sci-Fi'])
# Then book1 matches via both Fiction AND Sci-Fi categories, giving 2 rows.

print()
print(""Now testing with IN lookup..."")
field2 = EditorialReview._meta.get_field('book')
# Let's call get_choices with a custom limit_choices_to
qs = Book._default_manager.complex_filter(Q(book_categories__category__name__in=['Fiction', 'Sci-Fi']))
print(f""Query: {qs.query}"")
results = list(qs)
print(f""Number of results: {len(results)}"")
for r in results:
    print(f""  {r.id}: {r.title}"")

ids = [r.id for r in results]
if len(ids) != len(set(ids)):
    print(""BUG: DUPLICATE OPTIONS DETECTED!"")
else:
    print(""OK: No duplicates"")

# Clean up
from django.db import connection as conn
with conn.schema_editor() as se:
    se.delete_model(EditorialReview)
    se.delete_model(Page)
    se.delete_model(BookCategory)
    se.delete_model(Book)
    se.delete_model(Category)
