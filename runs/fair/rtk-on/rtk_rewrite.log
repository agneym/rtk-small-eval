from django.contrib.auth import models
from django.db.models import Max

# Let's trace the full compilation
a = models.User.objects.filter(email__isnull=True).values('email').annotate(m=Max('id')).values('m')[:1]

# The original query
print('=== Original inner query ===')
print('group_by:', a.query.group_by)
print('select:', a.query.select)
print('default_cols:', a.query.default_cols)
print('annotation_select:', dict(a.query.annotation_select))
print('values_select:', a.query.values_select)

# Now simulate what happens during filter(id=a[:1])
from django.db.models.sql.query import Query
b = models.User.objects.filter(id=a[:1])

# The inner query after resolve_expression
child = b.query.where.children[0]
rhs = child.rhs
print()
print('=== Inner query after resolve_expression ===')
print('group_by:', rhs.group_by)
print('select:', rhs.select)
print('default_cols:', rhs.default_cols)
print('annotation_select:', dict(rhs.annotation_select))
print('values_select:', rhs.values_select)

# Now compile the inner query
from django.db import connection
inner_compiler = rhs.get_compiler(connection=connection)
print()
print('=== Before inner compiler as_sql ===')
print('group_by:', inner_compiler.query.group_by)

# Let's trace get_group_by
inner_compiler.setup_query()
print('After setup_query:')
print('select:', inner_compiler.select)
print('group_by:', inner_compiler.query.group_by)

extra_select, order_by, group_by = inner_compiler.pre_sql_setup()
print('After pre_sql_setup:')
print('group_by expressions:', group_by)
