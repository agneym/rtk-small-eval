from django.apps import apps
apps.clear_cache()

import importlib
import testapp.models
django.setup()

new_state = ProjectState.from_apps(django.apps.apps)

from django.db.migrations.questioner import MigrationQuestioner
from django.db.migrations.autodetector import MigrationAutodetector
from django.db.migrations.graph import MigrationGraph

autodetector = MigrationAutodetector(old_state, new_state, MigrationQuestioner())

# Monkey-patch add_operation to track what's added
original_add_op = autodetector.add_operation
added_ops = []

def tracking_add_op(app_label, operation, dependencies=None, beginning=False):
    added_ops.append((app_label, operation.__class__.__name__, operation.describe()))
    return original_add_op(app_label, operation, dependencies, beginning)

autodetector.add_operation = tracking_add_op

graph = MigrationGraph()
changes = autodetector.changes(graph=graph)

print(f""\nAll operations added during autodetection:"")
for app_label, op_cls, desc in added_ops:
    print(f""  [{app_label}] {op_cls}: {desc}"")

print(f""\nNumber of migrations generated: {len(changes.get('testapp', []))}"")
for migration in changes.get('testapp', []):
    print(f""  Migration name: {migration.name}"")
    for op in migration.operations:
        print(f""    - {op.__class__.__name__}: {op.describe()}"")
