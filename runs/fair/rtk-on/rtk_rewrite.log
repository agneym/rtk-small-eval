import re

# Read the file
with open('django/db/models/sql/query.py', 'r') as f:
    content = f.read()

# The fix: change the early return to only return when defer is True
# Find and replace the lines
old = '''        field_names, defer = self.deferred_loading
        if not field_names:
            return
        orig_opts = self.get_meta()
        seen = {}
        must_include = {orig_opts.concrete_model: {orig_opts.pk}}'''

new = '''        field_names, defer = self.deferred_loading
        if not field_names:
            if defer:
                return
        orig_opts = self.get_meta()
        seen = {}
        must_include = {orig_opts.concrete_model: {orig_opts.pk}}'''

content = content.replace(old, new)

with open('django/db/models/sql/query.py', 'w') as f:
    f.write(content)

print('Done')
""
