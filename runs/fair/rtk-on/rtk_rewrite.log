print()
collector = Collector(using='default')
print(f'can_fast_delete(Origin queryset): {collector.can_fast_delete(Origin.objects.all())}')
print(f'can_fast_delete(Referrer queryset): {collector.can_fast_delete(Referrer.objects.all())}')
print(f'can_fast_delete(User queryset): {collector.can_fast_delete(User.objects.all())}')
