assert result[0].start == 1

# Test with regular tuple in __range
result2 = list(TestModel.objects.filter(start__range=(1, 5)))
print(f'Regular tuple range query returned {len(result2)} results: {[r.start for r in result2]}')
assert len(result2) == 1
assert result2[0].start == 1

print()
print('End-to-end tests passed!')
