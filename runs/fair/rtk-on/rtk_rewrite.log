import django, os, json
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')
django.setup()

from django.contrib.admin.utils import display_for_field
from django.db import models
from django.forms.fields import InvalidJSONInput

# Test with custom encoder
class CustomEncoder(json.JSONEncoder):
    pass

field = models.JSONField(encoder=CustomEncoder)
value = {'foo': 'bar'}
result = display_for_field(value, field, '')
print(f'Test with custom encoder:')
print(f'  Result:   {result!r}')
print(f'  Match: {result == json.dumps(value, cls=CustomEncoder)}')

# Test with InvalidJSONInput (to ensure it's returned as-is)
field = models.JSONField()
value = InvalidJSONInput('invalid json')
result = display_for_field(value, field, '')
print(f'Test with InvalidJSONInput:')
print(f'  Result:   {result!r}')
print(f'  Type:     {type(result)}')
print(f'  Match: {result == \""invalid json\""}')

# Run existing tests to make sure nothing is broken
print()
print('Running existing admin_utils tests...')
""
