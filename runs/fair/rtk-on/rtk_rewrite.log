import re

with open('django/db/models/deletion.py', 'r') as f:
    content = f.read()

# Replace the early return with the fix
old = '''        if not new_objs:
            return'''

new = '''        if not new_objs:
            if hasattr(objs, 'model'):
                self.data.setdefault(objs.model, set())
            return'''

