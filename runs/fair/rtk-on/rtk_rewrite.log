import django
from django.conf import settings
if not settings.configured:
    settings.configure(
        DATABASES={'default': {'ENGINE': 'django.db.backends.sqlite3', 'NAME': ':memory:'}},
        INSTALLED_APPS=['django.contrib.contenttypes', 'django.contrib.auth'],
        DEFAULT_AUTO_FIELD='django.db.models.BigAutoField',
    )
    django.setup()

from django import forms
from django.core.exceptions import ValidationError

# Create a simple model to test with
from django.db import models

# Define a simple model
class TestModel(models.Model):
    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'

# Create the table
from django.db import connection
with connection.schema_editor() as schema_editor:
    schema_editor.create_model(TestModel)

# Create a test instance
TestModel.objects.create(name='existing')

# Test ModelChoiceField
field = forms.ModelChoiceField(queryset=TestModel.objects.all())
try:
    field.clean('nonexistent')
except ValidationError as e:
    print('ModelChoiceField error message:', e.message)
    print('ModelChoiceField params:', e.params)
    assert 'nonexistent' in str(e.message), 'Value should be in error message'
    print('PASS: ModelChoiceField includes invalid value in error message')

# Test with valid value
obj = field.clean(TestModel.objects.first().pk)
print('Valid value works correctly:', obj)

# Clean up
with connection.schema_editor() as schema_editor:
    schema_editor.delete_model(TestModel)

print()
print('All tests passed!')
