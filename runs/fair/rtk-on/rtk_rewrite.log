from enum import Enum, IntEnum
from django.db.migrations.serializer import serializer_factory

# Test regular Enum
class Status(Enum):
    GOOD = 'Good'
    BAD = 'Bad'

class Color(Enum):
    RED = 1
    GREEN = 2

class BinaryEnum(Enum):
    A = b'a-value'
    B = b'value-b'

# Test IntEnum
class MyIntEnum(IntEnum):
    A = 1
    B = 2

for name, member in [('Status.GOOD', Status.GOOD), ('Color.RED', Color.RED), 
                      ('BinaryEnum.A', BinaryEnum.A), ('MyIntEnum.B', MyIntEnum.B)]:
    result, imports = serializer_factory(member).serialize()
    print(f'{name}: {result!r}, imports={imports}')
    # Verify the result can be evaluated if we set up the right context
    try:
        import sys
        this_module = sys.modules[__name__]
        eval_result = eval(result, {'__main__': __import__('__main__')})
        print(f'  -> {eval_result}, is same: {eval_result is member}')
    except Exception as e:
        print(f'  -> eval failed: {e}')
