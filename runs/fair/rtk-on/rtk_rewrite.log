        # The method starts at i, the docstring is at i+1, i+2, i+3
        # We need to insert after the closing """""" at i+3
        assert '""""""' in lines[i+3], f""Expected docstring close at line {i+3}, got: {lines[i+3]}""
        # Insert the check after the docstring
        indent = '        '
        lines.insert(i+4, indent + ""self._not_support_combined_queries('distinct')\n"")
        break

with open('django/db/models/query.py', 'w') as f:
    f.writelines(lines)

print(""Done"")
