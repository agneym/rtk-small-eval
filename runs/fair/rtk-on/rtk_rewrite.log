from django.utils.http import parse_http_date
from datetime import datetime

# Test year 70 - should be 2070 (44 years in future from 2026, not > 50)
result = parse_http_date('Sunday, 06-Nov-70 08:49:37 GMT')
dt = datetime.utcfromtimestamp(result)
print(f'Year 70 -> {dt.year} (expected: 2070)')

# Test year 99 - should be 1999 (73 years in future, > 50)
result = parse_http_date('Sunday, 06-Nov-99 08:49:37 GMT')
dt = datetime.utcfromtimestamp(result)
print(f'Year 99 -> {dt.year} (expected: 1999)')

# Test year 37 - should be 2037 (11 years in future, not > 50)
result = parse_http_date('Sun Nov  6 08:49:37 0037')
dt = datetime.utcfromtimestamp(result)
print(f'Year 37 (0037) -> {dt.year} (expected: 2037)')

# Test year 94 - should be 1994 (68 years in future, > 50)
result = parse_http_date('Sunday, 06-Nov-94 08:49:37 GMT')
dt = datetime.utcfromtimestamp(result)
print(f'Year 94 -> {dt.year} (expected: 1994)')

# Test full 4-digit year still works
result = parse_http_date('Sun, 06 Nov 1994 08:49:37 GMT')
dt = datetime.utcfromtimestamp(result)
print(f'Year 1994 -> {dt.year} (expected: 1994)')

print('All tests passed!')
