    name = models.CharField(max_length=100)
    class Meta:
        app_label = 'test'
        # Need to set db_table to avoid clashes
        db_table = 'test_author'

class Book(models.Model):
    title = models.CharField(max_length=100)
    author = models.ForeignKey(Author, models.CASCADE)
    class Meta:
        app_label = 'test'
        db_table = 'test_book'

# Register models
