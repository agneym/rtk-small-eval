2026-06-24T09:31:42+00:00,ee25d82e7c204f2c9a8394d60b71da81,1,"cd /testbed && python -c ""
from astropy.modeling import models as m
from astropy.modeling.separable import separability_matrix, is_separable
import numpy as np

# Test 1: Simple nested compound model
cm1 = m.Linear1D(10) & m.Linear1D(5)
cm2 = m.Linear1D(3) & m.Linear1D(7)
nested = cm1 & cm2
print('Test 1: Nested & models')
print(separability_matrix(nested))
print()

# Test 2: Three levels deep
deep = m.Shift(1) & (m.Linear1D(10) & (m.Linear1D(5) & m.Linear1D(3)))
print('Test 2: Three levels deep')
print(separability_matrix(deep))
expected = separability_matrix(m.Shift(1) & m.Linear1D(10) & m.Linear1D(5) & m.Linear1D(3))
print('Expected:')
print(expected)
print('Match:', np.array_equal(separability_matrix(deep), expected))
print()

# Test 3: Nested with non-separable model
cm = m.Linear1D(10) & m.Linear1D(5)
nested2 = m.Rotation2D(90) & cm
print('Test 3: Rotation2D & (Linear1D & Linear1D)')
print(separability_matrix(nested2))
expected2 = separability_matrix(m.Rotation2D(90) & m.Linear1D(10) & m.Linear1D(5))
print('Expected:')
print(expected2)
print('Match:', np.array_equal(separability_matrix(nested2), expected2))
print()

# Test 4: is_separable function
print('Test 4: is_separable')
print('is_separable(cm):', is_separable(cm))
print('is_separable(m.Pix2Sky_TAN() & cm):', is_separable(m.Pix2Sky_TAN() & cm))
print()

# Test 5: Original docs example
from astropy.modeling.models import Shift, Scale, Rotation2D, Polynomial2D, Mapping
print('Test 5: Doc examples')
print(is_separable(Shift(1) & Shift(2) | Scale(1) & Scale(2)))
print(is_separable(Shift(1) & Shift(2) | Rotation2D(2)))
print(is_separable(Shift(1) & Shift(2) | Mapping([0, 1, 0, 1]) | Polynomial2D(1) & Polynomial2D(2)))
print(is_separable(Shift(1) & Shift(2) | Mapping([0, 1, 0, 1])))
""",
