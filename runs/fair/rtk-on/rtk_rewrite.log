import os
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'tests.test_sqlite')

# Read the current file
with open('django/db/models/fields/json.py', 'r') as f:
    content = f.read()

# Replace the KeyTransformIsNull class
old_class = '''class KeyTransformIsNull(lookups.IsNull):
    # key__isnull=False is the same as has_key='key'
    def as_oracle(self, compiler, connection):
        if not self.rhs:
            return HasKey(self.lhs.lhs, self.lhs.key_name).as_oracle(compiler, connection)
        return super().as_sql(compiler, connection)

    def as_sqlite(self, compiler, connection):
        if not self.rhs:
            return HasKey(self.lhs.lhs, self.lhs.key_name).as_sqlite(compiler, connection)
        return super().as_sql(compiler, connection)'''

new_class = '''class KeyTransformIsNull(lookups.IsNull):
    # key__isnull=False is the same as has_key='key'
    def as_oracle(self, compiler, connection):
        if not self.rhs:
            return HasKey(self.lhs.lhs, self.lhs.key_name).as_oracle(compiler, connection)
        else:
            # Use the negation of HasKey for isnull=True.
            has_key_sql, has_key_params = HasKey(
                self.lhs.lhs, self.lhs.key_name
            ).as_oracle(compiler, connection)
            return 'NOT ' + has_key_sql, has_key_params

    def as_sqlite(self, compiler, connection):
        if not self.rhs:
            return HasKey(self.lhs.lhs, self.lhs.key_name).as_sqlite(compiler, connection)
        else:
            # Use JSON_TYPE instead of JSON_EXTRACT for isnull=True on SQLite.
            # JSON_TYPE returns NULL if the key doesn't exist, and the type
            # string (e.g., 'null' for JSON null) if the key exists.
            lhs, params, key_transforms = self.lhs.preprocess_lhs(
                compiler, connection,
            )
            json_path = compile_json_path(key_transforms)
            return 'JSON_TYPE(%s, %%s) IS NULL' % lhs, tuple(params) + (json_path,)'''

content = content.replace(old_class, new_class)

with open('django/db/models/fields/json.py', 'w') as f:
    f.write(content)

print(""Done"")
EOF
