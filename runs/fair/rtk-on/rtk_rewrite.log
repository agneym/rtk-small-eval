print(f'Different params: {e1 == e3}')  # Should be False

print()
print('=== List Form (same order) ===')
e1 = ValidationError(['err1', 'err2'])
e2 = ValidationError(['err1', 'err2'])
print(f'Same order: {e1 == e2}')  # Should be True

print()
print('=== List Form (different order) ===')
e1 = ValidationError(['err1', 'err2'])
e2 = ValidationError(['err2', 'err1'])
print(f'Different order: {e1 == e2}')  # Should be True

print()
print('=== List Form with duplicates ===')
e1 = ValidationError(['err1', 'err1'])
e2 = ValidationError(['err1', 'err1'])
e3 = ValidationError(['err1'])
print(f'Duplicates same: {e1 == e2}')  # Should be True
print(f'Duplicates vs single: {e1 == e3}')  # Should be False

print()
print('=== Dict Form (same) ===')
e1 = ValidationError({'field1': ['err1'], 'field2': ['err2']})
e2 = ValidationError({'field1': ['err1'], 'field2': ['err2']})
print(f'Same dict: {e1 == e2}')  # Should be True

print()
print('=== Dict Form (different field order) ===')
e1 = ValidationError({'field1': ['err1'], 'field2': ['err2']})
e2 = ValidationError({'field2': ['err2'], 'field1': ['err1']})
print(f'Different field order: {e1 == e2}')  # Should be True

print()
print('=== Dict Form (different error order in field) ===')
e1 = ValidationError({'field1': ['err1', 'err2']})
e2 = ValidationError({'field1': ['err2', 'err1']})
print(f'Different error order in field: {e1 == e2}')  # Should be True

print()
print('=== Dict Form (different fields) ===')
e1 = ValidationError({'field1': ['err1']})
e2 = ValidationError({'field2': ['err1']})
print(f'Different fields: {e1 == e2}')  # Should be False

print()
print('=== Cross-type comparisons ===')
e1 = ValidationError('msg')
e2 = ValidationError(['msg'])
e3 = ValidationError({'field': ['msg']})
print(f'simple == list (same message): {e1 == e2}')  # Both have error_list, should be True
print(f'simple == dict: {e1 == e3}')  # Should be False (different structure)
print(f'list == dict: {e2 == e3}')  # Should be False (different structure)

print()
print('=== Non-ValidationError comparison ===')
e = ValidationError('msg')
print(f'ValidationError == str: {e == \""msg\""}')  # Should be False (returns NotImplemented)

print()
print('=== NOT EQUAL ===')
e1 = ValidationError('msg1')
e2 = ValidationError('msg2')
print(f'Different messages: {e1 != e2}')  # Should be True

print()
print('=== Empty list form ===')
e1 = ValidationError([])
e2 = ValidationError([])
print(f'Empty list same: {e1 == e2}')  # Should be True
