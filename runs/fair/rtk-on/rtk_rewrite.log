from django.forms import MultiWidget, TextInput

# Test that MultiWidget no longer has its own id_for_label method
w = MultiWidget(widgets=(TextInput(), TextInput()))

# After removing MultiWidget.id_for_label, it should use Widget.id_for_label
# which returns id_ unchanged (no _0 suffix)
result = w.id_for_label('id_test')
print(f'id_for_label result: {repr(result)}')
assert result == 'id_test', f'Expected \""id_test\"", got {result!r}'

# Test with empty/None should return the same
result2 = w.id_for_label('')
print(f'id_for_label empty: {repr(result2)}')
assert result2 == ''

# Check that it inherits from Widget
from django.forms import Widget
assert isinstance(w, Widget)
print('All assertions passed!')
