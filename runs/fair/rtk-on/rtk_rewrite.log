    before_state.add_model(ms.clone())

after_state = ProjectState()
for ms in after:
    after_state.add_model(ms.clone())

# Check the FK to_field values in both states
old_fk = before_state.apps.get_model('app1', 'ModelB')._meta.get_field('modela')
new_fk = after_state.apps.get_model('app1', 'ModelB')._meta.get_field('modela')
print(f'Old FK field_name: {old_fk.remote_field.field_name}')
print(f'Old FK pk name: {old_fk.remote_field.model._meta.pk.name}')
print(f'New FK field_name: {new_fk.remote_field.field_name}')
print(f'New FK pk name: {new_fk.remote_field.model._meta.pk.name}')

