2026-06-24T09:18:37+00:00,1dd854ce221b4ee5961e09a3edd98fff,1,"cd /testbed && python3 -c ""
from astropy.modeling import models as m
from astropy.modeling.separable import separability_matrix, is_separable
import numpy as np

# Test 1: Deeply nested compound models
print('=== Test 1: Deeply nested ===')
cm1 = m.Linear1D(10) & m.Linear1D(5)
cm2 = m.Linear1D(3) & cm1
print('Linear1D(3) & (Linear1D(10) & Linear1D(5)):')
print(separability_matrix(cm2))
print()

# Test 2: Two levels of nesting
print('=== Test 2: Two levels of nesting ===')
cm_deep = m.Pix2Sky_TAN() & (m.Linear1D(1) & (m.Linear1D(2) & m.Linear1D(3)))
print('Pix2Sky_TAN() & (Linear1D(1) & (Linear1D(2) & Linear1D(3))):')
print(separability_matrix(cm_deep))
print()

# Test 3: Using | operator with nested models
print('=== Test 3: Nested with | operator ===')
cm3 = m.Linear1D(10) & m.Linear1D(5)
cm4 = m.Scale(2) & m.Scale(3)
cm_combined = cm3 | cm4
print('(Linear1D(10) & Linear1D(5)) | (Scale(2) & Scale(3)):')
print(separability_matrix(cm_combined))
print()

# Test 4: is_separable with nested
print('=== Test 4: is_separable with nested ===')
print('is_separable(Pix2Sky_TAN() & cm):')
print(is_separable(m.Pix2Sky_TAN() & cm))
print()

# Test 5: Verify flat vs nested give same results
print('=== Test 5: Flat vs nested consistency ===')
flat = m.Pix2Sky_TAN() & m.Linear1D(10) & m.Linear1D(5)
nested = m.Pix2Sky_TAN() & (m.Linear1D(10) & m.Linear1D(5))
print('Flat:')
print(separability_matrix(flat))
print('Nested:')
print(separability_matrix(nested))
print('Equal:', np.array_equal(separability_matrix(flat), separability_matrix(nested)))
""
